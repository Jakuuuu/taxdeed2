<!DOCTYPE html>
<html lang="en" style="margin:0;padding:0;background:#F0F2F5;">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Title Search Report is Ready</title>
</head>
<body style="font-family:'Helvetica Neue',Arial,sans-serif;margin:0;padding:40px 20px;background:#F0F2F5;">

  <div style="max-width:560px;margin:0 auto;">

    <!-- Header -->
    <div style="background:#1E3A5F;border-radius:10px 10px 0 0;padding:24px 32px;text-align:center;">
      <h1 style="margin:0;font-size:1.25rem;font-weight:800;color:#fff;letter-spacing:0.02em;">
        Tax Sale <span style="color:#C9A84C;">Resources</span>
      </h1>
      <p style="margin:8px 0 0;font-size:0.8rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.1em;">
        Report Notification
      </p>
    </div>

    <!-- Body -->
    <div style="background:#fff;padding:32px;border:1px solid #DEE2E6;border-top:0;">
      <h2 style="margin:0 0 8px;font-size:1.15rem;font-weight:700;color:#1E3A5F;">
        Your Title Search Report is Ready ✅
      </h2>
      <p style="margin:0 0 24px;font-size:0.9375rem;color:#4B5563;line-height:1.6;">
        Hi <%= @user.first_name %>,
      </p>
      <p style="margin:0 0 24px;font-size:0.9375rem;color:#4B5563;line-height:1.6;">
        Your title search report for the following property has been completed and is ready to download:
      </p>

      <!-- Property Card -->
      <div style="background:#F8F9FA;border:1px solid #DEE2E6;border-radius:8px;padding:16px 20px;margin-bottom:24px;">
        <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6C757D;margin-bottom:4px;">
          Property Address
        </div>
        <div style="font-size:1rem;font-weight:700;color:#1E3A5F;">
          <%= @parcel&.address || "—" %>
        </div>
        <% if @parcel&.county.present? %>
          <div style="font-size:0.875rem;color:#6C757D;margin-top:4px;">
            <%= @parcel.county %>, <%= @parcel.state %>
          </div>
        <% end %>
        <% if @parcel&.parcel_id.present? %>
          <div style="font-size:0.75rem;color:#9CA3AF;margin-top:6px;">
            Parcel ID: <%= @parcel.parcel_id %>
          </div>
        <% end %>
      </div>

      <!-- CTA Button -->
      <div style="text-align:center;margin-bottom:24px;">
        <%= link_to "Download Your Report →",
              rails_blob_url(@report.pdf_file, disposition: "attachment"),
              style: "display:inline-block;background:#1E3A5F;color:#fff;font-size:0.9375rem;font-weight:700;text-decoration:none;padding:14px 32px;border-radius:8px;letter-spacing:0.02em;" %>
      </div>

      <p style="margin:0;font-size:0.875rem;color:#6C757D;line-height:1.6;">
        If the button above doesn't work, log in to your
        <a href="<%= research_purchased_reports_url %>" style="color:#C9A84C;">TaxDeed Lion dashboard</a>
        to access your report from the Reports section.
      </p>
    </div>

    <!-- Footer -->
    <div style="background:#F8F9FA;border:1px solid #DEE2E6;border-top:0;border-radius:0 0 10px 10px;padding:16px 32px;text-align:center;">
      <p style="margin:0;font-size:0.78rem;color:#9CA3AF;line-height:1.6;">
        TaxDeed Lion · Internal Operations ·
        <a href="<%= root_url %>" style="color:#9CA3AF;">taxsaleresources.com</a>
      </p>
    </div>

  </div>
</body>
</html>

<% content_for :title, @auction.jurisdiction %>

<div class="admin-breadcrumb">
  <%= link_to "Auctions", admin_auctions_path %>
  <span class="admin-breadcrumb__sep">›</span>
  <span><%= @auction.jurisdiction %></span>
</div>

<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">
      <%= @auction.jurisdiction %>
      <span class="badge badge-<%= @auction.status %>" style="font-size:0.8rem;padding:0.2rem 0.7rem;border-radius:20px;vertical-align:middle;margin-left:0.5rem;">
        <%= @auction.status&.capitalize %>
      </span>
    </h1>
    <p class="admin-page-subtitle">
      <%= @auction.auction_type&.humanize %> — Sale: <%= @auction.sale_date&.strftime("%B %d, %Y") || "No date" %>
    </p>
  </div>
  <div class="admin-page-actions" style="display:flex;gap:0.5rem;align-items:center;">
    <%= link_to "Edit", edit_admin_auction_path(@auction), class: "btn-sm btn-sm-outline" %>

    <%# Status change button (secuencial: upcoming→active→completed) %>
    <% next_statuses = { "upcoming" => "active", "active" => "completed" } %>
    <% next_status = next_statuses[@auction.status] %>
    <% if next_status %>
      <%= form_with url: change_status_admin_auction_path(@auction), method: :patch, local: true, style: "display:inline;" do |f| %>
        <%= hidden_field_tag :new_status, next_status %>
        <button type="submit" class="btn-sm btn-sm-primary"
                onclick="return confirm('Change status to <%= next_status.capitalize %>?')">
          → Mark as <%= next_status.capitalize %>
        </button>
      <% end %>
    <% end %>

    <%# Delete button (solo si no tiene parcels) %>
    <% if @auction.parcels.exists? %>
      <span style="font-size:0.75rem;color:#6C757D;padding:0.4rem 0;">
        🔒 Has parcels — cannot delete
      </span>
    <% else %>
      <%= button_to "🗑 Delete", admin_auction_path(@auction), method: :delete,
            class: "btn-sm btn-sm-outline",
            style: "color:#DC2626;border-color:#DC2626;",
            form: { data: { turbo_confirm: "Delete this auction permanently? This cannot be undone." } } %>
    <% end %>
  </div>
</div>

<%# ── Mini Stats Strip ──────────────────────────────────────────── %>
<div class="admin-stat-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:1.25rem;">
  <div class="admin-stat-card">
    <div class="admin-stat-card__label">Total Parcels</div>
    <div class="admin-stat-card__value"><%= @auction.parcel_count || @auction.parcels.count %></div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-card__label">Total Amount</div>
    <div class="admin-stat-card__value" style="font-family:'JetBrains Mono',monospace;font-size:1.2rem;">
      <%= @auction.formatted_amount || "—" %>
    </div>
  </div>
  <div class="admin-stat-card admin-stat-card--accent">
    <div class="admin-stat-card__label">Days Until Sale</div>
    <div class="admin-stat-card__value">
      <% if @auction.days_until_sale %>
        <%= @auction.days_until_sale %>
      <% elsif @auction.sale_date && @auction.sale_date < Date.current %>
        <span style="color:#6C757D;font-size:0.9rem;">Past</span>
      <% else %>
        —
      <% end %>
    </div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-card__label">Status</div>
    <div class="admin-stat-card__value" style="font-size:1rem;">
      <span class="badge badge-<%= @auction.status %>" style="padding:0.2rem 0.7rem;border-radius:20px;font-size:0.85rem;">
        <%= @auction.status&.capitalize %>
      </span>
    </div>
  </div>
</div>

<%# ── Timeline de Fechas ────────────────────────────────────────── %>
<div class="admin-card" style="margin-bottom:1.25rem;">
  <div class="admin-card__header">
    <h2 class="admin-card__title">📅 Auction Timeline</h2>
  </div>
  <div class="admin-card__body">
    <div style="display:flex;align-items:center;gap:0;overflow-x:auto;padding:0.5rem 0;">
      <%
        timeline_dates = [
          { label: "Registration Opens", date: @auction.registration_opens },
          { label: "Registration Deadline", date: @auction.registration_deadline },
          { label: "Bidding Start", date: @auction.bidding_start },
          { label: "Sale Date", date: @auction.sale_date },
          { label: "End Date", date: @auction.end_date }
        ]
      %>
      <% timeline_dates.each_with_index do |item, idx| %>
        <div style="display:flex;flex-direction:column;align-items:center;min-width:120px;flex:1;position:relative;">
          <%# Connector line %>
          <% if idx > 0 %>
            <div style="position:absolute;top:14px;right:50%;width:100%;height:2px;
                        background:<%= item[:date] ? '#C9A84C' : '#E5E7EB' %>;z-index:0;"></div>
          <% end %>
          <%# Dot %>
          <div style="width:12px;height:12px;border-radius:50%;z-index:1;
                      background:<%= item[:date] ? '#C9A84C' : '#D1D5DB' %>;
                      border:2px solid <%= item[:date] ? '#1E3A5F' : '#E5E7EB' %>;"></div>
          <%# Label %>
          <div style="font-size:0.72rem;color:#6C757D;margin-top:0.4rem;text-align:center;line-height:1.2;">
            <%= item[:label] %>
          </div>
          <%# Date %>
          <div style="font-size:0.8rem;font-weight:600;color:<%= item[:date] ? '#1E3A5F' : '#D1D5DB' %>;
                      margin-top:0.15rem;text-align:center;">
            <%= item[:date]&.strftime("%b %d, %Y") || "—" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Auction Details ────────────────────────────────────────────── %>
<div class="admin-card" style="margin-bottom:1.25rem;">
  <div class="admin-card__header">
    <h2 class="admin-card__title">🏛️ Auction Details</h2>
  </div>
  <div class="admin-card__body">
    <div class="admin-detail-grid">
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">County</div>
        <div class="admin-detail-item__value"><%= @auction.county %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">State</div>
        <div class="admin-detail-item__value"><%= @auction.state %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">Type</div>
        <div class="admin-detail-item__value"><%= @auction.auction_type&.humanize || "—" %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">Sale Date</div>
        <div class="admin-detail-item__value"><%= @auction.sale_date&.strftime("%B %d, %Y") || "—" %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">Registration Deadline</div>
        <div class="admin-detail-item__value"><%= @auction.registration_deadline&.strftime("%B %d, %Y") || "—" %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">Registration Opens</div>
        <div class="admin-detail-item__value"><%= @auction.registration_opens&.strftime("%B %d, %Y") || "—" %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">Bidding Start</div>
        <div class="admin-detail-item__value"><%= @auction.bidding_start&.strftime("%B %d, %Y") || "—" %></div>
      </div>
      <div class="admin-detail-item">
        <div class="admin-detail-item__label">End Date</div>
        <div class="admin-detail-item__value"><%= @auction.end_date&.strftime("%B %d, %Y") || "—" %></div>
      </div>
    </div>

    <%# URLs %>
    <% if @auction.bidding_url.present? || @auction.source_url.present? %>
      <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #E5E7EB;">
        <div style="font-size:0.75rem;font-weight:600;color:#6C757D;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.5rem;">
          External Links
        </div>
        <div style="display:flex;gap:1.5rem;flex-wrap:wrap;">
          <% if @auction.bidding_url.present? %>
            <a href="<%= @auction.bidding_url %>" target="_blank"
               style="color:#C9A84C;font-size:0.85rem;font-weight:500;text-decoration:none;">
              🔗 Bidding Page ↗
            </a>
          <% end %>
          <% if @auction.source_url.present? %>
            <a href="<%= @auction.source_url %>" target="_blank"
               style="color:#C9A84C;font-size:0.85rem;font-weight:500;text-decoration:none;">
              📄 Source URL ↗
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Coordinates %>
    <% if @auction.latitude.present? && @auction.longitude.present? %>
      <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #E5E7EB;">
        <div style="font-size:0.75rem;font-weight:600;color:#6C757D;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.5rem;">
          📍 Coordinates
        </div>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;color:#1E3A5F;">
          <%= @auction.latitude %>, <%= @auction.longitude %>
        </span>
      </div>
    <% end %>
  </div>
</div>

<%# ── Notes ──────────────────────────────────────────────────────── %>
<% if @auction.notes.present? %>
  <div class="admin-card" style="margin-bottom:1.25rem;">
    <div class="admin-card__header"><h2 class="admin-card__title">📝 Notes</h2></div>
    <div class="admin-card__body">
      <p style="font-size:0.9rem;color:#4B5563;line-height:1.6;margin:0;white-space:pre-wrap;"><%= @auction.notes %></p>
    </div>
  </div>
<% end %>

<%# ── Parcels table ──────────────────────────────────────────────── %>
<div class="admin-card">
  <div class="admin-card__header">
    <h2 class="admin-card__title">Associated Parcels (<%= @auction.parcel_count || @auction.parcels.count %>)</h2>
  </div>
  <% if @parcels.any? %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Parcel ID</th>
          <th>Address</th>
          <th>Property Type</th>
          <th style="text-align:right;">Assessed Value</th>
          <th style="text-align:right;">Opening Bid</th>
          <th>Sq Ft</th>
        </tr>
      </thead>
      <tbody>
        <% @parcels.each do |parcel| %>
          <tr>
            <td style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:#1E3A5F;">
              <%= parcel.parcel_id %>
            </td>
            <td style="font-weight:500;"><%= parcel.address || "—" %></td>
            <td style="font-size:0.875rem;"><%= parcel.property_type || "—" %></td>
            <td style="font-size:0.875rem;text-align:right;font-family:'JetBrains Mono',monospace;">
              <% if parcel.assessed_value %>
                $<%= number_with_delimiter(parcel.assessed_value.to_i) %>
              <% else %>—<% end %>
            </td>
            <td style="font-size:0.875rem;text-align:right;font-family:'JetBrains Mono',monospace;">
              <% if parcel.opening_bid %>
                $<%= number_with_delimiter(parcel.opening_bid.to_i) %>
              <% else %>—<% end %>
            </td>
            <td style="font-size:0.875rem;">
              <%= parcel.sqft_living ? number_with_delimiter(parcel.sqft_living.to_i) : "—" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @parcels.respond_to?(:current_page) && @parcels.total_pages > 1 %>
      <div class="admin-card__footer">
        <span style="font-size:0.8rem;color:#6C757D;">
          Showing <%= @parcels.offset_value + 1 %>–<%= [@parcels.offset_value + @parcels.limit_value, @parcels.total_count].min %>
          of <%= @parcels.total_count %>
        </span>
        <div style="display:flex;gap:0.4rem;">
          <% if @parcels.prev_page %>
            <%= link_to "← Prev", admin_auction_path(@auction, page: @parcels.prev_page), class: "btn-sm btn-sm-outline" %>
          <% end %>
          <% if @parcels.next_page %>
            <%= link_to "Next →", admin_auction_path(@auction, page: @parcels.next_page), class: "btn-sm btn-sm-outline" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="empty-state" style="padding:2rem;">
      <div class="empty-state__desc">No parcels associated with this auction yet.</div>
    </div>
  <% end %>
</div>

<%# ── Metadata Footer ────────────────────────────────────────────── %>
<div style="margin-top:1.25rem;padding:1rem;background:#F9FAFB;border-radius:8px;display:flex;gap:2rem;flex-wrap:wrap;">
  <div style="font-size:0.75rem;color:#9CA3AF;">
    <strong>ID:</strong> <%= @auction.id %>
  </div>
  <div style="font-size:0.75rem;color:#9CA3AF;">
    <strong>Created:</strong> <%= @auction.created_at.strftime("%b %d, %Y %H:%M") %>
  </div>
  <div style="font-size:0.75rem;color:#9CA3AF;">
    <strong>Updated:</strong> <%= @auction.updated_at.strftime("%b %d, %Y %H:%M") %>
  </div>
</div>

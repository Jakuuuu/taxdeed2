<%# ═══════════════════════════════════════════════════════
     US OVERVIEW — Atlas Layout
     Direct ERB translation of proposal-atlas.jsx + shared-ui.jsx
     ═══════════════════════════════════════════════════════ %>
<% content_for :title, "LionTaxdeed — US Overview" %>
<%= render "research/auctions/atlas_tokens" %>
<%= render "research/auctions/atlas_styles" %>

<%
  # ── Dynamic data from controller ──
  # Controller keys: :county, :state, :parcel_count, :auction_ids, :next_sale_date, :sale_dates
  county_rows = @county_rows || []
  total_props = county_rows.sum { |c| c[:parcel_count].to_i }
  active_counties = county_rows.count { |c| c[:next_sale_date].present? }
  top_counties = county_rows.sort_by { |c| -(c[:parcel_count].to_i) }.first(6)

  # Extract unique upcoming sale_dates with their county info for the agenda panel
  auctions_map = @auctions_by_state || {}
  state_data = auctions_map.values.first || {}
  state_auctions = state_data.is_a?(Hash) ? (state_data[:auctions] || []) : []
  upcoming_grouped = county_rows
    .select { |c| c[:next_sale_date].present? && c[:next_sale_date] >= Date.current }
    .group_by { |c| c[:next_sale_date] }
    .sort_by { |date, _| date }
    .first(5)
    .map do |date, counties|
      sorted_counties = counties.sort_by { |c| -c[:parcel_count].to_i }
      {
        date: date,
        county_names: sorted_counties.map { |c| c[:county] }.compact,
        counties_with_state: sorted_counties.map { |c| { name: c[:county], state: c[:state], parcel_count: c[:parcel_count].to_i } },
        parcel_count: counties.sum { |c| c[:parcel_count].to_i }
      }
    end
  total_auction_dates = @count_unique_dates || county_rows.flat_map { |c| c[:sale_dates] || [] }.uniq.size
%>

<div class="atlas" data-density="comfortable">
  <%# ── Tabs Row ── %>
  <div class="tabs-row">
    <div class="tabs">
      <button class="tab tab--active" data-atlas-tab="auctions">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
        <span>Tax Sale Auctions</span>
      </button>
      <%# Prior Sale Results tab — HIDDEN per client decision (not selling this data for now) %>
    </div>
    <div class="view-controls">
      <div class="view-toggle">
        <button class="view-btn view-btn--active" data-view="map" title="Map view" onclick="atlasView(this, 'map')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6 9 4l6 2 6-2v14l-6 2-6-2-6 2z"/><path d="M9 4v16M15 6v16"/></svg>
        </button>
        <button class="view-btn" data-view="calendar" title="Calendar view" onclick="atlasView(this, 'calendar')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></svg>
        </button>
        <button class="view-btn" data-view="table" title="Table view" onclick="atlasView(this, 'table')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 10h18M3 16h18M9 4v16M15 4v16"/></svg>
        </button>
      </div>
      <button class="ghost-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h18l-7 9v6l-4-2v-4z"/></svg>
        <span>Filters</span>
      </button>

    </div>
  </div>

  <%# Prior Sale Results panel — HIDDEN per client decision %>
  <% if false # Prior Sale Results disabled %>
    <div class="atlas__prior" id="atlasPriorPanel">
      <%= render "research/auctions/list_view" %>
    </div>
  <% end %>
  <%# ═══════════════════════════════════════
       MAP STAGE — fullbleed map with floating glass panels
       ═══════════════════════════════════════ %>
  <div class="atlas__stage" id="atlasStage">

    <%# Background grid + compass + coordinates %>
    <div class="atlas__map-bg">
      <div class="atlas__compass">
        <span class="atlas__compass-n">N</span>
        <svg viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3"/><path d="M20 4 L23 20 L20 36 L17 20 Z" fill="currentColor" opacity="0.4"/></svg>
      </div>
      <div class="atlas__coord">26.97°N — 81.78°W</div>
      <div class="atlas__map-wrap" id="atlasMapWrap">
        <%# SVG Florida map rendered by JS %>
      </div>


    </div>

    <%# ── Floating panel: State pill + title block ── %>
    <div class="atlas__top-panel" data-panel-id="state-pill" data-panel-label="State Overview" data-panel-default-pos='{"left":24,"top":24}'>
      <div class="atlas__state-pill" id="atlasStatePill">
        <span class="atlas__state-flag" aria-hidden="true">
          <svg viewBox="0 0 24 16" width="22" height="14"><rect width="24" height="16" fill="#fff"/><g fill="#b22234"><rect y="0" width="24" height="1.23"/><rect y="2.46" width="24" height="1.23"/><rect y="4.92" width="24" height="1.23"/><rect y="7.38" width="24" height="1.23"/><rect y="9.84" width="24" height="1.23"/><rect y="12.30" width="24" height="1.23"/><rect y="14.76" width="24" height="1.23"/></g><rect width="10" height="8.61" fill="#3c3b6e"/></svg>
        </span>
        <div>
          <div class="atlas__state-label">Active state</div>
          <div class="atlas__state-name" id="atlasStateName"><%= @active_state[:name] %></div>
        </div>
        <span class="atlas__state-count" id="atlasStateCount"><%= active_counties %> counties</span>
        <button class="atlas__state-switch" id="atlasStateSwitch" aria-label="Switch state" aria-expanded="false" aria-controls="atlasStateMenu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>

        <%# ── Inline glass dropdown — opens on chevron click ── %>
        <div class="atlas__state-menu" id="atlasStateMenu" role="listbox" hidden>
          <% atlas_states.each do |st| %>
            <button type="button"
                    class="atlas__state-menu-item<%= ' is-active' if st[:abbr] == @active_state[:abbr] %>"
                    role="option"
                    data-state-abbr="<%= st[:abbr] %>"
                    data-state-name="<%= st[:name] %>">
              <span class="atlas__state-menu-name"><%= st[:name] %></span>
              <span class="atlas__state-menu-meta"><%= st[:county_count] %> counties</span>
            </button>
          <% end %>
        </div>
      </div>

      <div class="atlas__title-block">
        <h1 class="atlas__title">
          <span class="atlas__title-eyebrow">Tax deed auction map</span>
          <span id="atlasStateOverview"><%= @active_state[:name] %> overview</span>
        </h1>
        <p class="atlas__subtitle"><%= active_counties %> counties · <%= total_auction_dates %> upcoming auction dates · <%= number_with_delimiter(total_props) %> properties up for bid</p>
      </div>
    </div>

    <%# ── Static right column: Top Opps / CRM Cal / Next Auctions ── %>
    <div class="atlas__right-column">

      <%# ── Top Opportunities — pre-qualified "optimo" properties ── %>
      <div class="atlas__right-panel atlas-panel--minimized" data-panel-id="top-opportunities" data-panel-label="Top Opportunities">
        <div class="section-title">
          <div class="section-title__main">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Top Opportunities
          </div>
          <a href="<%= research_clear_to_bid_path %>" class="atlas__see-all">
            See all
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="panel-body">
          <%= render "research/auctions/top_opportunities",
                     parcels: (@top_opportunity_parcels || []),
                     premier_access: (current_user.admin? || current_user.subscription&.premier_active? || false) %>
        </div>
      </div>

      <%# ── CRM Auction Calendar panel ── %>
      <%# SOURCE: @crm_calendar_events — scoped to current_user.pipeline_properties (SECURITY) %>
      <div class="atlas__crm-calendar atlas-panel--minimized"
           data-panel-id="crm-calendar"
           data-panel-label="My CRM Calendar"
           data-events="<%= (@crm_calendar_events || {}).to_json %>"
           aria-label="CRM Auction Calendar">
        <div class="section-title">
          <div class="section-title__main">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/><circle cx="12" cy="16" r="1" fill="currentColor"/></svg>
            My CRM Calendar
          </div>
          <% crm_count = (@crm_calendar_events || {}).values.sum(&:size) %>
          <span class="count-pill count-pill--circle count-pill--accent"><%= crm_count %></span>
        </div>
        <div class="panel-body" id="crmCalendarBody">
          <div class="crm-cal__grid" id="crmCalGrid"></div>
          <div class="crm-cal__legend">
            <span class="crm-cal__dot"></span>
            <span class="crm-cal__legend-label">Auction in your pipeline</span>
          </div>
        </div>
      </div>

      <%# ── Next Auctions ── %>
      <div class="atlas__left-panel atlas-panel--minimized" data-panel-id="agenda" data-panel-label="Next Auctions">
        <div class="section-title">
          <div class="section-title__main">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></svg>
            Next auctions
          </div>
          <span class="count-pill count-pill--circle"><%= upcoming_grouped.size %></span>
        </div>
        <div class="panel-body">
        <div class="agenda-list">
        <% upcoming_grouped.each_with_index do |entry, idx| %>
          <%
            auction_date = entry[:date]
            diff_days    = (auction_date.to_date - Date.today).to_i
            month_str    = auction_date.strftime("%b").upcase
            day_str      = auction_date.strftime("%d")
            weekday_str  = auction_date.strftime("%A")
            when_label   = diff_days == 0 ? "today" : diff_days == 1 ? "tomorrow" : "in #{diff_days < 7 ? "#{diff_days}d" : diff_days < 30 ? "#{(diff_days / 7.0).round}w" : "#{(diff_days / 30.0).round}mo"}"
            counties_all = entry[:counties_with_state] || []
            visible      = counties_all.first(5)
            extra        = counties_all.size - visible.size
            is_today     = diff_days == 0
            is_last      = idx == upcoming_grouped.size - 1
          %>
          <div class="agenda-row<%= is_last ? ' agenda-row--last' : '' %>"
               role="link"
               tabindex="0"
               data-href="<%= research_auctions_path(from_date: auction_date.strftime('%Y-%m-%d'), to_date: auction_date.strftime('%Y-%m-%d'), view: 'table') %>"
               onclick="if(typeof Turbo!=='undefined'){Turbo.visit(this.dataset.href)}else{window.location.href=this.dataset.href}"
               onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();if(typeof Turbo!=='undefined'){Turbo.visit(this.dataset.href)}else{window.location.href=this.dataset.href}}"
               title="View auctions on <%= auction_date.strftime('%B %d, %Y') %>">
            <%# ── Date block ── %>
            <div class="agenda-row__date<%= is_today ? ' agenda-row__date--today' : '' %>">
              <span class="agenda-row__month"><%= month_str %></span>
              <span class="agenda-row__day"><%= day_str %></span>
            </div>
            <%# ── Body ── %>
            <div class="agenda-row__body">
              <div class="agenda-row__heading">
                <%= weekday_str %>
                <span class="agenda-row__when<%= is_today ? ' agenda-row__when--today' : '' %>">· <%= when_label %></span>
              </div>
              <div class="agenda-row__chips">
                <% visible.each_with_index do |cs, ci| %>
                  <a href="<%= research_parcels_path(county: cs[:name], state: cs[:state]) %>"
                     onclick="event.stopPropagation()"
                     title="View properties in <%= cs[:name] %><%= cs[:parcel_count] && cs[:parcel_count] > 0 ? " · #{cs[:parcel_count]} parcels" : '' %>"
                     class="agenda-chip<%= ci == 0 && visible.size > 1 ? ' agenda-chip--featured' : '' %>"><%= cs[:name] %></a>
                <% end %>
                <% if extra > 0 %>
                  <span class="agenda-chip agenda-chip--extra">+<%= extra %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
        </div>
        </div>
      </div>
    </div>

    <%# ── KPI strip (bottom) ── %>
    <div class="atlas__kpis" data-panel-id="kpis" data-panel-label="KPI Strip">

      <%# ── Tile 1: Counties Active ── %>
      <div class="kpi-tile" data-kpi-id="counties-active" data-kpi-label="Counties Active">
        <div class="kpi-tile__info">
          <div class="kpi-tile__head">
            <span class="kpi-icon">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
            </span>
            <span class="kpi-label">Counties active</span>
            <button class="kpi-hide-btn" onclick="window.atlasPanelMgr && window.atlasPanelMgr.toggleKpiTile('counties-active', false)" title="Hide this tile" aria-label="Hide Counties Active tile">
              <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="kpi-sub">of <%= @active_state[:county_count] %> in <%= @active_state[:name] %></div>
        </div>
        <div class="kpi-tile__number">
          <span class="kpi-value"><%= active_counties %></span>
        </div>
      </div>

      <%# ── Tile 2: Upcoming Dates ── %>
      <div class="kpi-tile" data-kpi-id="upcoming-dates" data-kpi-label="Upcoming Dates">
        <div class="kpi-tile__info">
          <div class="kpi-tile__head">
            <span class="kpi-icon">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></svg>
            </span>
            <span class="kpi-label">Upcoming dates</span>
            <button class="kpi-hide-btn" onclick="window.atlasPanelMgr && window.atlasPanelMgr.toggleKpiTile('upcoming-dates', false)" title="Hide this tile" aria-label="Hide Upcoming Dates tile">
              <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="kpi-sub">next 90 days</div>
        </div>
        <div class="kpi-tile__number">
          <span class="kpi-value"><%= total_auction_dates %></span>
        </div>
      </div>

      <%# ── Tile 3: Properties up for Bid ── %>
      <div class="kpi-tile" data-kpi-id="properties-bid" data-kpi-label="Properties up for Bid">
        <div class="kpi-tile__info">
          <div class="kpi-tile__head">
            <span class="kpi-icon">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 9 5-9 5-9-5z"/><path d="m3 13 9 5 9-5M3 18l9 5 9-5"/></svg>
            </span>
            <span class="kpi-label">Properties up for bid</span>
            <button class="kpi-hide-btn" onclick="window.atlasPanelMgr && window.atlasPanelMgr.toggleKpiTile('properties-bid', false)" title="Hide this tile" aria-label="Hide Properties tile">
              <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="kpi-sub">across all counties</div>
        </div>
        <div class="kpi-tile__number">
          <span class="kpi-value kpi-value--accent"><%= number_with_delimiter(total_props) %></span>
          <span class="kpi-trend">
            <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>
            +128
          </span>
        </div>
      </div>

    </div>




  </div>

  <%# ── County Detail Panel — OUTSIDE atlasStage so overflow:hidden doesn't clip the fixed popover ── %>
  <div class="county-detail-panel" id="atlasCountyPanel" aria-hidden="true">
    <div class="cdp__header">
      <div>
        <div class="cdp__eyebrow">County overview</div>
        <div class="cdp__name" id="cdpName">—</div>
      </div>
      <button class="cdp__close" id="cdpClose" aria-label="Close county panel" title="Close">
        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="cdp__stats">
      <div class="cdp__stat">
        <span class="cdp__stat-label">Properties</span>
        <strong class="cdp__stat-value" id="cdpProps">0</strong>
      </div>
      <div class="cdp__stat">
        <span class="cdp__stat-label">Auctions</span>
        <strong class="cdp__stat-value" id="cdpAuctions">0</strong>
      </div>
      <div class="cdp__stat">
        <span class="cdp__stat-label">Next sale</span>
        <strong class="cdp__stat-value" id="cdpNext">—</strong>
      </div>
    </div>
    <button class="cdp__cta" id="cdpCta" data-href="#"
      onclick="var u=this.dataset.href;if(u&&u!=='#'){if(typeof Turbo!=='undefined'){Turbo.visit(u)}else{window.location.href=u}}">
      <span>View Opportunities</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </button>
  </div>

  <%# ═══════════════════════════════════════
       CALENDAR VIEW — hidden by default, shown via view toggle
       ═══════════════════════════════════════ %>
  <div class="atlas__alt-panel" id="atlas-panel-calendar" style="display:none;">
    <%= render "research/auctions/calendar_view" %>
  </div>

  <%# ═══════════════════════════════════════
       TABLE VIEW — hidden by default, shown via view toggle
       ═══════════════════════════════════════ %>
  <div class="atlas__alt-panel" id="atlas-panel-table" style="display:none;">
    <%= render "research/auctions/list_view" %>
  </div>

</div>

<%# ── Atlas scripts (map rendering + interactions) ── %>
<%= render "research/auctions/atlas_scripts" %>
<%# ── Legacy scripts for calendar render + table sort ── %>
<%= render "research/auctions/rama1_scripts" %>

<script>
  // Tab switching — Prior Sale Results tab disabled per client decision
  function atlasTab(btn, tab) {
    // Prior Sale Results disabled — always stay on auctions
    window.location.href = '<%= research_auctions_path %>';
  }

  // View toggle — Map / Calendar / Table
  function atlasView(btn, view) {
    // Toggle button active state
    document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('view-btn--active'));
    btn.classList.add('view-btn--active');

    // Panels — guard against null (Turbo may call this before DOM is ready)
    const mapStage = document.getElementById('atlasStage');
    const calPanel = document.getElementById('atlas-panel-calendar');
    const tblPanel = document.getElementById('atlas-panel-table');
    if (!mapStage || !calPanel || !tblPanel) return;

    if (view === 'map') {
      mapStage.style.display = '';
      calPanel.style.display = 'none';
      tblPanel.style.display = 'none';
    } else if (view === 'calendar') {
      mapStage.style.display = 'none';
      calPanel.style.display = '';
      tblPanel.style.display = 'none';
      // Trigger calendar render from rama1_scripts
      if (typeof r1RenderCalendar === 'function') r1RenderCalendar();
      if (typeof lucide !== 'undefined') lucide.createIcons();
    } else if (view === 'table') {
      mapStage.style.display = 'none';
      calPanel.style.display = 'none';
      tblPanel.style.display = '';
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    // Persist preference
    try { localStorage.setItem('atlas_view', view); } catch(e) {}
  }

  // County highlight from sidebar
  function atlasHighlight(id) {
    document.querySelectorAll('#atlasMapWrap path[data-county]').forEach(p => {
      if (id && p.dataset.county === id) {
        p.style.filter = 'brightness(0.85)';
        p.style.stroke = 'var(--accent-strong)';
        p.style.strokeWidth = '2';
      } else {
        p.style.filter = '';
        p.style.stroke = '';
        p.style.strokeWidth = '';
      }
    });
  }

  // ── Auto-switch view from URL param ──────────────────────────
  // When arriving via a date link (?view=table&from_date=X),
  // auto-switch to the requested view.
  (function() {
    var params = new URLSearchParams(window.location.search);
    var requestedView = params.get('view');
    if (requestedView && ['table', 'calendar', 'map'].indexOf(requestedView) !== -1) {
      var btn = document.querySelector('[data-view="' + requestedView + '"]');
      if (btn) {
        // Delay slightly to let the DOM settle after Turbo navigation
        setTimeout(function() { atlasView(btn, requestedView); }, 50);
      }
    }
  })();
</script>

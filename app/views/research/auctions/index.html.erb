<% content_for :title, "Auctions — Tax Sale Resources" %>

<%# Inject Google Maps API key and page-level head tags %>
<% content_for :head do %>
  <style>
    .auction-map { height: calc(100vh - var(--rn-header-h) - 120px); min-height: 400px; }
    .auction-card {
      background: #fff;
      border: 1px solid var(--color-border, #DEE2E6);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      cursor: pointer;
      transition: box-shadow 0.15s, border-color 0.15s;
      margin-bottom: 0.75rem;
    }
    .auction-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.1); border-color: var(--color-accent, #2E86C1); }
    .auction-card.highlighted { border-color: var(--color-accent, #2E86C1); box-shadow: 0 0 0 2px rgba(46,134,193,.2); }
    .auction-card__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.5rem; }
    .auction-card__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-primary, #1E3A5F); margin: 0; }
    .auction-card__meta { font-size: 0.8rem; color: var(--color-text-muted, #6C757D); margin-bottom: 0.5rem; }
    .auction-card__stats { display: flex; gap: 1rem; flex-wrap: wrap; }
    .auction-card__stat { font-size: 0.8rem; }
    .auction-card__stat span { font-weight: 600; color: var(--color-primary, #1E3A5F); }
    .list-scroll { overflow-y: auto; height: calc(100vh - var(--rn-header-h) - 180px); padding-right: 0.25rem; }
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1.25rem; }
    @media (max-width: 900px) { .stat-row { grid-template-columns: repeat(2, 1fr); } }
    .map-info-window { font-family: 'Inter', sans-serif; min-width: 200px; }
    .map-info-window h4 { font-size: 0.875rem; font-weight: 700; color: #1E3A5F; margin: 0 0 0.4rem; }
    .map-info-window p  { font-size: 0.8rem; color: #4a5568; margin: 0 0 0.25rem; }
    .map-info-window a  { font-size: 0.8rem; color: #2E86C1; font-weight: 600; text-decoration: none; }
    
    /* ── Choropleth container ── */
    #usa-choropleth { position:relative; width:100%; height:100%; background:#F8FAFC;
      border:1px solid var(--color-border, #E2E8F0); border-radius:10px; overflow:hidden; margin: 0 auto;}
    #usa-choropleth svg { display:block; margin: 0 auto; width:100%; height:100%; }
    .datamaps-subunit { cursor:pointer; transition:opacity .15s; }
    .datamaps-subunit:hover { opacity:.8; }

    #state-info-bar {
      display:none; margin: 1rem auto; max-width: 900px;
      background: linear-gradient(135deg,#1E3A5F,#2E5F8A);
      border-radius:10px; padding:1rem 1.25rem;
      color:#fff;
    }
    #state-info-bar h3 { font-size:1rem; font-weight:700; margin-bottom:.35rem; }
    .state-bar-meta { display:flex; gap:1.25rem; flex-wrap:wrap; font-size:.82rem; opacity:.85; margin-bottom:.75rem; }
    .state-bar-auctions { display:flex; gap:.5rem; flex-wrap:wrap; }
    .state-bar-item {
      background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2);
      border-radius:8px; padding:.5rem .85rem; font-size:.8rem; min-width:180px;
    }
  </style>
  <script src="https://d3js.org/d3.v7.min.js"></script>
<% end %>

<div class="rn-page">
  <!-- Sidebar: Filters -->
  <aside class="rn-sidebar">
    <%= form_with url: research_auctions_path, method: :get, local: true, id: "auction-filter-form" do |f| %>
      <div class="filter-sidebar">
        <p class="filter-sidebar__title">Filters</p>

        <div class="filter-group">
          <label class="filter-label" for="filter-state">State</label>
          <select class="filter-select" name="state" id="filter-state">
            <option value="">All States</option>
            <% @states.each do |s| %>
              <option value="<%= s %>" <%= 'selected' if params[:state] == s %>><%= s %></option>
            <% end %>
          </select>
        </div>

        <div class="filter-group">
          <label class="filter-label" for="filter-county">County</label>
          <select class="filter-select" name="county" id="filter-county">
            <option value="">All Counties</option>
            <% @all_counties.each do |c| %>
              <option value="<%= c %>" <%= 'selected' if params[:county] == c %>><%= c %></option>
            <% end %>
          </select>
        </div>

        <div class="filter-group">
          <label class="filter-label" for="filter-status">Status</label>
          <select class="filter-select" name="status" id="filter-status">
            <option value="">All Statuses</option>
            <option value="upcoming"  <%= 'selected' if params[:status] == 'upcoming' %>>Upcoming</option>
            <option value="active"    <%= 'selected' if params[:status] == 'active' %>>Active</option>
            <option value="completed" <%= 'selected' if params[:status] == 'completed' %>>Completed</option>
          </select>
        </div>

        <div class="filter-group">
          <label class="filter-label" for="filter-from">From Date</label>
          <input class="filter-input" type="date" name="from_date" id="filter-from" value="<%= params[:from_date] %>">
        </div>

        <div class="filter-group">
          <label class="filter-label" for="filter-to">To Date</label>
          <input class="filter-input" type="date" name="to_date" id="filter-to" value="<%= params[:to_date] %>">
        </div>

        <button type="submit" class="filter-btn-apply">Apply Filters</button>
        <%= link_to "Clear", research_auctions_path, class: "filter-btn-clear" %>
      </div>
    <% end %>
  </aside>

  <!-- Main Content -->
  <div class="rn-content">
    <!-- Page Header -->
    <div class="rn-page-header">
      <div>
        <h1 class="rn-page-title">Tax Sale Auctions</h1>
        <p class="rn-page-subtitle"><%= @auctions.count %> auctions found</p>
      </div>
      <div class="view-toggle" id="view-toggle" role="group" aria-label="Switch view">
        <button class="view-toggle__btn active" id="btn-map" onclick="switchView('map')" type="button">
          🗺 Map
        </button>
        <button class="view-toggle__btn" id="btn-list" onclick="switchView('list')" type="button">
          ☰ List
        </button>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="stat-row">
      <div class="stat-card">
        <p class="stat-card__label">Total Auctions</p>
        <p class="stat-card__value"><%= @count_total %></p>
        <p class="stat-card__sub">filtered</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Upcoming</p>
        <p class="stat-card__value"><%= @count_upcoming %></p>
        <p class="stat-card__sub">scheduled</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Active</p>
        <p class="stat-card__value"><%= @count_active %></p>
        <p class="stat-card__sub">in progress</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__label">Total Parcels</p>
        <p class="stat-card__value"><%= @count_total_parcels %></p>
        <p class="stat-card__sub">across all auctions</p>
      </div>
    </div>

    <!-- MAP VIEW -->
    <div id="map-view">
      <div class="map-container auction-map" id="usa-choropleth"></div>
      <div id="state-info-bar">
        <h3 id="bar-title"></h3>
        <div class="state-bar-meta" id="bar-meta"></div>
        <div class="state-bar-auctions" id="bar-auctions"></div>
      </div>
    </div>

    <!-- LIST VIEW -->
    <div id="list-view" style="display:none;">
      <% if @auctions.any? %>
        <div class="data-table-wrap">
          <table class="data-table" id="auctions-table">
            <thead>
              <tr>
                <th>Jurisdiction</th>
                <th>Type</th>
                <th>Sale Date</th>
                <th>Parcels</th>
                <th>Amount</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @auctions.each do |auction| %>
                <tr id="row-<%= auction.id %>">
                  <td>
                    <div style="font-weight: 600; color: var(--color-primary)"><%= auction.county %></div>
                    <div style="font-size: 0.8rem; color: var(--color-text-muted)"><%= auction.state %></div>
                  </td>
                  <td>Tax Deed</td>
                  <td>
                    <% if auction.sale_date %>
                      <div style="font-weight: 500;"><%= auction.sale_date.strftime("%b %d, %Y") %></div>
                    <% else %>
                      <span style="color: var(--color-text-muted)">—</span>
                    <% end %>
                  </td>
                  <td><strong><%= auction.parcel_count || 0 %></strong></td>
                  <td>
                    <% if auction.total_amount&.positive? %>
                      $<%= number_with_delimiter(auction.total_amount.to_i) %>
                    <% else %>
                      <span style="color: var(--color-text-muted)">—</span>
                    <% end %>
                  </td>
                  <td>
                    <span class="badge badge-<%= auction.status %>">
                      <%= auction.status_label %>
                    </span>
                  </td>
                  <td>
                    <% if auction.bidding_url.present? %>
                      <%= link_to "Bid →", auction.bidding_url, target: "_blank", rel: "noopener", class: "btn-sm btn-sm-primary" %>
                    <% end %>
                    <%= link_to "View", research_auction_path(auction), class: "btn-sm btn-sm-outline" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-state__icon">🏛️</div>
          <h2 class="empty-state__title">No auctions found</h2>
          <p class="empty-state__desc">Try adjusting your filters or clearing them to see all available auctions.</p>
          <%= link_to "Clear Filters", research_auctions_path, class: "btn-sm btn-sm-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Auction data for JS map -->
<script>
  // ⚠️ Solo auctions visible (upcoming + active) — excluye completed del mapa
  var AUCTIONS_BY_STATE = <%= raw @auctions.visible.group_by(&:state).transform_values { |state_auctions|
    {
      count: state_auctions.size,
      total_parcels: state_auctions.sum { |a| a.parcel_count || 0 },
      total_amount: state_auctions.sum { |a| a.total_amount&.to_f || 0 },
      auctions: []
    }
  }.to_json %>;

  var STATE_NAME_TO_CODE = {
    'Alabama':'AL','Alaska':'AK','Arizona':'AZ','Arkansas':'AR','California':'CA',
    'Colorado':'CO','Connecticut':'CT','Delaware':'DE','Florida':'FL','Georgia':'GA',
    'Hawaii':'HI','Idaho':'ID','Illinois':'IL','Indiana':'IN','Iowa':'IA','Kansas':'KS',
    'Kentucky':'KY','Louisiana':'LA','Maine':'ME','Maryland':'MD','Massachusetts':'MA',
    'Michigan':'MI','Minnesota':'MN','Mississippi':'MS','Missouri':'MO','Montana':'MT',
    'Nebraska':'NE','Nevada':'NV','New Hampshire':'NH','New Jersey':'NJ','New Mexico':'NM',
    'New York':'NY','North Carolina':'NC','North Dakota':'ND','Ohio':'OH','Oklahoma':'OK',
    'Oregon':'OR','Pennsylvania':'PA','Rhode Island':'RI','South Carolina':'SC',
    'South Dakota':'SD','Tennessee':'TN','Texas':'TX','Utah':'UT','Vermont':'VT',
    'Virginia':'VA','Washington':'WA','West Virginia':'WV','Wisconsin':'WI','Wyoming':'WY'
  };

  function stateColor(count) {
    if (!count || count === 0) return '#CBD5E0';
    if (count <= 2)  return '#BFD9EC';
    if (count <= 5)  return '#5BA3C9';
    if (count <= 15) return '#2E86C1';
    return '#1E3A5F';
  }

  // ── Cache del GeoJSON para no hacer fetch en cada toggle ──────────────────
  var _geoDataCache = null;
  var _mapRendered  = false;

  function _renderD3Map() {
    // Si el mapa ya fue renderizado, no volver a construirlo
    if (_mapRendered) return;

    var container = d3.select('#usa-choropleth');
    container.selectAll('*').remove();

    // Spinner de carga mientras llega el GeoJSON
    container.append('div')
      .attr('id', 'map-loading')
      .style('display', 'flex')
      .style('align-items', 'center')
      .style('justify-content', 'center')
      .style('height', '100%')
      .style('color', 'var(--color-text-muted, #6C757D)')
      .style('font-size', '0.875rem')
      .text('Loading map…');

    var width = 960;
    var height = 550;

    function buildMap(geoData) {
      container.selectAll('*').remove();
      var svg = container
        .append('svg')
        .attr('viewBox', '0 0 ' + width + ' ' + height)
        .attr('preserveAspectRatio', 'xMidYMid meet')
        .style('width', '100%')
        .style('height', '100%');

      var projection = d3.geoAlbersUsa().fitSize([width, height], geoData);
      var path = d3.geoPath().projection(projection);

      var statesGroup = svg.append('g').attr('class', 'states');
      var labelsGroup = svg.append('g').attr('class', 'labels');

      statesGroup.selectAll('path')
        .data(geoData.features)
        .enter()
        .append('path')
        .attr('class', 'datamaps-subunit')
        .attr('d', path)
        .attr('fill', function(d) {
          var code = STATE_NAME_TO_CODE[d.properties.name];
          var count = code && AUCTIONS_BY_STATE[code] ? AUCTIONS_BY_STATE[code].count : 0;
          return stateColor(count);
        })
        .attr('stroke', '#ffffff')
        .attr('stroke-width', 1.5)
        .style('cursor', function(d) {
          var code = STATE_NAME_TO_CODE[d.properties.name];
          var count = code && AUCTIONS_BY_STATE[code] ? AUCTIONS_BY_STATE[code].count : 0;
          return count > 0 ? 'pointer' : 'default';
        })
        .on('click', function(event, d) {
          var name = d.properties.name;
          var code = STATE_NAME_TO_CODE[name];
          if (code && AUCTIONS_BY_STATE[code] && AUCTIONS_BY_STATE[code].count > 0) {
            showStateBar(code, AUCTIONS_BY_STATE[code]);
          }
        })
        .on('mouseover', function(event, d) {
           d3.select(this)
             .attr('stroke', '#1E3A5F')
             .attr('stroke-width', 2)
             .attr('opacity', 0.85);
        })
        .on('mouseout', function(event, d) {
           d3.select(this)
             .attr('stroke', '#ffffff')
             .attr('stroke-width', 1.5)
             .attr('opacity', 1);
        });

      geoData.features.forEach(function(d) {
        var code = STATE_NAME_TO_CODE[d.properties.name];
        var count = code && AUCTIONS_BY_STATE[code] ? AUCTIONS_BY_STATE[code].count : 0;
        
        if (count > 0) {
          var centroid = path.centroid(d);
          if (isNaN(centroid[0]) || isNaN(centroid[1])) return;
          var cx = centroid[0], cy = centroid[1];
          if (code === 'FL') { cx += 12; cy += 8; }
          if (code === 'MI') { cx += 12; cy += 18; }
          if (code === 'ID') { cy += 15; }
          if (code === 'CA') { cx -= 10; cy += 10; }
          if (code === 'LA') { cx -= 8; }
          if (code === 'MD') { cy -= 5; cx += 5; }

          labelsGroup.append('text')
            .attr('x', cx)
            .attr('y', cy + 5)
            .attr('text-anchor', 'middle')
            .attr('fill', '#ffffff')
            .attr('font-size', '14px')
            .attr('font-weight', '700')
            .style('pointer-events', 'none')
            .text(count);
        }
      });

      _mapRendered = true;
    }

    // Usar cache si existe; si no, hacer fetch una sola vez
    if (_geoDataCache) {
      buildMap(_geoDataCache);
    } else {
      d3.json('https://raw.githubusercontent.com/PublicaMundi/MappingAPI/master/data/geojson/us-states.json')
        .then(function(geoData) {
          _geoDataCache = geoData;
          buildMap(geoData);
        })
        .catch(function(err) {
          container.selectAll('*').remove();
          container.append('div')
            .style('display', 'flex')
            .style('flex-direction', 'column')
            .style('align-items', 'center')
            .style('justify-content', 'center')
            .style('height', '100%')
            .style('gap', '0.5rem')
            .html('<span style="font-size:2rem">🗺️</span>' +
                  '<p style="color:var(--color-text-muted);font-size:0.875rem;margin:0">No se pudo cargar el mapa. Verifica tu conexión.</p>' +
                  '<button onclick="_mapRendered=false; _renderD3Map();" class="btn-sm btn-sm-outline" style="margin-top:0.5rem">Reintentar</button>');
        });
    }
  }

  function showStateBar(state, data) {
    var bar      = document.getElementById('state-info-bar');
    var barTitle = document.getElementById('bar-title');
    var barMeta  = document.getElementById('bar-meta');

    barTitle.textContent = state + ' — ' + data.count + ' auctions';
    barMeta.innerHTML    = '<span>🏠 ' + data.total_parcels.toLocaleString() + ' total parcels</span>'
      + (data.total_amount > 0 ? '<span>💰 ~$' + Math.round(data.total_amount).toLocaleString() + ' est.</span>' : '');

    bar.style.display = 'block';
  }

  // ── VIEW TOGGLE con persistencia localStorage ─────────────────────────────
  function switchView(view) {
    document.getElementById('map-view').style.display  = view === 'map'  ? 'block' : 'none';
    document.getElementById('list-view').style.display = view === 'list' ? 'block' : 'none';
    document.getElementById('btn-map').classList.toggle('active',  view === 'map');
    document.getElementById('btn-list').classList.toggle('active', view === 'list');
    if (view === 'map') _renderD3Map();
    // Persistir preferencia del usuario
    try { localStorage.setItem('auctions_view', view); } catch(e) {}
  }

  document.addEventListener("DOMContentLoaded", function() {
    // Restaurar vista persistida o mostrar mapa por defecto
    var savedView = 'map';
    try { savedView = localStorage.getItem('auctions_view') || 'map'; } catch(e) {}
    switchView(savedView);
  });
</script>

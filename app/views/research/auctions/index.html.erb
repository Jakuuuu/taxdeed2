<%#
  Rama 1: US Overview — Condados con Subastas (Production View)
  ══════════════════════════════════════════════════════════════
  REFACTORED: Modular architecture via Rails Partials.
  LAYOUT: 50/50 split — Left: SVG Map + State Selector | Right: State Data
  ──────────────────────────────────────────────────────────────
  ARCHITECTURE RULES:
  • ⛔ NO Google Maps / Leaflet — SVG choropleth inline ONLY
  • ⛔ NO "Aggregate Value" — ELIMINATED
  • ✅ Terminología: "Condados con subastas" (NEVER "Sale Events")
  • Rule 16: Map/Calendar/Table clicks → Rama 2 (NEVER Parcel#show)
  ──────────────────────────────────────────────────────────────
  PARTIALS:
    _sub_navigation     → Tabs (Tax Sale Auctions | Prior Sale Results)
    _filter_bar         → Filters, dropdowns, view toggle
    _state_selector     → State dropdown above SVG map
    _svg_map_container  → SVG choropleth + summary stats (NO aggregate value)
    _state_overview_data→ Right panel: state header, counties, dates
    _calendar_view      → Calendar panel
    _list_view          → Table + pagination
    _state_popup        → Map hover tooltip (NO aggregate value)
    _rama1_scripts      → All JS (view switching, zoom, filters, etc.)
%>

<%# ── Sub-Navigation Tabs ─────────────────────────────────────────────── %>
<%= render 'research/auctions/sub_navigation' %>

<%# ── Filter Bar ──────────────────────────────────────────────────────── %>
<%= render 'research/auctions/filter_bar' %>


<%# ═══════════════════ MAIN CONTENT ═══════════════════════════════════ %>
<div class="r1-main-content">

  <%# ══ VIEW: MAP — 50/50 Split Layout ══ %>
  <div class="r1-view-panel active" id="panel-map">
    <div class="r1-split-layout">

      <%# ── LEFT SIDE (50%): State Selector + SVG Map ── %>
      <div class="r1-split-left">
        <%= render 'research/auctions/state_selector' %>
        <%= render 'research/auctions/svg_map_container' %>
      </div>

      <%# ── RIGHT SIDE (50%): State Overview Data ── %>
      <div class="r1-split-right">
        <%= render 'research/auctions/state_overview_data' %>
      </div>

    </div>
  </div>

  <%# ══ VIEW: CALENDAR ══ %>
  <div class="r1-view-panel" id="panel-calendar">
    <%= render 'research/auctions/calendar_view' %>
  </div>

  <%# ══ VIEW: LIST (Table) ══ %>
  <div class="r1-view-panel" id="panel-list">
    <%= render 'research/auctions/list_view' %>
  </div>

</div><!-- /r1-main-content -->


<%# ── State Popup (map hover tooltip) ─────────────────────────────── %>
<%= render 'research/auctions/state_popup' %>


<%# ── 50/50 Split Layout CSS ─────────────────────────────────────── %>
<style>
  /* ── Split Layout Container ── */
  .r1-split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    min-height: 600px;
  }

  .r1-split-left {
    display: flex;
    flex-direction: column;
    padding-right: 20px;
    border-right: 1px solid var(--r1-color-border, #DEE2E6);
    gap: 12px;
  }

  .r1-split-right {
    display: flex;
    flex-direction: column;
    max-height: 800px;
    overflow-y: auto;
  }

  /* ── Responsive: stack on small screens ── */
  @media (max-width: 1024px) {
    .r1-split-layout {
      grid-template-columns: 1fr;
    }
    .r1-split-left {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid var(--r1-color-border, #DEE2E6);
      padding-bottom: 20px;
    }
  }

  /* Ensure SVG map fills its container properly and centers the state */
  .r1-split-left .r1-map-container {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .r1-split-left .r1-map-svg-wrap {
    height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .r1-split-left .r1-map-svg-wrap svg {
    width: 100%;
    height: 100%;
    max-height: 420px;
    transition: viewBox 0.4s ease;
  }
</style>


<%# ── All JavaScript ──────────────────────────────────────────────── %>
<%= render 'research/auctions/rama1_scripts' %>

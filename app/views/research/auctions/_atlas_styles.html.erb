<%# ═══════════════════════════════════════════════════════
     ATLAS LAYOUT — Direct copy from prototype styles-atlas.css
     ═══════════════════════════════════════════════════════ %>
<style>
/* === PROPOSAL 1: ATLAS === */

.atlas {
  width: 100%;
  height: calc(100vh - 58px); /* minus header */
  display: flex;
  flex-direction: column;
  background: var(--surface-0);
}
/* ═══ Prior Sale Results Panel ═══ */
.atlas__prior {
  padding: 24px 32px;
  flex: 1;
  overflow: auto;
  background:
    radial-gradient(ellipse at 20% 10%, oklch(0.48 0.11 158 / 0.04), transparent 50%),
    var(--surface-0);
  animation: atlasFadeUp 400ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}
/* Override legacy table container */
.atlas__prior .r1-table-container {
  background: oklch(1 0 0 / 0.7);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}
.atlas__prior .r1-table-toolbar {
  padding: 14px 22px;
  background: oklch(0.97 0.004 158 / 0.6);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-sans);
  font-size: 13px;
  color: var(--ink-2);
}
.atlas__prior .r1-table-toolbar strong { color: var(--ink-1); font-weight: 600; }
.atlas__prior .r1-table-count-sub { color: var(--ink-3); font-size: 11px; }
.atlas__prior .r1-table-wrap { overflow-x: auto; }
.atlas__prior #r1-auction-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-sans);
  font-size: 13.5px;
}
.atlas__prior #r1-auction-table thead {
  background: oklch(0.97 0.008 158 / 0.5);
  border-bottom: 1px solid var(--border);
}
.atlas__prior #r1-auction-table thead th {
  padding: 11px 16px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  border: none;
}
.atlas__prior #r1-auction-table thead th .r1-th-inner {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  transition: color 160ms ease;
}
.atlas__prior #r1-auction-table thead th .r1-th-inner:hover { color: var(--accent); }
.atlas__prior #r1-auction-table tbody tr {
  border-bottom: 1px solid oklch(0.93 0.004 158 / 0.5);
  transition: background 160ms ease;
}
.atlas__prior #r1-auction-table tbody tr:hover {
  background: oklch(0.48 0.11 158 / 0.04);
}
.atlas__prior #r1-auction-table tbody td {
  padding: 12px 16px;
  color: var(--ink-2);
  vertical-align: middle;
  border: none;
}
.atlas__prior .r1-td-date { color: var(--accent) !important; font-weight: 600 !important; }
.atlas__prior .r1-td-jurisdiction { font-weight: 600 !important; color: var(--ink-1) !important; }
.atlas__prior .r1-td-state { color: var(--ink-2) !important; }
.atlas__prior .r1-td-badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.atlas__prior .r1-badge-deed {
  background: oklch(0.48 0.11 158 / 0.1);
  color: var(--accent);
}
/* Buy now button — Atlas */
.atlas__prior #r1-auction-table tbody td button {
  background: var(--accent) !important;
  color: #fff !important;
  border: none !important;
  padding: 7px 18px !important;
  border-radius: var(--radius-sm) !important;
  font-family: var(--font-sans) !important;
  font-weight: 600 !important;
  font-size: 12px !important;
  cursor: pointer !important;
  transition: background 160ms ease, transform 160ms ease !important;
  white-space: nowrap !important;
}
.atlas__prior #r1-auction-table tbody td button:hover {
  background: var(--accent-strong) !important;
  transform: translateY(-1px) !important;
}
/* Pagination — Atlas */
.atlas__prior .r1-pagination-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 22px;
  background: oklch(0.97 0.004 158 / 0.6);
  border-top: 1px solid var(--border);
  font-family: var(--font-sans);
  font-size: 12.5px;
  color: var(--ink-3);
}
.atlas__prior .r1-pagination-info strong { color: var(--ink-1); }
.atlas__prior .r1-pagination-btns { display: flex; gap: 4px; align-items: center; }
.atlas__prior .r1-page-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  height: 28px;
  padding: 0 8px;
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: 11.5px;
  color: var(--ink-2);
  text-decoration: none;
  transition: all 160ms ease;
}
.atlas__prior .r1-page-btn:hover { background: oklch(0.48 0.11 158 / 0.08); color: var(--accent); }
.atlas__prior .r1-page-btn.active {
  background: var(--accent);
  color: #fff;
  font-weight: 600;
}
.atlas__prior .r1-page-btn.disabled { opacity: 0.35; pointer-events: none; }

.atlas__stage {
  flex: 1;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 30% 20%, oklch(0.94 0.012 158 / 0.4), transparent 50%),
    radial-gradient(ellipse at 80% 70%, oklch(0.92 0.010 170 / 0.25), transparent 55%),
    oklch(0.92 0.005 158);
}

.atlas__map-bg {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  pointer-events: none;
}
.atlas__map-bg::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 56px 56px;
  background-position: 0 0;
  opacity: 0.5;
  mask-image: radial-gradient(ellipse 70% 60% at center, black 40%, transparent 90%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at center, black 40%, transparent 90%);
}
.atlas__map-wrap {
  width: min(78%, 880px);
  height: calc(100% - 120px); /* leave room for KPI strip at bottom */
  position: relative;
  pointer-events: auto;
}
.atlas__map-wrap svg { width: 100%; height: 100%; }
.atlas__map-wrap svg path { pointer-events: auto; cursor: pointer; }

.atlas__compass {
  position: absolute;
  top: 110px; right: 80px;
  width: 56px; height: 56px;
  color: var(--ink-4);
  opacity: 0.6;
}
.atlas__compass svg { width: 100%; height: 100%; }
.atlas__compass-n {
  position: absolute;
  top: -8px; left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  color: var(--accent);
  font-weight: 700;
}
.atlas__coord {
  position: absolute;
  bottom: 160px; right: 80px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--ink-3);
  letter-spacing: 0.06em;
  opacity: 0.7;
}

/* Zoom controls */
.atlas__zoom-controls {
  position: absolute;
  bottom: 80px; right: 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 15;
  background: oklch(1 0 0 / 0.8);
  backdrop-filter: blur(16px) saturate(140%);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}
.atlas__zoom-btn {
  display: grid;
  place-items: center;
  width: 36px; height: 36px;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--ink-2);
  transition: background 150ms ease, color 150ms ease;
}
.atlas__zoom-btn:hover {
  background: oklch(0.95 0.015 158 / 0.6);
  color: var(--accent-strong);
}
.atlas__zoom-btn:active {
  background: oklch(0.90 0.03 158 / 0.5);
}
.atlas__zoom-btn svg { width: 16px; height: 16px; }
.atlas__zoom-btn + .atlas__zoom-btn {
  border-top: 1px solid oklch(0.91 0.008 158 / 0.4);
}

/* Floating panels — glass */
.atlas__top-panel {
  position: absolute;
  top: 20px; left: 12px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 11;
  width: 288px;
}
.atlas__state-pill {
  position: relative; /* anchor for the dropdown menu */
  z-index: 50;        /* lift above sibling .atlas__title-block (own stacking context via backdrop-filter) */
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 8px 8px 14px;
  background: oklch(1 0 0 / 0.85);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.7);
  border-radius: 999px;
  box-shadow: var(--shadow-md);
  width: fit-content;
}
.atlas__state-flag { font-size: 16px; }
.atlas__state-label {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  line-height: 1;
}
.atlas__state-name {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.005em;
  color: var(--ink-1);
}
.atlas__state-count {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-3);
  padding-left: 12px;
  margin-left: 2px;
  border-left: 1px solid var(--border);
}
.atlas__state-switch {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--surface-2);
  display: grid; place-items: center;
  color: var(--ink-2);
}
.atlas__state-switch svg { width: 14px; height: 14px; transform: rotate(90deg); transition: transform 200ms ease; }
.atlas__state-switch[aria-expanded="true"] svg { transform: rotate(-90deg); }
.atlas__state-switch { cursor: pointer; border: 0; }
.atlas__state-switch:hover { background: oklch(0.92 0.012 158); }

/* ── State menu (inline glass dropdown anchored to the state-pill) ── */
.atlas__state-menu {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  min-width: 100%;
  background: oklch(1 0 0 / 0.92);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid oklch(0.91 0.008 158 / 0.7);
  border-radius: 14px;
  box-shadow: 0 12px 32px oklch(0.18 0.015 158 / 0.18);
  padding: 6px;
  z-index: 60;
  display: flex;
  flex-direction: column;
  gap: 2px;
  animation: atlasStateMenuSlide 160ms cubic-bezier(.2,.8,.2,1);
}
.atlas__state-menu[hidden] { display: none; }
@keyframes atlasStateMenuSlide {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}
.atlas__state-menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  width: 100%;
  padding: 10px 14px;
  border: 0;
  background: transparent;
  border-radius: 10px;
  cursor: pointer;
  text-align: left;
  font: inherit;
  color: var(--ink-1);
  white-space: nowrap;
  transition: background 120ms ease;
}
.atlas__state-menu-item:hover { background: oklch(0.95 0.012 158); }
.atlas__state-menu-item.is-active {
  background: oklch(0.93 0.06 155);
  font-weight: 600;
}
.atlas__state-menu-name { font-size: 13.5px; }
.atlas__state-menu-meta {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--ink-3);
}

.atlas__title-block {
  padding: 14px 18px;
  background: oklch(1 0 0 / 0.85);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.7);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  width: 100%;
  box-sizing: border-box;
}
.atlas__title-eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 6px;
}
.atlas__title {
  font-family: var(--font-display);
  font-size: 26px;
  letter-spacing: -0.025em;
  font-weight: 400;
  margin: 0;
  line-height: 1.1;
  color: var(--ink-1);
}
.atlas__subtitle {
  margin: 4px 0 0;
  font-size: 11.5px;
  color: var(--ink-3);
  line-height: 1.3;
}



.atlas__left-panel {
  /* Width inherited from parent .atlas__right-column */
  overflow: visible;
  z-index: 10;
}
.atlas__left-panel .agenda-list {
  max-height: calc(100vh - 460px);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: oklch(0.82 0.018 158) transparent;
}
.atlas__agenda {
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 0;
}

/* Left sidebar — panels column */
.atlas__right-column {
  position: absolute;
  top: 0;
  left: 0;
  width: 312px;
  height: 100%;
  padding: 210px 12px 80px;
  background: oklch(0.965 0.005 155);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 9;
  max-height: 100%;
  overflow-y: auto;
  overflow-x: visible;
  scrollbar-width: none;
  box-sizing: border-box;
}
.atlas__right-column::-webkit-scrollbar { display: none; }

/* Panels inside the column — override absolute positioning */
.atlas__right-column .atlas__right-panel,
.atlas__right-column .atlas__crm-calendar,
.atlas__right-column .atlas__left-panel {
  position: relative !important;
  top: auto !important;
  right: auto !important;
  left: auto !important;
  bottom: auto !important;
  width: 100% !important;
}

.atlas__right-panel {
  overflow: visible;
  z-index: 10;
}
.atlas__top-counties {
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  padding: 8px;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.atlas__see-all {
  display: flex; align-items: center; gap: 4px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent);
  font-weight: 600;
  padding: 8px 14px;
  text-decoration: none;
}
.atlas__see-all svg { width: 12px; height: 12px; }

/* Bottom-center legend */
.atlas__legend {
  position: absolute;
  bottom: 112px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

/* KPI strip — compact */
.atlas__kpis {
  position: absolute;
  bottom: 0; left: 312px; right: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-top: 1px solid var(--border);
  z-index: 5;
}
.atlas__kpis .kpi-tile {
  border: none;
  border-radius: 0;
  padding: 8px 20px;
  background: oklch(1 0 0);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* ═══ fadeUp animation ═══ */
@keyframes atlasFadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.atlas__top-panel,
.atlas__left-panel,
.atlas__right-panel,
.atlas__legend,
.atlas__kpis {
  animation: atlasFadeUp 500ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}
.atlas__top-panel   { animation-delay: 100ms; }
.atlas__left-panel  { animation-delay: 250ms; }
.atlas__right-panel { animation-delay: 200ms; }
.atlas__legend      { animation-delay: 350ms; }
.atlas__kpis        { animation-delay: 300ms; }

/* ═══ Panel Customization System ═══ */

/* Draggable state — applied by JS when user is actively dragging */
.atlas-panel--dragging {
  box-shadow:
    0 24px 48px oklch(0.18 0.015 158 / 0.22),
    0 0 0 2px var(--accent-soft) !important;
  z-index: 9999 !important;
  user-select: none;
  pointer-events: none; /* prevents interfering with mousemove during drag */
}

/* Hidden panel */
.atlas-panel--hidden {
  display: none !important;
}

/* Minimized panel — body collapses, only controls stay visible */
.atlas-panel--minimized .panel-body {
  max-height: 0 !important;
  overflow: hidden !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  margin-top: 0 !important;
  margin-bottom: 0 !important;
  opacity: 0;
  transition: max-height 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
              opacity 200ms ease,
              padding 200ms ease;
}
.panel-body {
  transition: max-height 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
              opacity 200ms ease,
              padding 200ms ease;
}

/* Panel controls bar — always visible, subtle */
.panel-header-controls {
  display: flex;
  align-items: center;
  gap: 2px;
  position: absolute;
  top: 6px;
  right: 6px;
  z-index: 20;
  opacity: 1;
}

.panel-ctrl-btn {
  display: grid;
  place-items: center;
  width: 20px;
  height: 20px;
  border-radius: 5px;
  border: none;
  background: oklch(1 0 0 / 0.75);
  backdrop-filter: blur(8px);
  color: var(--ink-3);
  cursor: pointer;
  transition: background 140ms ease, color 140ms ease, transform 120ms ease;
  padding: 0;
  line-height: 1;
}
.panel-ctrl-btn:hover {
  background: var(--accent-soft);
  color: var(--accent-strong);
  transform: scale(1.1);
}
.panel-ctrl-btn--drag {
  cursor: grab;
}
.panel-ctrl-btn--drag:active {
  cursor: grabbing;
}
.panel-ctrl-btn--minimize.is-minimized svg {
  transform: rotate(180deg);
}
.panel-ctrl-btn svg {
  transition: transform 200ms ease;
}

/* Resize handle */
.panel-resize-handle {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 16px;
  height: 16px;
  cursor: nwse-resize;
  z-index: 25;
  display: grid;
  place-items: center;
  opacity: 0;
  transition: opacity 160ms ease;
}
[data-panel-id]:hover .panel-resize-handle {
  opacity: 0.5;
}
.panel-resize-handle::after {
  content: "";
  display: block;
  width: 8px;
  height: 8px;
  border-right: 2px solid var(--ink-3);
  border-bottom: 2px solid var(--ink-3);
  border-radius: 1px;
}

/* ═══ Panel Manager ═══ */
.atlas__panel-manager {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 100;
}

.atlas__panel-mgr-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px 6px 10px;
  background: oklch(1 0 0 / 0.85);
  backdrop-filter: blur(16px) saturate(140%);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: 999px;
  box-shadow: var(--shadow-md);
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 600;
  color: var(--ink-2);
  cursor: pointer;
  transition: background 150ms ease, color 150ms ease, transform 120ms ease, box-shadow 150ms ease;
}
.atlas__panel-mgr-btn:hover {
  background: oklch(0.96 0.012 158 / 0.95);
  color: var(--accent-strong);
  transform: translateY(-1px);
  box-shadow: var(--shadow-lg);
}

.atlas__panel-mgr-popover {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 240px;
  background: oklch(1 0 0 / 0.9);
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.65);
  border-radius: var(--radius-lg);
  box-shadow:
    0 20px 40px oklch(0.18 0.015 158 / 0.18),
    0 4px 12px oklch(0.18 0.015 158 / 0.08);
  overflow: hidden;
  animation: atlasFadeUp 200ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.atlas__panel-mgr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px 10px;
  border-bottom: 1px solid var(--border);
}
.atlas__panel-mgr-title {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: var(--ink-1);
}
.atlas__panel-mgr-close {
  display: grid;
  place-items: center;
  width: 22px; height: 22px;
  border: none;
  border-radius: 5px;
  background: transparent;
  color: var(--ink-3);
  cursor: pointer;
  transition: background 140ms ease, color 140ms ease;
}
.atlas__panel-mgr-close:hover { background: var(--surface-2); color: var(--ink-1); }

.atlas__panel-mgr-list {
  padding: 8px 0;
  max-height: 320px;
  overflow-y: auto;
}

/* Each row in the panel list */
.panel-mgr-row {
  display: flex;
  align-items: center;

<%# ═══════════════════════════════════════════════════════
     ATLAS LAYOUT — Direct copy from prototype styles-atlas.css
     ═══════════════════════════════════════════════════════ %>
<style>
/* === PROPOSAL 1: ATLAS === */

.atlas {
  width: 100%;
  height: calc(100vh - 58px); /* minus header */
  display: flex;
  flex-direction: column;
  background: var(--surface-0);
}
/* ═══ Prior Sale Results Panel ═══ */
.atlas__prior {
  padding: 24px 32px;
  flex: 1;
  overflow: auto;
  background:
    radial-gradient(ellipse at 20% 10%, oklch(0.48 0.11 158 / 0.04), transparent 50%),
    var(--surface-0);
  animation: atlasFadeUp 400ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}
/* Override legacy table container */
.atlas__prior .r1-table-container {
  background: oklch(1 0 0 / 0.7);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}
.atlas__prior .r1-table-toolbar {
  padding: 14px 22px;
  background: oklch(0.97 0.004 158 / 0.6);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-sans);
  font-size: 13px;
  color: var(--ink-2);
}
.atlas__prior .r1-table-toolbar strong { color: var(--ink-1); font-weight: 600; }
.atlas__prior .r1-table-count-sub { color: var(--ink-3); font-size: 11px; }
.atlas__prior .r1-table-wrap { overflow-x: auto; }
.atlas__prior #r1-auction-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-sans);
  font-size: 13.5px;
}
.atlas__prior #r1-auction-table thead {
  background: oklch(0.97 0.008 158 / 0.5);
  border-bottom: 1px solid var(--border);
}
.atlas__prior #r1-auction-table thead th {
  padding: 11px 16px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 600;
  text-align: left;
  white-space: nowrap;
  border: none;
}
.atlas__prior #r1-auction-table thead th .r1-th-inner {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  transition: color 160ms ease;
}
.atlas__prior #r1-auction-table thead th .r1-th-inner:hover { color: var(--accent); }
.atlas__prior #r1-auction-table tbody tr {
  border-bottom: 1px solid oklch(0.93 0.004 158 / 0.5);
  transition: background 160ms ease;
}
.atlas__prior #r1-auction-table tbody tr:hover {
  background: oklch(0.48 0.11 158 / 0.04);
}
.atlas__prior #r1-auction-table tbody td {
  padding: 12px 16px;
  color: var(--ink-2);
  vertical-align: middle;
  border: none;
}
.atlas__prior .r1-td-date { color: var(--accent) !important; font-weight: 600 !important; }
.atlas__prior .r1-td-jurisdiction { font-weight: 600 !important; color: var(--ink-1) !important; }
.atlas__prior .r1-td-state { color: var(--ink-2) !important; }
.atlas__prior .r1-td-badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.atlas__prior .r1-badge-deed {
  background: oklch(0.48 0.11 158 / 0.1);
  color: var(--accent);
}
/* Buy now button — Atlas */
.atlas__prior #r1-auction-table tbody td button {
  background: var(--accent) !important;
  color: #fff !important;
  border: none !important;
  padding: 7px 18px !important;
  border-radius: var(--radius-sm) !important;
  font-family: var(--font-sans) !important;
  font-weight: 600 !important;
  font-size: 12px !important;
  cursor: pointer !important;
  transition: background 160ms ease, transform 160ms ease !important;
  white-space: nowrap !important;
}
.atlas__prior #r1-auction-table tbody td button:hover {
  background: var(--accent-strong) !important;
  transform: translateY(-1px) !important;
}
/* Pagination — Atlas */
.atlas__prior .r1-pagination-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 22px;
  background: oklch(0.97 0.004 158 / 0.6);
  border-top: 1px solid var(--border);
  font-family: var(--font-sans);
  font-size: 12.5px;
  color: var(--ink-3);
}
.atlas__prior .r1-pagination-info strong { color: var(--ink-1); }
.atlas__prior .r1-pagination-btns { display: flex; gap: 4px; align-items: center; }
.atlas__prior .r1-page-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  height: 28px;
  padding: 0 8px;
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: 11.5px;
  color: var(--ink-2);
  text-decoration: none;
  transition: all 160ms ease;
}
.atlas__prior .r1-page-btn:hover { background: oklch(0.48 0.11 158 / 0.08); color: var(--accent); }
.atlas__prior .r1-page-btn.active {
  background: var(--accent);
  color: #fff;
  font-weight: 600;
}
.atlas__prior .r1-page-btn.disabled { opacity: 0.35; pointer-events: none; }

.atlas__stage {
  flex: 1;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 30% 20%, oklch(0.65 0.04 158 / 0.10), transparent 50%),
    radial-gradient(ellipse at 80% 70%, oklch(0.67 0.03 170 / 0.08), transparent 55%),
    oklch(0.60 0.01 158);
}

.atlas__map-bg {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  pointer-events: none;
}
.atlas__map-bg::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(oklch(1 0 0 / 0.08) 1px, transparent 1px),
    linear-gradient(90deg, oklch(1 0 0 / 0.08) 1px, transparent 1px);
  background-size: 56px 56px;
  background-position: 0 0;
  opacity: 0.5;
  mask-image: radial-gradient(ellipse 70% 60% at center, black 40%, transparent 90%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at center, black 40%, transparent 90%);
}
.atlas__map-wrap {
  width: min(78%, 880px);
  height: calc(100% - 120px); /* leave room for KPI strip at bottom */
  position: relative;
  pointer-events: auto;
}
.atlas__map-wrap svg { width: 100%; height: 100%; }
.atlas__map-wrap svg path { pointer-events: auto; cursor: pointer; }

.atlas__compass {
  position: absolute;
  top: 110px; right: 80px;
  width: 56px; height: 56px;
  color: oklch(0.75 0.01 158);
  opacity: 0.6;
}
.atlas__compass svg { width: 100%; height: 100%; }
.atlas__compass-n {
  position: absolute;
  top: -8px; left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  color: var(--accent);
  font-weight: 700;
}
.atlas__coord {
  position: absolute;
  bottom: 160px; right: 80px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: oklch(0.65 0.01 158);
  letter-spacing: 0.06em;
  opacity: 0.7;
}

/* Zoom controls */
.atlas__zoom-controls {
  position: absolute;
  bottom: 120px; right: 340px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 15;
  background: oklch(1 0 0);
  backdrop-filter: blur(16px) saturate(140%);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}
.atlas__zoom-btn {
  display: grid;
  place-items: center;
  width: 36px; height: 36px;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--ink-2);
  transition: background 150ms ease, color 150ms ease;
}
.atlas__zoom-btn:hover {
  background: oklch(0.95 0.015 158 / 0.6);
  color: var(--accent-strong);
}
.atlas__zoom-btn:active {
  background: oklch(0.90 0.03 158 / 0.5);
}
.atlas__zoom-btn svg { width: 16px; height: 16px; }
.atlas__zoom-btn + .atlas__zoom-btn {
  border-top: 1px solid oklch(0.91 0.008 158 / 0.4);
}

/* Floating panels — glass */
.atlas__top-panel {
  position: absolute;
  top: 24px; left: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 10;
}
.atlas__state-pill {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 8px 8px 14px;
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.7);
  border-radius: 999px;
  box-shadow: var(--shadow-md);
  width: fit-content;
}
.atlas__state-flag { font-size: 16px; }
.atlas__state-label {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  line-height: 1;
}
.atlas__state-name {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: -0.005em;
  color: var(--ink-1);
}
.atlas__state-count {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-3);
  padding-left: 12px;
  margin-left: 2px;
  border-left: 1px solid var(--border);
}
.atlas__state-switch {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--surface-2);
  display: grid; place-items: center;
  color: var(--ink-2);
}
.atlas__state-switch svg { width: 14px; height: 14px; transform: rotate(90deg); }

.atlas__title-block {
  padding: 14px 18px;
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  max-width: 320px;
}
.atlas__title-eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 6px;
}
.atlas__title {
  font-family: var(--font-display);
  font-size: 26px;
  letter-spacing: -0.025em;
  font-weight: 400;
  margin: 0;
  line-height: 1.1;
  color: var(--ink-1);
}
.atlas__subtitle {
  margin: 4px 0 0;
  font-size: 11.5px;
  color: var(--ink-3);
  line-height: 1.3;
}

/* Floating left panel — anchored below the top panel, not from bottom */
.atlas__left-panel {
  position: absolute;
  top: 220px; left: 24px;
  width: 260px;
  max-height: calc(100% - 360px); /* never overlap KPI strip */
  overflow-y: auto;
  z-index: 10;
}
.atlas__agenda {
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  padding: 12px;
  box-shadow: var(--shadow-md);
}

/* Floating right panel */
.atlas__right-panel {
  position: absolute;
  top: 24px; right: 24px;
  width: 320px;
  z-index: 10;
}
.atlas__top-counties {
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  padding: 8px;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.atlas__see-all {
  display: flex; align-items: center; gap: 4px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent);
  font-weight: 600;
  padding: 8px 14px;
  text-decoration: none;
}
.atlas__see-all svg { width: 12px; height: 12px; }

/* Bottom-center legend */
.atlas__legend {
  position: absolute;
  bottom: 112px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

/* KPI strip bottom */
.atlas__kpis {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-top: 1px solid var(--border);
  z-index: 5;
}
.atlas__kpis .kpi-tile {
  border: none;
  border-radius: 0;
  padding: 18px 28px;
  background: oklch(1 0 0);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* ═══ fadeUp animation ═══ */
@keyframes atlasFadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.atlas__top-panel,
.atlas__left-panel,
.atlas__right-panel,
.atlas__legend,
.atlas__kpis {
  animation: atlasFadeUp 500ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}
.atlas__top-panel   { animation-delay: 100ms; }
.atlas__left-panel  { animation-delay: 250ms; }
.atlas__right-panel { animation-delay: 200ms; }
.atlas__legend      { animation-delay: 350ms; }
.atlas__kpis        { animation-delay: 300ms; }
</style>

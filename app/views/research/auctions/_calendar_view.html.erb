<%#
  Partial: Calendar View (Rama 1)
  Month-view calendar with sale date indicators.
  Click event → Rama 2 parcels list (NEVER to Parcel#show).
%>
<div class="r1-calendar-container">
  <div class="r1-calendar-header">
    <button class="r1-cal-nav-btn" title="Previous month" onclick="r1ChangeMonth(-1)">
      <i data-lucide="chevron-left" style="width:14px;height:14px;"></i>
    </button>
    <button class="r1-cal-today-btn" onclick="r1GoToday()">Today</button>
    <button class="r1-cal-nav-btn" title="Next month" onclick="r1ChangeMonth(1)">
      <i data-lucide="chevron-right" style="width:14px;height:14px;"></i>
    </button>
    <span class="r1-cal-month-title" id="r1-cal-title"></span>
    <div class="r1-cal-legend">
      <div class="r1-cal-legend-item">
        <div class="r1-cal-legend-dot" style="background:#15803D;"></div> Deed
      </div>
    </div>
    <div class="r1-cal-view-toggle">
      <button class="r1-cal-view-btn active" onclick="r1CalViewMode('month', this)">Month</button>
    </div>
  </div>
  <div id="r1-cal-grid" class="r1-calendar-grid">
    <!-- Generated by JS -->
  </div>
</div>

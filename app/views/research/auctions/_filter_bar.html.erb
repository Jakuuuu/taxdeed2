<%#
  Partial: Filter Bar (Rama 1)
  Settings, Save, Reset, View toggle
%>
<div class="r1-filter-bar">
  <%# Action buttons: Settings, Save, Presets %>
  <div class="r1-filter-group" style="position:relative; margin-left: auto;">
    <%# Settings (column visibility) popup %>
    <div style="position:relative;">
      <button class="r1-custom-dropdown-btn" id="btn-filter" onclick="r1ToggleSettingsPopup()" title="Table Settings">
        <i data-lucide="settings" style="width:14px;height:14px;"></i>
      </button>
      <div class="r1-settings-popup" id="menu-settings-popup">
        <h4>Table Columns</h4>
        <div class="r1-settings-list" id="r1-column-settings">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>

    <%# Save search popup %>
    <div style="position:relative;">
      <button class="r1-custom-dropdown-btn" id="btn-save" onclick="r1ToggleSavePopup()" title="Saved Searches">
        <i data-lucide="bookmark" style="width:14px;height:14px;"></i>
      </button>
      <div class="r1-save-popup" id="menu-save-popup">
        <h4>Saved Searches</h4>
        <div class="r1-save-form-row">
          <input type="text" id="r1-save-name" placeholder="Name this search...">
          <button onclick="r1SaveSearch()">Save</button>
        </div>
        <div id="r1-saved-list">
          <!-- Populated by JS from localStorage -->
        </div>
      </div>
    </div>

    <%# Preset chip %>
    <a href="<%= research_auctions_path %>" class="r1-preset-chip" title="Reset all filters">
      <i data-lucide="filter-x" style="width:12px;height:12px;"></i> Reset
    </a>

    <%# View toggle buttons %>
    <div class="r1-view-btn-group">
      <button class="r1-view-btn active" id="btn-map" onclick="r1SwitchView('map')" title="Map View">
        <i data-lucide="map" style="width:14px;height:14px;"></i>
      </button>
      <button class="r1-view-btn" id="btn-calendar" onclick="r1SwitchView('calendar')" title="Calendar">
        <i data-lucide="calendar" style="width:14px;height:14px;"></i>
      </button>
      <button class="r1-view-btn" id="btn-list" onclick="r1SwitchView('list')" title="List View">
        <i data-lucide="list" style="width:14px;height:14px;"></i>
      </button>
    </div>
  </div>
</div>

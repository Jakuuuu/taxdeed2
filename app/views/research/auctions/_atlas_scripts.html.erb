<%# Atlas Scripts — Multi-state SVG Map + Interactions %>
<%# NOTE: state-geo.js files are loaded dynamically below to survive Turbo Drive navigations %>
<script>
(function(){
"use strict";

// ═══════════════════════════════════════
// Multi-state geo registry (one entry per *-geo.js file in /public)
// ═══════════════════════════════════════
var STATE_GEO = {
  FL: { script: "/florida-geo.js",    name: "Florida",    paths: "FL_COUNTY_PATHS_REAL", labels: "FL_COUNTY_LABELS_REAL", viewBox: "FL_MAP_VIEWBOX" },
  TX: { script: "/texas-geo.js",      name: "Texas",      paths: "TX_COUNTY_PATHS_REAL", labels: "TX_COUNTY_LABELS_REAL", viewBox: "TX_MAP_VIEWBOX" },
  CA: { script: "/california-geo.js", name: "California", paths: "CA_COUNTY_PATHS_REAL", labels: "CA_COUNTY_LABELS_REAL", viewBox: "CA_MAP_VIEWBOX" }
};
var ACTIVE_STATE = "<%= (@active_state && @active_state[:abbr]) || 'FL' %>";
if (!STATE_GEO[ACTIVE_STATE]) ACTIVE_STATE = "FL";
function activeStateName() { return (STATE_GEO[ACTIVE_STATE] || STATE_GEO.FL).name; }

// ═══════════════════════════════════════
// Turbo-safe geo-data loader (per state)
// ═══════════════════════════════════════
function ensureGeoData(stateAbbr, cb) {
  var cfg = STATE_GEO[stateAbbr];
  if (!cfg) { console.warn("[Atlas] unknown state:", stateAbbr); return; }
  if (window[cfg.paths] && Object.keys(window[cfg.paths]).length > 0) { cb(); return; }
  var s = document.createElement("script");
  s.src = cfg.script + "?_t=" + Date.now(); // cache-bust for safety
  s.onload = function() { cb(); };
  s.onerror = function() { console.warn("[Atlas] geo script failed:", cfg.script); cb(); };
  document.head.appendChild(s);
}

var P, L, VB;
function initGeoRefs(stateAbbr) {
  var cfg = STATE_GEO[stateAbbr] || STATE_GEO.FL;
  P  = window[cfg.paths]   || {};
  L  = window[cfg.labels]  || {};
  VB = window[cfg.viewBox] || "0 0 1000 800";
}

var CD={};
<% (@county_rows || []).each do |cr| %>
CD["<%= cr[:county]&.parameterize %>"]=
{id:"<%= cr[:county]&.parameterize %>",name:"<%= cr[:county] %>",state:"<%= cr[:state] %>",
props:<%= cr[:parcel_count].to_i %>,
auctions:<%= cr[:auction_ids]&.size || 0 %>,
next:"<%= cr[:next_sale_date].is_a?(Date) ? cr[:next_sale_date].strftime('%b %d') : cr[:next_sale_date] %>",
url:"<%= research_parcels_path(county: cr[:county], state: cr[:state]) %>"};
<% end %>

function hc(n){
 if(n===0)return{f:"#FFFFFF",s:"#E0E0E0"};
 return{f:"oklch(0.62 0.17 155)",s:"oklch(0.48 0.14 155)"};
}

// ═══════════════════════════════════════
// Pan & Zoom state (deferred — VB is set by initGeoRefs)
// ═══════════════════════════════════════
var vb = { x: 0, y: 0, w: 1000, h: 800 };
var origVb = { x: 0, y: 0, w: 1000, h: 800 };
var MIN_ZOOM = 0.25;  // max zoom-in: 25% of original viewBox
var MAX_ZOOM = 1.2;   // max zoom-out: 120% of original
var isPanning = false;
var panStart = { x: 0, y: 0 };
var panDragged = false;
var DRAG_THRESHOLD = 5; // px before counting as drag vs click
var mapSvg = null;

// ── County selection state (shared across renderMap / initTip / boot) ──
var activeCounty = null;   // currently hovered county item
var selectedCounty = null; // click-persistent selected county item

function applySelected(item){
 item.p.setAttribute("fill","oklch(0.35 0.13 158)");
 item.p.setAttribute("stroke","oklch(0.62 0.17 155)");
 item.p.setAttribute("stroke-width","2.5");
 item.p.style.filter="drop-shadow(0 0 10px oklch(0.62 0.17 155/0.55))";
}
function clearSelected(item){
 if(!item)return;
 item.p.setAttribute("fill",item.origFill);
 item.p.setAttribute("stroke","#2C3E50");
 item.p.setAttribute("stroke-width","1.2");
 item.p.style.filter="none";
}

function initViewBox() {
  var vbParts = (VB || "0 0 1000 800").split(" ").map(Number);
  vb = { x: vbParts[0], y: vbParts[1], w: vbParts[2], h: vbParts[3] };
  origVb = { x: vb.x, y: vb.y, w: vb.w, h: vb.h };
}

function applyViewBox() {
  if (!mapSvg) return;
  mapSvg.setAttribute("viewBox", vb.x + " " + vb.y + " " + vb.w + " " + vb.h);
}

function resetView() {
  vb.x = origVb.x; vb.y = origVb.y; vb.w = origVb.w; vb.h = origVb.h;
  applyViewBox();
}

function screenToSVG(svg, clientX, clientY) {
  var pt = svg.createSVGPoint();
  pt.x = clientX; pt.y = clientY;
  var ctm = svg.getScreenCTM();
  if (!ctm) return { x: 0, y: 0 };
  return pt.matrixTransform(ctm.inverse());
}

function renderMap(){
 var w=document.getElementById("atlasMapWrap"); if(!w)return;
 var ns="http://www.w3.org/2000/svg";
 var svg=document.createElementNS(ns,"svg");
 svg.setAttribute("viewBox",VB);
 svg.setAttribute("preserveAspectRatio","xMidYMid meet");
 svg.style.cssText="width:100%;height:100%;display:block;cursor:grab";
 mapSvg = svg;

 // Defs
 var defs=document.createElementNS(ns,"defs");
 var pat=document.createElementNS(ns,"pattern");
 pat.setAttribute("id","grid-pat");pat.setAttribute("width","32");pat.setAttribute("height","32");
 pat.setAttribute("patternUnits","userSpaceOnUse");
 var pp=document.createElementNS(ns,"path");
 pp.setAttribute("d","M 32 0 L 0 0 0 32");pp.setAttribute("fill","none");
 pp.setAttribute("stroke","var(--border)");pp.setAttribute("stroke-width","0.5");pp.setAttribute("opacity","0.35");
 pat.appendChild(pp);defs.appendChild(pat);svg.appendChild(defs);

 var gr=document.createElementNS(ns,"rect");
 gr.setAttribute("width","100%");gr.setAttribute("height","100%");gr.setAttribute("fill","url(#grid-pat)");
 svg.appendChild(gr);

 // Shadow halo
 var sh=document.createElementNS(ns,"g");sh.setAttribute("opacity","0.1");
 for(var id in P){var sp=document.createElementNS(ns,"path");
  sp.setAttribute("d",P[id]);sp.setAttribute("fill","oklch(0.18 0.015 158)");
  sp.setAttribute("transform","translate(2 4)");sh.appendChild(sp);}
 svg.appendChild(sh);

 // Counties — hover tracking + click-to-select
 // NOTE: activeCounty, selectedCounty, applySelected, clearSelected are in IIFE scope above renderMap
 var cg=document.createElementNS(ns,"g");
 function resetCounty(item){
  if(!item)return;
  item.g.style.transform="translate(0,0) scale(1)";item.g.style.filter="none";
  item.p.setAttribute("fill",item.origFill);item.p.setAttribute("stroke","#2C3E50");
  item.p.setAttribute("stroke-width","1.2");if(item.lg)item.lg.style.opacity="0";
 }
 for(var id in P){(function(id){
  var c=CD[id]||{id:id,name:(L[id]||{}).name||id,state:activeStateName(),props:0,next:"—",url:""};
  var lb=L[id], co=hc(c.props);
  var g=document.createElementNS(ns,"g");
  g.style.cssText="cursor:pointer;transition:transform 220ms cubic-bezier(.2,.8,.2,1),filter 220ms ease";
  if(lb)g.style.transformOrigin=lb.x+"px "+lb.y+"px";

  var p=document.createElementNS(ns,"path");
  p.setAttribute("d",P[id]);p.setAttribute("fill",co.f);
  p.dataset.origFill=co.f;
  p.setAttribute("stroke","#2C3E50");p.setAttribute("stroke-width","1.2");
  p.setAttribute("stroke-linejoin","round");p.setAttribute("vector-effect","non-scaling-stroke");
  p.style.transition="fill 200ms ease,stroke 200ms ease";
  g.appendChild(p);

  // Hover label
  var lg=null;
  if(lb){
   lg=document.createElementNS(ns,"g");lg.style.cssText="pointer-events:none;opacity:0;transition:opacity 180ms ease";
   var t1=document.createElementNS(ns,"text");
   t1.setAttribute("x",lb.x);t1.setAttribute("y",lb.y-2);
   t1.setAttribute("text-anchor","middle");t1.setAttribute("dominant-baseline","middle");
   t1.style.cssText="font-family:var(--font-sans);font-size:13px;font-weight:700;fill:var(--accent-strong);letter-spacing:-0.01em;paint-order:stroke;stroke:white;stroke-width:3.5;stroke-linejoin:round";
   t1.textContent=lb.name;lg.appendChild(t1);
   var t2=document.createElementNS(ns,"text");
   t2.setAttribute("x",lb.x);t2.setAttribute("y",lb.y+13);
   t2.setAttribute("text-anchor","middle");t2.setAttribute("dominant-baseline","middle");
   t2.style.cssText="font-family:var(--font-mono);font-size:10px;font-weight:600;fill:var(--ink-2);paint-order:stroke;stroke:white;stroke-width:3;stroke-linejoin:round";
   t2.textContent=c.props+(c.props===1?" property":" properties");lg.appendChild(t2);
   g.appendChild(lg);
  }

  // Store ref for exclusive hover reset
  var item={g:g,p:p,lg:lg,origFill:co.f};

  g.addEventListener("mouseenter",function(){
   if(isPanning)return;
   if(activeCounty&&activeCounty!==item){resetCounty(activeCounty);}
   activeCounty=item;
   // Don't override selected state visuals
   if(selectedCounty!==item){
    g.style.transform="translate(-3px,-8px) scale(1.04)";
    g.style.filter="drop-shadow(0 10px 18px oklch(0.18 0.015 158/0.28))";
    p.setAttribute("fill","var(--accent-soft)");p.setAttribute("stroke","var(--accent-strong)");
    p.setAttribute("stroke-width","1.8");
   }
   if(lg)lg.style.opacity="1";
   cg.appendChild(g);
   // Mostrar ficha flotante en hover (no pisar el estado click-pinned)
   if(selectedCounty!==item){
    var hx,hy;
    if(lb&&mapSvg){var sp=svgToScreen(mapSvg,lb.x,lb.y);hx=sp.x;hy=sp.y;}
    else{var r=p.getBoundingClientRect();hx=r.left+r.width/2;hy=r.top+r.height/2;}
    showTip(c,hx,hy);
   }
  });
  g.addEventListener("mouseleave",function(){
   if(selectedCounty===item)return; // keep selected state, don't reset
   resetCounty(item);
   if(activeCounty===item)activeCounty=null;
   if(!selectedCounty)hideTip(); // oculta solo si nada está pinned
  });
  (function(county,labelData){
   var downX=0,downY=0;
   g.addEventListener("mousedown",function(e){downX=e.clientX;downY=e.clientY;});
   g.addEventListener("click",function(e){
    var dx=Math.abs(e.clientX-downX),dy=Math.abs(e.clientY-downY);
    if(dx>DRAG_THRESHOLD||dy>DRAG_THRESHOLD)return;
    e.stopPropagation();
    // Toggle: clicking selected county closes the popover
    if(selectedCounty===item){clearSelected(item);selectedCounty=null;hideTip();return;}
    // Select new county
    if(selectedCounty)clearSelected(selectedCounty);
    selectedCounty=item;
    applySelected(item);
    // Get screen position from SVG centroid, fall back to click coords
    var sx,sy;
    if(labelData&&mapSvg){var sp=svgToScreen(mapSvg,labelData.x,labelData.y);sx=sp.x;sy=sp.y;}
    else{sx=e.clientX;sy=e.clientY;}
    showTip(county,sx,sy);
   });
  })(c,lb);
  cg.appendChild(g);
 })(id);}
 svg.appendChild(cg);

 // Close county detail panel when clicking on empty SVG background
 svg.addEventListener("click",function(e){
  if(e.target===svg||e.target.tagName==="rect"){
   hideTip();
   if(activeCounty){ resetCounty(activeCounty); activeCounty=null; }
  }
 });

 w.innerHTML="";w.appendChild(svg);

 // ═══════════════════════════════════════
 // Pan handlers on the SVG
 // ═══════════════════════════════════════
 svg.addEventListener("mousedown", function(e) {
   if (e.button !== 0) return; // left-click only
   isPanning = true;
   panDragged = false;
   panStart.x = e.clientX;
   panStart.y = e.clientY;
   svg.style.cursor = "grabbing";
   e.preventDefault(); // prevent text selection
 });

 svg.addEventListener("mousemove", function(e) {
   if (!isPanning) return;
   var dx = e.clientX - panStart.x;
   var dy = e.clientY - panStart.y;
   if (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD) {
     panDragged = true;
   }
   // Convert screen px movement to SVG viewBox units
   var rect = svg.getBoundingClientRect();
   var scaleX = vb.w / rect.width;
   var scaleY = vb.h / rect.height;
   vb.x -= dx * scaleX;
   vb.y -= dy * scaleY;
   applyViewBox();
   panStart.x = e.clientX;
   panStart.y = e.clientY;
 });

 svg.addEventListener("mouseup", function() {
   isPanning = false;
   svg.style.cursor = "grab";
   // Clear panDragged after a tick so click events can check it
   setTimeout(function() { panDragged = false; }, 50);
 });

 svg.addEventListener("mouseleave", function() {
   if (isPanning) {
     isPanning = false;
     svg.style.cursor = "grab";
     setTimeout(function() { panDragged = false; }, 50);
   }
 });

 // ═══════════════════════════════════════
 // Zoom with scroll wheel
 // ═══════════════════════════════════════
 w.addEventListener("wheel", function(e) {
   e.preventDefault();
   var zoomFactor = e.deltaY > 0 ? 1.08 : 0.92; // scroll down = zoom out, up = zoom in
   var newW = vb.w * zoomFactor;
   var newH = vb.h * zoomFactor;
   // Enforce limits
   var ratioW = newW / origVb.w;
   if (ratioW < MIN_ZOOM || ratioW > MAX_ZOOM) return;
   // Zoom toward mouse position
   var svgPt = screenToSVG(svg, e.clientX, e.clientY);
   var dx = (newW - vb.w);
   var dy = (newH - vb.h);
   // Proportion of mouse position within current viewBox
   var mx = (svgPt.x - vb.x) / vb.w;
   var my = (svgPt.y - vb.y) / vb.h;
   vb.x -= dx * mx;
   vb.y -= dy * my;
   vb.w = newW;
   vb.h = newH;
   applyViewBox();
 }, { passive: false });
}

// County Anchored Popover
var tt=null,tn=null,tp=null,ta=null,tx=null;

// Convert SVG coordinate to screen pixel
function svgToScreen(svgEl,svgX,svgY){
 var pt=svgEl.createSVGPoint();
 pt.x=svgX;pt.y=svgY;
 var ctm=svgEl.getScreenCTM();
 if(!ctm)return{x:0,y:0};
 return pt.matrixTransform(ctm);
}

function initTip(){
 tt=document.getElementById("atlasCountyPanel");
 tn=document.getElementById("cdpName");
 tp=document.getElementById("cdpProps");
 ta=document.getElementById("cdpAuctions");
 tx=document.getElementById("cdpNext");
 var closeBtn=document.getElementById("cdpClose");
 if(closeBtn)closeBtn.addEventListener("click",function(e){
  e.stopPropagation();
  // selectedCounty and clearSelected are in IIFE scope — always accessible
  if(selectedCounty){clearSelected(selectedCounty);selectedCounty=null;}
  hideTip();
 });
}

function showTip(c,screenX,screenY){
 // Lazy init — retry panel lookup in case boot() ran before the partial was painted
 if(!tt) initTip();
 if(!tt)return;
 // Populate content
 tn.textContent=c.name;
 if(tp)tp.textContent=c.props;
 if(ta)ta.textContent=c.auctions||c.props;
 if(tx)tx.textContent=c.next||"—";
 var cta=document.getElementById("cdpCta");
 if(cta){
   var ctaUrl="/research/parcels?county="+encodeURIComponent(c.name)+"&state="+encodeURIComponent(c.state||ACTIVE_STATE);
   // Assign onclick directly — immune to Turbo cache and missing data-href attributes
   cta.onclick=function(e){
     e.preventDefault();
     if(typeof Turbo!=="undefined"){Turbo.visit(ctaUrl);}
     else{window.location.href=ctaUrl;}
   };
 }
 // Smart positioning
 var PW=278,PH=168,OFFSET=22;
 var vw=window.innerWidth,vh=window.innerHeight;
 var PANEL_L=416,PANEL_R=316; // widths of left/right panels
 var stemDir="down"; // popover above county → stem points down
 var top=screenY-PH-OFFSET;
 var left=screenX-PW/2;
 if(top<88){top=screenY+OFFSET;stemDir="up";}
 var minL=PANEL_L+8,maxL=vw-PANEL_R-PW-8;
 if(left<minL)left=minL;
 if(left>maxL)left=maxL;
 // Stem x offset: where arrow points relative to popover left edge
 var stemX=Math.max(18,Math.min(PW-18,Math.round(screenX-left)));
 tt.style.left=left+"px";
 tt.style.top=top+"px";
 tt.setAttribute("data-stem",stemDir);
 tt.style.setProperty("--cdp-stem-x",stemX+"px");
 tt.setAttribute("aria-hidden","false");
 tt.classList.add("visible");
}

function hideTip(){
 if(!tt)return;
 tt.classList.remove("visible");
 tt.setAttribute("aria-hidden","true");
}
// no-op — hover handlers manejan show/hide; click solo "pinnea"
function _atlasMouseMove(e){}
// NOTE: mousemove listener is registered in the Turbo management section below

// Expose resetView globally for the zoom controls
window.atlasResetView = function() { resetView(); };

// ═══════════════════════════════════════
// State switcher — opens the inline glass dropdown and reloads via Turbo
// ═══════════════════════════════════════
window.atlasChangeActiveState = function(stateAbbr) {
  var cfg = STATE_GEO[stateAbbr];
  if (!cfg) return;
  var url = new URL(window.location.href);
  url.searchParams.set("state", cfg.name);
  // Drop pagination/county filters that don't carry across states
  url.searchParams.delete("county");
  url.searchParams.delete("page");
  if (window.Turbo && typeof Turbo.visit === "function") {
    Turbo.visit(url.toString(), { action: "replace" });
  } else {
    window.location.href = url.toString();
  }
};

function initStateMenu() {
  var pill = document.getElementById("atlasStatePill");
  var btn  = document.getElementById("atlasStateSwitch");
  var menu = document.getElementById("atlasStateMenu");
  if (!btn || !menu || !pill) return;
  // Guard against double-binding across Turbo loads
  if (pill.dataset.stateMenuReady === "1") return;
  pill.dataset.stateMenuReady = "1";

  function openMenu()  { menu.hidden = false; btn.setAttribute("aria-expanded","true"); }
  function closeMenu() { menu.hidden = true;  btn.setAttribute("aria-expanded","false"); }

  btn.addEventListener("click", function(e) {
    e.stopPropagation();
    menu.hidden ? openMenu() : closeMenu();
  });

  menu.querySelectorAll(".atlas__state-menu-item").forEach(function(item) {
    item.addEventListener("click", function(e) {
      e.stopPropagation();
      var abbr = item.dataset.stateAbbr;
      closeMenu();
      window.atlasChangeActiveState(abbr);
    });
  });

  // Click-outside closes the menu (use mousedown so it fires before pan handlers)
  document.addEventListener("mousedown", function(e) {
    if (!menu.hidden && !pill.contains(e.target)) closeMenu();
  });
  // Esc closes
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && !menu.hidden) closeMenu();
  });
}

function boot(){
  // Guard: skip if the atlas map container is not in the DOM (we're on another page)
  if (!document.getElementById("atlasMapWrap")) return;

  // Ensure geo data is loaded (survives Turbo Drive navigations)
  ensureGeoData(ACTIVE_STATE, function() {
    initGeoRefs(ACTIVE_STATE);
    initViewBox();
    initTip();
    renderMap();
    initStateMenu();

    // Zoom control buttons
    var zoomIn = document.getElementById("atlasZoomIn");
    var zoomOut = document.getElementById("atlasZoomOut");
    var zoomReset = document.getElementById("atlasZoomReset");
    if (zoomIn) zoomIn.addEventListener("click", function() {
      var factor = 0.8;
      var newW = vb.w * factor, newH = vb.h * factor;
      if (newW / origVb.w < MIN_ZOOM) return;
      vb.x += (vb.w - newW) / 2;
      vb.y += (vb.h - newH) / 2;
      vb.w = newW; vb.h = newH;
      applyViewBox();
    });
    if (zoomOut) zoomOut.addEventListener("click", function() {
      var factor = 1.25;
      var newW = vb.w * factor, newH = vb.h * factor;
      if (newW / origVb.w > MAX_ZOOM) return;
      vb.x += (vb.w - newW) / 2;
      vb.y += (vb.h - newH) / 2;
      vb.w = newW; vb.h = newH;
      applyViewBox();
    });
    if (zoomReset) zoomReset.addEventListener("click", function() { resetView(); });

    // Ocultar el popover INMEDIATAMENTE al salir de los bordes del mapa.
    // Si el mouse va hacia el panel (popover), no se oculta para permitir el click.
    var wrap  = document.getElementById("atlasMapWrap");
    var panel = document.getElementById("atlasCountyPanel");

    function hideIfNotTowardPanel(e) {
      // relatedTarget = elemento al que va el mouse tras salir
      var to = e.relatedTarget;
      if (panel && to && (panel === to || panel.contains(to))) return; // va al popover → no ocultar
      // Va fuera del mapa y fuera del popover → ocultar de inmediato
      var groups = wrap ? wrap.querySelectorAll("g[style]") : [];
      [].forEach.call(groups, function(g){
        g.style.transform = "translate(0,0) scale(1)";
        g.style.filter = "none";
        var path = g.querySelector("path");
        if(path && path.dataset.origFill){
          path.setAttribute("fill", path.dataset.origFill);
          path.setAttribute("stroke", "#2C3E50");
          path.setAttribute("stroke-width", "1.2");
        }
        var label = g.querySelector("g[style*='pointer-events']");
        if(label) label.style.opacity = "0";
      });
      if(activeCounty){ activeCounty = null; }
      if(!selectedCounty){ hideTip(); }
    }

    if(wrap){
      wrap.addEventListener("mouseleave", hideIfNotTowardPanel);
    }
    if(panel){
      // Al salir del popover: ocultar de inmediato si el mouse NO vuelve al mapa
      panel.addEventListener("mouseleave", function(e){
        var to = e.relatedTarget;
        if (wrap && to && (wrap === to || wrap.contains(to))) return; // vuelve al mapa → no ocultar
        if(!selectedCounty){ hideTip(); }
      });
    }
    // Signal to AtlasPanelManager that the map is fully rendered
    document.dispatchEvent(new CustomEvent("atlas:booted"));
  });
}

// ── Turbo-safe listener management ──────────────────────────────────────
// Store handlers on window so removeEventListener works across IIFE re-executions
if (window._atlasTurboBeforeRender) {
  document.removeEventListener("turbo:before-render", window._atlasTurboBeforeRender);
}
if (window._atlasTurboLoad) {
  document.removeEventListener("turbo:load", window._atlasTurboLoad);
}
if (window._atlasMouseMoveHandler) {
  document.removeEventListener("mousemove", window._atlasMouseMoveHandler);
}

window._atlasTurboBeforeRender = function() {
  hideTip();
  var tip = document.getElementById("atlasTooltip");
  if (tip) tip.classList.remove("visible");
  // Clear panel manager flags so it re-initializes after Turbo navigation
  var stage = document.getElementById("atlasStage");
  if (stage) {
    delete stage.dataset.panelMgrReady;
    stage.querySelectorAll("[data-panel-controls-injected]").forEach(function(el) {
      delete el.dataset.panelControlsInjected;
    });
  }
  window.atlasPanelMgr = null;
};
window._atlasTurboLoad = function() { boot(); };
window._atlasMouseMoveHandler = _atlasMouseMove;

document.addEventListener("turbo:before-render", window._atlasTurboBeforeRender);
document.addEventListener("turbo:load", window._atlasTurboLoad);
document.addEventListener("mousemove", window._atlasMouseMoveHandler);

document.addEventListener("DOMContentLoaded", boot);

})(); // ── close IIFE #1 (Atlas Scripts: map + interactions) ──

// ═══════════════════════════════════════════════════════
// AtlasPanelManager — Draggable, resizable, minimizable panels
// ═══════════════════════════════════════════════════════
(function() {
"use strict";

var LS_PREFIX = "atlas_panel_v1_";

function AtlasPanelManager(stageEl) {
  this.stage = stageEl;
  this.panels = []; // { el, id, label, defaultPos, defaultSize }
  this.kpiTiles = []; // { el, id, label }
  this._mgrOpen = false;
}

AtlasPanelManager.prototype.init = function() {
  var self = this;
  var stage = this.stage;
  if (!stage) return;

  // Guard: only inject once per DOM boot (Turbo cache safety)
  if (stage.dataset.panelMgrReady === "1") return;
  stage.dataset.panelMgrReady = "1";

  // Collect panels
  var panelEls = stage.querySelectorAll("[data-panel-id]");
  panelEls.forEach(function(el) {
    var id = el.dataset.panelId;
    var label = el.dataset.panelLabel || id;
    var defaultPos = {};
    var defaultSize = {};
    try { defaultPos = JSON.parse(el.dataset.panelDefaultPos || "{}"); } catch(e) {}
    try { defaultSize = JSON.parse(el.dataset.panelDefaultSize || "{}"); } catch(e) {}

    // Make position:absolute driven by JS, converting CSS-set position
    // to computed left/top so drag works from current visual position
    el.style.position = "absolute";
    var rect = el.getBoundingClientRect();
    var stageRect = stage.getBoundingClientRect();

    var panel = { el: el, id: id, label: label, defaultPos: defaultPos, defaultSize: defaultSize };
    self.panels.push(panel);

    self._restoreState(panel, rect, stageRect);
    self._injectControls(panel);
    self._makeDraggable(panel);
    // Don't add resize to kpis strip (it's a grid strip)
    if (id !== "kpis" && id !== "state-pill") {
      self._makeResizable(panel);
    }
  });

  // Collect KPI tiles
  var kpiEls = stage.querySelectorAll("[data-kpi-id]");
  kpiEls.forEach(function(el) {
    var ktiId = el.dataset.kpiId;
    var ktiLabel = el.dataset.kpiLabel || ktiId;
    self.kpiTiles.push({ el: el, id: ktiId, label: ktiLabel });
    self._restoreKpiState(ktiId, el);
  });

  // Build Panel Manager list
  this._buildMgrList();

  // Click outside popover closes it
  document.addEventListener("mousedown", function(e) {
    var mgr = document.getElementById("atlasPanelManager");
    if (mgr && !mgr.contains(e.target)) {
      self._closeMgrPopover();
    }
  });
};

AtlasPanelManager.prototype._restoreState = function(panel, rect, stageRect) {
  var id = panel.id;
  var el = panel.el;
  var ds = panel.defaultSize || {};

  // Restore visibility
  var vis = this._load(id, "visible");
  if (vis === false) {
    el.classList.add("atlas-panel--hidden");
  }

  // Restore minimized
  var min = this._load(id, "minimized");
  if (min === true) {
    el.classList.add("atlas-panel--minimized");
  }

  // Restore size (only if user has previously resized)
  var size = this._load(id, "size");
  if (size && size.width) el.style.width = size.width + "px";
  if (size && size.height) el.style.height = size.height + "px";

  // Restore position ONLY if user has previously moved the panel.
  // When no saved pos exists we leave the CSS-defined position completely
  // untouched — the stylesheet already places every panel correctly.
  var pos = this._load(id, "pos");
  if (pos) {
    el.style.left = pos.left + "px";
    el.style.top  = pos.top  + "px";
    el.style.right  = "";
    el.style.bottom = "";
  }
  // No else — CSS handles the default layout. Clean and safe.
};

AtlasPanelManager.prototype._restoreKpiState = function(id, el) {
  var vis = this._load("kpi_" + id, "visible");
  if (vis === false) {
    el.classList.add("kpi-tile--hidden");
  }
};

AtlasPanelManager.prototype._injectControls = function(panel) {
  var self = this;
  var el = panel.el;
  var id = panel.id;

  // Guard against double-injection
  if (el.dataset.panelControlsInjected === "1") return;
  el.dataset.panelControlsInjected = "1";

  // Ensure relative positioning for absolute children
  var cs = window.getComputedStyle(el);
  if (cs.position === "static") el.style.position = "relative";

  // Build control bar
  var bar = document.createElement("div");
  bar.className = "panel-header-controls";

  // Drag handle
  var dragBtn = document.createElement("button");
  dragBtn.className = "panel-ctrl-btn panel-ctrl-btn--drag";
  dragBtn.title = "Drag to move";
  dragBtn.setAttribute("aria-label", "Drag panel");
  dragBtn.innerHTML = '<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="9" cy="5" r="1" fill="currentColor"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="9" cy="19" r="1" fill="currentColor"/><circle cx="15" cy="5" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="19" r="1" fill="currentColor"/></svg>';
  bar.appendChild(dragBtn);

  // Minimize button (not for kpis strip)
  if (id !== "kpis") {
    var minBtn = document.createElement("button");
    minBtn.className = "panel-ctrl-btn panel-ctrl-btn--minimize";
    minBtn.title = "Minimize";
    minBtn.setAttribute("aria-label", "Minimize panel");
    minBtn.innerHTML = '<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 15l6 6 6-6"/></svg>';
    if (el.classList.contains("atlas-panel--minimized")) minBtn.classList.add("is-minimized");
    minBtn.addEventListener("click", function(e) {
      e.stopPropagation();
      self.toggleMinimize(panel, minBtn);
    });
    bar.appendChild(minBtn);
  }

  // Hide button
  var hideBtn = document.createElement("button");
  hideBtn.className = "panel-ctrl-btn panel-ctrl-btn--hide";
  hideBtn.title = "Hide panel";
  hideBtn.setAttribute("aria-label", "Hide panel");
  hideBtn.innerHTML = '<svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>';
  hideBtn.addEventListener("click", function(e) {
    e.stopPropagation();
    self.toggleVisible(id, false);
  });
  bar.appendChild(hideBtn);

  el.appendChild(bar);

  // Drag activates from the drag handle OR anywhere on the bar (not just the button)
  panel._dragHandle = dragBtn;
};

AtlasPanelManager.prototype._makeDraggable = function(panel) {
  var self = this;
  var el = panel.el;
  var handle = panel._dragHandle || el;

  var startX, startY, startLeft, startTop;
  var isDragging = false;

  handle.addEventListener("mousedown", function(e) {
    if (e.button !== 0) return;
    // CRITICAL: stopPropagation so SVG map pan is NOT triggered
    e.stopPropagation();
    e.preventDefault();

    isDragging = false;
    startX = e.clientX;
    startY = e.clientY;

    var rect = el.getBoundingClientRect();
    var stageRect = self.stage.getBoundingClientRect();
    startLeft = rect.left - stageRect.left;
    startTop = rect.top - stageRect.top;

    // Fix left/top immediately so we work in absolute coords
    el.style.left = startLeft + "px";
    el.style.top = startTop + "px";
    el.style.right = "";
    el.style.bottom = "";

    function onMove(e) {
      var dx = e.clientX - startX;
      var dy = e.clientY - startY;
      if (!isDragging && (Math.abs(dx) > 3 || Math.abs(dy) > 3)) {
        isDragging = true;
        el.classList.add("atlas-panel--dragging");
        el.style.pointerEvents = "none";
        document.body.style.userSelect = "none";
        document.body.style.cursor = "grabbing";
      }
      if (!isDragging) return;

      var stageRect = self.stage.getBoundingClientRect();
      var newLeft = Math.max(0, Math.min(stageRect.width - 40, startLeft + dx));
      var newTop = Math.max(0, Math.min(stageRect.height - 40, startTop + dy));
      el.style.left = newLeft + "px";
      el.style.top = newTop + "px";
    }

    function onUp() {
      document.removeEventListener("mousemove", onMove);
      document.removeEventListener("mouseup", onUp);
      if (isDragging) {
        el.classList.remove("atlas-panel--dragging");
        el.style.pointerEvents = "";
        document.body.style.userSelect = "";
        document.body.style.cursor = "";
        self._saveState(panel);
      }
      isDragging = false;
    }

    document.addEventListener("mousemove", onMove);
    document.addEventListener("mouseup", onUp);
  });
};

AtlasPanelManager.prototype._makeResizable = function(panel) {
  var self = this;
  var el = panel.el;

  var handle = document.createElement("div");
  handle.className = "panel-resize-handle";
  el.appendChild(handle);

  var startX, startY, startW, startH;
  var isResizing = false;

  handle.addEventListener("mousedown", function(e) {
    if (e.button !== 0) return;
    e.stopPropagation();
    e.preventDefault();

    isResizing = true;
    startX = e.clientX;
    startY = e.clientY;
    startW = el.offsetWidth;
    startH = el.offsetHeight;
    document.body.style.userSelect = "none";
    document.body.style.cursor = "nwse-resize";

    function onMove(e) {
      if (!isResizing) return;
      var newW = Math.max(180, startW + (e.clientX - startX));
      var newH = Math.max(80, startH + (e.clientY - startY));
      el.style.width = newW + "px";
      if (el.dataset.panelId !== "agenda") { // agenda scroll height is dynamic
        el.style.height = newH + "px";
      }
    }

    function onUp() {
      document.removeEventListener("mousemove", onMove);
      document.removeEventListener("mouseup", onUp);
      document.body.style.userSelect = "";
      document.body.style.cursor = "";
      isResizing = false;
      self._saveState(panel);
    }

    document.addEventListener("mousemove", onMove);
    document.addEventListener("mouseup", onUp);
  });
};

AtlasPanelManager.prototype.toggleMinimize = function(panel, btn) {
  var el = panel.el;
  var isMin = el.classList.toggle("atlas-panel--minimized");
  if (btn) btn.classList.toggle("is-minimized", isMin);
  this._save(panel.id, "minimized", isMin);
};

AtlasPanelManager.prototype.toggleVisible = function(panelId, visible) {
  var panel = this.panels.find(function(p) { return p.id === panelId; });
  if (!panel) return;
  if (visible) {
    panel.el.classList.remove("atlas-panel--hidden");
  } else {
    panel.el.classList.add("atlas-panel--hidden");
  }
  this._save(panelId, "visible", visible);
  this._buildMgrList();
};

AtlasPanelManager.prototype.toggleKpiTile = function(kpiId, visible) {
  var tile = this.kpiTiles.find(function(t) { return t.id === kpiId; });
  if (!tile) return;
  if (visible) {
    tile.el.classList.remove("kpi-tile--hidden");
  } else {
    tile.el.classList.add("kpi-tile--hidden");
  }
  this._save("kpi_" + kpiId, "visible", visible);
  this._buildMgrList();
};

AtlasPanelManager.prototype._saveState = function(panel) {
  var el = panel.el;
  var cs = window.getComputedStyle(el);
  var pos = { left: parseFloat(el.style.left) || 0, top: parseFloat(el.style.top) || 0 };
  var size = { width: el.offsetWidth, height: el.offsetHeight };
  this._save(panel.id, "pos", pos);
  this._save(panel.id, "size", size);
};

AtlasPanelManager.prototype.toggleMgrPopover = function() {
  this._mgrOpen = !this._mgrOpen;
  var pop = document.getElementById("atlasPanelMgrPopover");
  if (pop) pop.style.display = this._mgrOpen ? "" : "none";
};

AtlasPanelManager.prototype._closeMgrPopover = function() {
  this._mgrOpen = false;
  var pop = document.getElementById("atlasPanelMgrPopover");
  if (pop) pop.style.display = "none";
};

AtlasPanelManager.prototype._buildMgrList = function() {
  var self = this;
  var list = document.getElementById("atlasPanelMgrList");
  if (!list) return;
  list.innerHTML = "";

  this.panels.forEach(function(panel) {
    var isVisible = !panel.el.classList.contains("atlas-panel--hidden");
    var row = document.createElement("div");
    row.className = "panel-mgr-row";

    var label = document.createElement("span");
    label.className = "panel-mgr-row__label";
    label.textContent = panel.label;
    row.appendChild(label);

    var controls = document.createElement("div");
    controls.className = "panel-mgr-row__controls";

    // Toggle
    var tog = document.createElement("label");
    tog.className = "panel-mgr-toggle";
    var inp = document.createElement("input");
    inp.type = "checkbox";
    inp.checked = isVisible;
    var track = document.createElement("span");
    track.className = "panel-mgr-toggle-track";
    tog.appendChild(inp);
    tog.appendChild(track);
    inp.addEventListener("change", function() {
      self.toggleVisible(panel.id, inp.checked);
    });
    controls.appendChild(tog);
    row.appendChild(controls);
    list.appendChild(row);

    // KPI sub-rows
    if (panel.id === "kpis" && self.kpiTiles.length > 0) {
      var sub = document.createElement("div");
      sub.className = "panel-mgr-kpi-sub";
      self.kpiTiles.forEach(function(tile) {
        var kpiVisible = !tile.el.classList.contains("kpi-tile--hidden");
        var kRow = document.createElement("div");
        kRow.className = "panel-mgr-kpi-row";
        var kLabel = document.createElement("span");
        kLabel.className = "panel-mgr-kpi-row__label";
        kLabel.textContent = tile.label;
        kRow.appendChild(kLabel);

        var kTog = document.createElement("label");
        kTog.className = "panel-mgr-toggle";
        var kInp = document.createElement("input");
        kInp.type = "checkbox";
        kInp.checked = kpiVisible;
        var kTrack = document.createElement("span");
        kTrack.className = "panel-mgr-toggle-track";
        kTog.appendChild(kInp);
        kTog.appendChild(kTrack);
        kInp.addEventListener("change", (function(t, inp) {
          return function() { self.toggleKpiTile(t.id, inp.checked); };
        })(tile, kInp));

        kRow.appendChild(kTog);
        sub.appendChild(kRow);
      });
      list.appendChild(sub);
    }
  });
};

AtlasPanelManager.prototype.resetAllPanels = function() {
  var self = this;

  // Clear all saved state for panels
  this.panels.forEach(function(p) {
    ["pos","size","minimized","visible"].forEach(function(k) {
      try { localStorage.removeItem(LS_PREFIX + p.id + "_" + k); } catch(e) {}
    });
    // Restore DOM
    p.el.classList.remove("atlas-panel--hidden", "atlas-panel--minimized");
    var minBtn = p.el.querySelector(".panel-ctrl-btn--minimize");
    if (minBtn) minBtn.classList.remove("is-minimized");
    // Clear all inline styles — the CSS stylesheet defines the correct
    // default position/size for each panel, so we just let it take over.
    p.el.style.left   = "";
    p.el.style.top    = "";
    p.el.style.right  = "";
    p.el.style.bottom = "";
    p.el.style.width  = "";
    p.el.style.height = "";
  });

  // Clear KPI tiles
  this.kpiTiles.forEach(function(t) {
    try { localStorage.removeItem(LS_PREFIX + "kpi_" + t.id + "_visible"); } catch(e) {}
    t.el.classList.remove("kpi-tile--hidden");
  });

  this._buildMgrList();
  this._closeMgrPopover();
};

// localStorage helpers
AtlasPanelManager.prototype._save = function(id, key, val) {
  try { localStorage.setItem(LS_PREFIX + id + "_" + key, JSON.stringify(val)); } catch(e) {}
};
AtlasPanelManager.prototype._load = function(id, key) {
  try {
    var v = localStorage.getItem(LS_PREFIX + id + "_" + key);
    return v !== null ? JSON.parse(v) : null;
  } catch(e) { return null; }
};

// ── AtlasPanelManager boot — multi-path init ──
// Path 1: atlas:booted (normal — map rendered successfully)
document.addEventListener("atlas:booted", function() {
  var stage = document.getElementById("atlasStage");
  if (!stage) return;
  delete stage.dataset.panelMgrReady;
  window.atlasPanelMgr = new AtlasPanelManager(stage);
  window.atlasPanelMgr.init();
  initCrmCalendar();
});

// Path 2: turbo:load (Turbo Drive navigation)
document.addEventListener("turbo:load", function() {
  var stage = document.getElementById("atlasStage");
  if (!stage) return;
  // Clear ready flag so we can re-initialize (cache may have left it set)
  delete stage.dataset.panelMgrReady;
  stage.querySelectorAll("[data-panel-controls-injected]").forEach(function(el) {
    delete el.dataset.panelControlsInjected;
  });
  setTimeout(function() {
    // Only run if atlas:booted hasn't already initialized it
    if (stage.dataset.panelMgrReady !== "1") {
      window.atlasPanelMgr = new AtlasPanelManager(stage);
      window.atlasPanelMgr.init();
    }
    initCrmCalendar();
  }, 600);
});

// Path 3: Immediate inline attempt (script runs after DOM is parsed on first load)
// This handles the case where DOMContentLoaded already fired before this IIFE ran.
(function tryBootPanelMgr() {
  var stage = document.getElementById("atlasStage");
  if (!stage) return;
  if (stage.dataset.panelMgrReady === "1") return;
  window.atlasPanelMgr = new AtlasPanelManager(stage);
  window.atlasPanelMgr.init();
  initCrmCalendar();
})();

})();
</script>


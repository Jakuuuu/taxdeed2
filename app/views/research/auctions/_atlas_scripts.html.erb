<script>
// ═══════════════════════════════════════════════════════
// CRM Calendar — Personal pipeline auction calendar
// SOURCE: data-events JSON on [data-panel-id="crm-calendar"]
// SECURITY: data is pre-filtered server-side to current_user.pipeline_properties
// ═══════════════════════════════════════════════════════
(function() {
"use strict";

// State: which month is being displayed
var _crmYear  = new Date().getFullYear();
var _crmMonth = new Date().getMonth(); // 0-indexed

window.initCrmCalendar = function() {
  var panelEl = document.querySelector('[data-panel-id="crm-calendar"]');
  if (!panelEl) return;

  var gridEl = document.getElementById("crmCalGrid");
  if (!gridEl) return;

  // Parse events from server-rendered JSON
  var events = {};
  try {
    events = JSON.parse(panelEl.dataset.events || "{}");
  } catch(e) {
    events = {};
  }

  // Render current month
  renderCrmMonth(gridEl, events, _crmYear, _crmMonth);
};

function renderCrmMonth(gridEl, events, year, month) {
  gridEl.innerHTML = "";

  var MONTH_NAMES = ["January","February","March","April","May","June",
                     "July","August","September","October","November","December"];
  var today = new Date();
  var todayKey = today.getFullYear() + "-" +
    String(today.getMonth() + 1).padStart(2,"0") + "-" +
    String(today.getDate()).padStart(2,"0");

  // ── Header: Prev | Month Year | Next ──
  var header = document.createElement("div");
  header.className = "crm-cal__header";

  var prevBtn = document.createElement("button");
  prevBtn.className = "crm-cal__nav";
  prevBtn.setAttribute("aria-label", "Previous month");
  prevBtn.innerHTML = '<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="m15 18-6-6 6-6"/></svg>';
  prevBtn.onclick = function() {
    _crmMonth--;
    if (_crmMonth < 0) { _crmMonth = 11; _crmYear--; }
    renderCrmMonth(gridEl, events, _crmYear, _crmMonth);
  };

  var monthLabel = document.createElement("span");
  monthLabel.className = "crm-cal__month-label";
  monthLabel.textContent = MONTH_NAMES[month] + " " + year;

  var nextBtn = document.createElement("button");
  nextBtn.className = "crm-cal__nav";
  nextBtn.setAttribute("aria-label", "Next month");
  nextBtn.innerHTML = '<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>';
  nextBtn.onclick = function() {
    _crmMonth++;
    if (_crmMonth > 11) { _crmMonth = 0; _crmYear++; }
    renderCrmMonth(gridEl, events, _crmYear, _crmMonth);
  };

  header.appendChild(prevBtn);
  header.appendChild(monthLabel);
  header.appendChild(nextBtn);
  gridEl.appendChild(header);

  // ── Weekday labels ──
  var wds = document.createElement("div");
  wds.className = "crm-cal__weekdays";
  ["Su","Mo","Tu","We","Th","Fr","Sa"].forEach(function(d) {
    var span = document.createElement("span");
    span.className = "crm-cal__wd";
    span.textContent = d;
    wds.appendChild(span);
  });
  gridEl.appendChild(wds);

  // ── Day cells ──
  var days = document.createElement("div");
  days.className = "crm-cal__days";

  var firstDay = new Date(year, month, 1).getDay(); // 0=Sun
  var daysInMonth = new Date(year, month + 1, 0).getDate();

  // Empty cells before first day
  for (var i = 0; i < firstDay; i++) {
    var empty = document.createElement("div");
    empty.className = "crm-cal__day crm-cal__day--empty";
    days.appendChild(empty);
  }

  // Day cells
  for (var d = 1; d <= daysInMonth; d++) {
    var dateKey = year + "-" +
      String(month + 1).padStart(2,"0") + "-" +
      String(d).padStart(2,"0");

    var hasEvent = !!events[dateKey];
    var isToday  = dateKey === todayKey;

    var cell = document.createElement("div");
    cell.className = "crm-cal__day" +
      (isToday  ? " crm-cal__day--today"     : "") +
      (hasEvent ? " crm-cal__day--has-event"  : "");

    var num = document.createElement("span");
    num.textContent = d;
    cell.appendChild(num);

    if (hasEvent) {
      var dot = document.createElement("div");
      dot.className = "crm-cal__event-dot";
      cell.appendChild(dot);

      // Tooltip: list jurisdiction names on hover
      var evts = events[dateKey] || [];
      var jurisdictions = evts.map(function(e) { return e.jurisdiction; }).join(", ");
      cell.title = jurisdictions;
      cell.setAttribute("aria-label", "Auctions: " + jurisdictions);
      cell.setAttribute("role", "button");
      cell.setAttribute("tabindex", "0");
    }

    days.appendChild(cell);
  }

  gridEl.appendChild(days);

  // ── Empty state if no events in any visible date ──
  var hasAnyEvent = Object.keys(events).length > 0;
  var existingEmpty = gridEl.querySelector(".crm-cal__empty");
  if (existingEmpty) existingEmpty.remove();

  if (!hasAnyEvent) {
    var empty = document.createElement("div");
    empty.className = "crm-cal__empty";
    empty.textContent = "No CRM pipeline auctions found. Add properties to your pipeline to track their auction dates.";
    gridEl.appendChild(empty);
  }
}

})();
</script>


<%# ═══════════════════════════════════════════════════════
     ATLAS TOKENS — Shared Component Styles (Design System)
     Inyectado globalmente desde research.html.erb layout.
     Todas las vistas del módulo Research heredan estos estilos.
     Dependencias: variables :root OKLCH definidas en research.html.erb
     ═══════════════════════════════════════════════════════ %>
<style>
/* === Tabs row === */
.tabs-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 24px 0;
  border-bottom: 1px solid var(--border);
  background: var(--surface-1);
}
.tabs { display: flex; gap: 0; }
.tab {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 16px 14px;
  font-size: 13.5px;
  color: var(--ink-3);
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 160ms ease;
  font-weight: 500;
  cursor: pointer;
  background: none; border-top: none; border-left: none; border-right: none;
  text-decoration: none;
}
.tab svg { width: 15px; height: 15px; }
.tab:hover { color: var(--ink-1); }
.tab--active { color: var(--accent); border-bottom-color: var(--accent); }

.view-controls { display: flex; align-items: center; gap: 8px; padding-bottom: 8px; }
.view-toggle {
  display: flex;
  background: var(--surface-2);
  border-radius: 9px;
  padding: 3px;
  gap: 2px;
}
.view-btn {
  width: 30px; height: 28px;
  display: grid; place-items: center;
  border-radius: 7px;
  color: var(--ink-3);
  transition: all 160ms ease;
  cursor: pointer;
  background: none; border: none;
}
.view-btn svg { width: 15px; height: 15px; }
.view-btn:hover { color: var(--ink-1); }
.view-btn--active {
  background: var(--surface-1);
  color: var(--accent);
  box-shadow: var(--shadow-sm);
}
.ghost-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 12px;
  font-size: 13px;
  color: var(--ink-2);
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--surface-1);
  transition: all 160ms ease;
  text-decoration: none;
}
.ghost-btn svg { width: 14px; height: 14px; }
.ghost-btn:hover { background: var(--surface-2); color: var(--ink-1); }

/* === KPI tile === */
.kpi-tile {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--kpi-pad, 18px 20px);
  display: flex; flex-direction: column;
  gap: 8px;
  transition: all 200ms ease;
}
.kpi-tile:hover { border-color: var(--border-strong); }
.kpi-tile__head { display: flex; align-items: center; justify-content: space-between; }
.kpi-label {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.kpi-icon {
  width: 28px; height: 28px;
  display: grid; place-items: center;
  background: var(--accent-soft);
  color: var(--accent-strong);
  border-radius: 8px;
}
.kpi-icon svg { width: 14px; height: 14px; }
.kpi-value-row { display: flex; align-items: baseline; gap: 10px; }
.kpi-value {
  font-family: var(--font-display);
  font-size: 42px;
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--ink-1);
  line-height: 1;
}
.kpi-value--accent { color: var(--accent); }
.kpi-trend {
  display: inline-flex; align-items: center; gap: 3px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--success);
  background: var(--success-soft);
  padding: 3px 8px;
  border-radius: 6px;
}
.kpi-trend svg { width: 11px; height: 11px; }
.kpi-sub {
  font-size: 12.5px;
  color: var(--ink-3);
}

/* === County row === */
.county-row {
  width: 100%;
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px;
  border-radius: 10px;
  text-align: left;
  transition: all 160ms ease;
  border: 1px solid transparent;
  cursor: pointer;
  background: none;
  text-decoration: none;
  color: inherit;
}
.county-row--dense { padding: 8px 12px; }
.county-row:hover, .county-row--hover {
  background: var(--surface-2);
  border-color: var(--border);
}
.county-row__main { flex: 1; min-width: 0; }
.county-row__name {
  display: flex; align-items: center; gap: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--ink-1);
  margin-bottom: 3px;
}
.county-row__bullet {
  width: 8px; height: 8px;
  border-radius: 2px;
  flex-shrink: 0;
}
.county-row__meta {
  display: flex; gap: 12px;
  font-size: 11.5px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  letter-spacing: -0.01em;
}
.meta-prop i { font-style: normal; opacity: 0.7; }
.meta-next--urgent { color: var(--danger); font-weight: 600; }
.county-row__chev {
  color: var(--ink-4);
  display: grid; place-items: center;
  opacity: 0;
  transform: translateX(-4px);
  transition: all 160ms ease;
}
.county-row__chev svg { width: 14px; height: 14px; }
.county-row:hover .county-row__chev, .county-row--hover .county-row__chev {
  opacity: 1; transform: translateX(0);
}

/* === Auction date card === */
.auction-card {
  display: flex;
  gap: 14px;
  padding: 14px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  transition: all 200ms ease;
}
.auction-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow-md);
}
.auction-card--today {
  background: linear-gradient(135deg, oklch(0.48 0.11 158 / 0.08), oklch(0.48 0.11 158 / 0.02));
  border-color: var(--accent);
}
.auction-card__date {
  width: 52px;
  flex-shrink: 0;
  background: var(--accent-soft);
  border-radius: 9px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 6px 0;
}
.auction-card--today .auction-card__date {
  background: var(--accent);
}
.auction-card--today .auction-card__date * { color: white !important; }
.auction-card__month {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-strong);
  font-weight: 600;
}
.auction-card__day {
  font-family: var(--font-display);
  font-size: 26px;
  line-height: 1;
  color: var(--accent-strong);
  font-weight: 500;
}
.auction-card__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.auction-card__weekday {
  font-size: 12px;
  color: var(--ink-3);
  font-weight: 500;
}
.auction-card__counties { display: flex; flex-wrap: wrap; gap: 4px; }
.auction-card__chip {
  font-size: 11px;
  padding: 2px 7px;
  background: var(--surface-2);
  color: var(--ink-2);
  border-radius: 4px;
  font-weight: 500;
}
.auction-card__chip--more { background: var(--accent-soft); color: var(--accent-strong); }
.auction-card__when { font-size: 11px; font-family: var(--font-mono); color: var(--ink-3); margin-top: 2px; }
.auction-card__when--today { color: var(--danger); font-weight: 700; }
.auction-card__when--tomorrow { color: var(--accent); font-weight: 600; }

/* ── Clickable auction cards (a.auction-card) ── */
a.auction-card {
  text-decoration: none;
  color: inherit;
  cursor: pointer;
}
a.auction-card:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px oklch(0.18 0.015 158 / 0.12);
}

/* ── Clickable county chips inside cards ── */
a.auction-card__chip {
  text-decoration: none;
  color: var(--ink-2);
  cursor: pointer;
  transition: all 140ms ease;
  position: relative;
  z-index: 2;
}
a.auction-card__chip:hover {
  background: var(--accent-soft);
  color: var(--accent-strong);
  transform: scale(1.06);
  box-shadow: 0 1px 4px oklch(0.18 0.015 158 / 0.08);
}

/* === Agenda cards (Next Auctions panel — screenshot design) === */
.agenda-card {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: stretch;
  gap: 14px;
  padding: 14px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  transition: all 200ms ease;
  text-decoration: none !important;
  color: inherit;
  cursor: pointer;
}
.agenda-card:hover {
  border-color: oklch(0.68 0.12 280);
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}
.agenda-card--today {
  border-color: oklch(0.68 0.12 280);
  background: linear-gradient(135deg, oklch(0.68 0.12 280 / 0.06), oklch(0.68 0.12 280 / 0.02));
}
.agenda-card__date {
  width: 52px;
  min-width: 52px;
  max-width: 52px;
  flex-shrink: 0;
  flex-grow: 0;
  background: oklch(0.92 0.06 280);
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8px 4px;
  gap: 1px;
}
.agenda-card--today .agenda-card__date {
  background: oklch(0.68 0.12 280);
}
.agenda-card--today .agenda-card__date * { color: white !important; }
.agenda-card__month {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: oklch(0.50 0.14 280);
  font-weight: 700;
}
.agenda-card__day {
  font-family: var(--font-display);
  font-size: 26px;
  line-height: 1;
  color: oklch(0.45 0.14 280);
  font-weight: 500;
}
.agenda-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.agenda-card__weekday {
  font-size: 12.5px;
  color: var(--ink-1);
  font-weight: 600;
}
.agenda-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  align-items: center;
}
.agenda-card__tag {
  font-size: 11px;
  padding: 3px 8px;
  background: var(--surface-2);
  color: var(--ink-2);
  border-radius: 5px;
  font-weight: 500;
  text-decoration: none;
  transition: all 140ms ease;
  position: relative;
  z-index: 2;
  white-space: nowrap;
}
.agenda-card__tag:hover {
  background: oklch(0.92 0.06 280);
  color: oklch(0.45 0.14 280);
  transform: scale(1.04);
}
.agenda-card__extra {
  font-size: 10.5px;
  padding: 2px 7px;
  background: oklch(0.92 0.06 280);
  color: oklch(0.50 0.14 280);
  border-radius: 5px;
  font-weight: 700;
  font-family: var(--font-mono);
}
.agenda-card__when {
  font-size: 11.5px;
  color: var(--ink-3);
  margin-top: 2px;
}

/* === County Anchored Popover ===
   Light glass card. JS sets left/top dynamically.
   Stem arrow points toward the county centroid. */
.county-detail-panel {
  position: fixed;
  z-index: 200;
  width: 278px;
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: 14px;
  box-shadow: var(--shadow-md);
  padding: 0;
  overflow: visible; /* stem needs overflow visible */
  opacity: 0;
  pointer-events: none;
  transform: scale(0.92) translateY(10px);
  transform-origin: center bottom;
  transition:
    opacity 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
    transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform, opacity;
}
.county-detail-panel.visible {
  opacity: 1;
  transform: scale(1) translateY(0);
  pointer-events: auto;
}
/* Clip the inner content but not the stem pseudo-element */
.county-detail-panel > :not(.cdp__stem) { overflow: hidden; }
.county-detail-panel > *:first-child { border-radius: 14px 14px 0 0; }
.county-detail-panel > .cdp__cta { border-radius: 0 0 14px 14px; }

/* Stem arrow */
.county-detail-panel::after {
  content: '';
  position: absolute;
  width: 0; height: 0;
  left: var(--cdp-stem-x, 50%);
  transform: translateX(-50%);
  border: 10px solid transparent;
  pointer-events: none;
}
.county-detail-panel[data-stem="down"]::after {
  bottom: -20px;
  border-top-color: oklch(1 0 0);
  transform-origin: top center;
}
.county-detail-panel[data-stem="up"]::after {
  top: -20px;
  border-bottom-color: oklch(1 0 0);
}

/* Header */
.cdp__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
  padding: 14px 16px 11px;
  border-bottom: 1px solid var(--border);
  border-radius: 14px 14px 0 0;
  background: var(--surface-2);
}
.cdp__eyebrow {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  margin-bottom: 4px;
}
.cdp__name {
  font-family: var(--font-display);
  font-size: 19px;
  font-weight: 400;
  color: var(--ink-1);
  line-height: 1.1;
  letter-spacing: -0.015em;
}
.cdp__close {
  flex-shrink: 0;
  width: 22px; height: 22px;
  border-radius: 6px;
  border: none;
  background: var(--surface-2);
  color: var(--ink-3);
  cursor: pointer;
  display: grid;
  place-items: center;
  transition: background 140ms ease, color 140ms ease;
  margin-top: 1px;
}
.cdp__close:hover {
  background: var(--surface-3);
  color: var(--ink-1);
}

/* Stats */
.cdp__stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  padding: 13px 16px;
  border-bottom: 1px solid var(--border);
}
.cdp__stat {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-right: 10px;
}
.cdp__stat + .cdp__stat {
  padding-left: 12px;
  border-left: 1px solid var(--border);
}
.cdp__stat-label {
  font-family: var(--font-mono);
  font-size: 8.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 600;
}
.cdp__stat-value {
  font-family: var(--font-display);
  font-size: 21px;
  font-weight: 400;
  color: var(--ink-1);
  line-height: 1;
  letter-spacing: -0.02em;
}

/* CTA */
.cdp__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 13px 16px;
  background: oklch(0.48 0.13 158);
  color: #fff;
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  letter-spacing: 0.01em;
  border-radius: 0 0 14px 14px;
  transition: background 160ms ease, gap 160ms ease;
  cursor: pointer;
}
.cdp__cta:hover { background: oklch(0.40 0.15 158); gap: 12px; }
.cdp__cta svg { width: 14px; height: 14px; flex-shrink: 0; transition: transform 160ms ease; }
.cdp__cta:hover svg { transform: translateX(2px); }

/* === Heat legend === */
.heat-legend {
  display: flex; align-items: center; gap: 14px;
  padding: 8px 14px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: var(--shadow-sm);
  font-size: 11.5px;
  color: var(--ink-2);
}
.heat-legend__title {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.heat-legend__item { display: flex; align-items: center; gap: 5px; }
.heat-legend__item i {
  width: 12px; height: 12px;
  border-radius: 3px;
  display: inline-block;
  border: 1px solid var(--border);
  font-style: normal;
}

/* === Section title === */
.section-title {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}
.section-title__main {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  display: flex; align-items: center; gap: 8px;
}
.count-pill {
  background: var(--ink-1);
  color: white;
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 999px;
  font-weight: 600;
}
.count-pill--circle {
  width: 22px;
  height: 22px;
  padding: 0;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
}

/* === Next Auctions flat list (glass card matching Top Opportunities) === */
.agenda-list {
  display: flex;
  flex-direction: column;
  background: oklch(1 0 0);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid oklch(0.91 0.008 158 / 0.6);
  border-radius: var(--radius-lg);
  padding: 4px 14px;
  box-shadow: var(--shadow-md);
}
.agenda-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
  padding: 11px 0;
  border-bottom: 1px dashed var(--border);
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: opacity 150ms ease;
}
.agenda-row:hover { opacity: 0.75; }
.agenda-row:focus-visible {
  outline: 2px solid oklch(0.55 0.18 260);
  outline-offset: 2px;
  border-radius: 6px;
}
.agenda-row--last { border-bottom: none; }

.agenda-row__date {
  width: 48px;
  min-width: 48px;
  flex-shrink: 0;
  background: oklch(0.92 0.06 145);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 7px 4px;
  gap: 1px;
}
.agenda-row__date--today {
  background: oklch(0.35 0.12 145);
}
.agenda-row__month {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: oklch(0.38 0.10 145);
  font-weight: 700;
}
.agenda-row__date--today .agenda-row__month {
  color: oklch(0.88 0.06 145);
}
.agenda-row__day {
  font-size: 24px;
  line-height: 1;
  color: oklch(0.32 0.12 145);
  font-weight: 500;
}
.agenda-row__date--today .agenda-row__day {
  color: #fff;
}

.agenda-row__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.agenda-row__heading {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-1);
  display: flex;
  align-items: baseline;
  gap: 4px;
  flex-wrap: wrap;
}
.agenda-row__when {
  font-size: 11.5px;
  font-weight: 400;
  color: var(--ink-3);
}
.agenda-row__when--today {
  color: oklch(0.62 0.18 25);
  font-weight: 600;
}

.agenda-row__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  align-items: center;
}
.agenda-chip {
  font-size: 11px;
  padding: 2px 8px;
  background: transparent;
  border: 1.5px solid oklch(0.82 0.01 280);
  color: var(--ink-2);
  border-radius: 999px;
  font-weight: 500;
  text-decoration: none;
  white-space: nowrap;
  transition: border-color 140ms ease, color 140ms ease;
}
.agenda-chip:hover {
  border-color: oklch(0.55 0.14 280);
  color: oklch(0.40 0.14 280);
}
.agenda-chip--featured {
  background: oklch(0.55 0.18 260);
  border-color: oklch(0.55 0.18 260);
  color: #fff;
  font-weight: 600;
}
.agenda-chip--featured:hover {
  background: oklch(0.48 0.18 260);
  border-color: oklch(0.48 0.18 260);
  color: #fff;
}
.agenda-chip--extra {
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 700;
  border-style: dashed;
  color: var(--ink-3);
}

/* === Scroll utility === */
.scroll-y { overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--border-strong) transparent; }
.scroll-y::-webkit-scrollbar { width: 6px; }
.scroll-y::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

/* ═══════════════════════════════════════════
   ALT PANELS — Calendar & Table (Atlas themed)
   ═══════════════════════════════════════════ */
.atlas__alt-panel {
  padding: 1.5rem 2rem;
  background: var(--surface-1);
  min-height: 60vh;
}

/* ── Calendar override with Atlas tokens ── */
.atlas__alt-panel .r1-calendar-container {
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--surface-1);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

<%# ═══════════════════════════════════════════════════════
     ATLAS TOKENS — Shared Component Styles (Design System)
     Inyectado globalmente desde research.html.erb layout.
     Todas las vistas del módulo Research heredan estos estilos.
     Dependencias: variables :root OKLCH definidas en research.html.erb
     ═══════════════════════════════════════════════════════ %>
<style>
/* === Tabs row === */
.tabs-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 24px 0;
  border-bottom: 1px solid var(--border);
  background: var(--surface-1);
}
.tabs { display: flex; gap: 0; }
.tab {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 16px 14px;
  font-size: 13.5px;
  color: var(--ink-3);
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 160ms ease;
  font-weight: 500;
  cursor: pointer;
  background: none; border-top: none; border-left: none; border-right: none;
  text-decoration: none;
}
.tab svg { width: 15px; height: 15px; }
.tab:hover { color: var(--ink-1); }
.tab--active { color: var(--accent); border-bottom-color: var(--accent); }

.view-controls { display: flex; align-items: center; gap: 8px; padding-bottom: 8px; }
.view-toggle {
  display: flex;
  background: var(--surface-2);
  border-radius: 9px;
  padding: 3px;
  gap: 2px;
}
.view-btn {
  width: 30px; height: 28px;
  display: grid; place-items: center;
  border-radius: 7px;
  color: var(--ink-3);
  transition: all 160ms ease;
  cursor: pointer;
  background: none; border: none;
}
.view-btn svg { width: 15px; height: 15px; }
.view-btn:hover { color: var(--ink-1); }
.view-btn--active {
  background: var(--surface-1);
  color: var(--accent);
  box-shadow: var(--shadow-sm);
}
.ghost-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 12px;
  font-size: 13px;
  color: var(--ink-2);
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--surface-1);
  transition: all 160ms ease;
  text-decoration: none;
}
.ghost-btn svg { width: 14px; height: 14px; }
.ghost-btn:hover { background: var(--surface-2); color: var(--ink-1); }

/* === KPI tile === */
.kpi-tile {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--kpi-pad, 18px 20px);
  display: flex; flex-direction: column;
  gap: 8px;
  transition: all 200ms ease;
}
.kpi-tile:hover { border-color: var(--border-strong); }
.kpi-tile__head { display: flex; align-items: center; justify-content: space-between; }
.kpi-label {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.kpi-icon {
  width: 28px; height: 28px;
  display: grid; place-items: center;
  background: var(--accent-soft);
  color: var(--accent-strong);
  border-radius: 8px;
}
.kpi-icon svg { width: 14px; height: 14px; }
.kpi-value-row { display: flex; align-items: baseline; gap: 10px; }
.kpi-value {
  font-family: var(--font-display);
  font-size: 42px;
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--ink-1);
  line-height: 1;
}
.kpi-value--accent { color: var(--accent); }
.kpi-trend {
  display: inline-flex; align-items: center; gap: 3px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--success);
  background: var(--success-soft);
  padding: 3px 8px;
  border-radius: 6px;
}
.kpi-trend svg { width: 11px; height: 11px; }
.kpi-sub {
  font-size: 12.5px;
  color: var(--ink-3);
}

/* === County row === */
.county-row {
  width: 100%;
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px;
  border-radius: 10px;
  text-align: left;
  transition: all 160ms ease;
  border: 1px solid transparent;
  cursor: pointer;
  background: none;
  text-decoration: none;
  color: inherit;
}
.county-row--dense { padding: 8px 12px; }
.county-row:hover, .county-row--hover {
  background: var(--surface-2);
  border-color: var(--border);
}
.county-row__main { flex: 1; min-width: 0; }
.county-row__name {
  display: flex; align-items: center; gap: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--ink-1);
  margin-bottom: 3px;
}
.county-row__bullet {
  width: 8px; height: 8px;
  border-radius: 2px;
  flex-shrink: 0;
}
.county-row__meta {
  display: flex; gap: 12px;
  font-size: 11.5px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  letter-spacing: -0.01em;
}
.meta-prop i { font-style: normal; opacity: 0.7; }
.meta-next--urgent { color: var(--danger); font-weight: 600; }
.county-row__chev {
  color: var(--ink-4);
  display: grid; place-items: center;
  opacity: 0;
  transform: translateX(-4px);
  transition: all 160ms ease;
}
.county-row__chev svg { width: 14px; height: 14px; }
.county-row:hover .county-row__chev, .county-row--hover .county-row__chev {
  opacity: 1; transform: translateX(0);
}

/* === Auction date card === */
.auction-card {
  display: flex;
  gap: 14px;
  padding: 14px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  transition: all 200ms ease;
}
.auction-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow-md);
}
.auction-card--today {
  background: linear-gradient(135deg, oklch(0.48 0.11 158 / 0.08), oklch(0.48 0.11 158 / 0.02));
  border-color: var(--accent);
}
.auction-card__date {
  width: 52px;
  flex-shrink: 0;
  background: var(--accent-soft);
  border-radius: 9px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 6px 0;
}
.auction-card--today .auction-card__date {
  background: var(--accent);
}
.auction-card--today .auction-card__date * { color: white !important; }
.auction-card__month {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-strong);
  font-weight: 600;
}
.auction-card__day {
  font-family: var(--font-display);
  font-size: 26px;
  line-height: 1;
  color: var(--accent-strong);
  font-weight: 500;
}
.auction-card__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.auction-card__weekday {
  font-size: 12px;
  color: var(--ink-3);
  font-weight: 500;
}
.auction-card__counties { display: flex; flex-wrap: wrap; gap: 4px; }
.auction-card__chip {
  font-size: 11px;
  padding: 2px 7px;
  background: var(--surface-2);
  color: var(--ink-2);
  border-radius: 4px;
  font-weight: 500;
}
.auction-card__chip--more { background: var(--accent-soft); color: var(--accent-strong); }
.auction-card__when { font-size: 11px; font-family: var(--font-mono); color: var(--ink-3); margin-top: 2px; }
.auction-card__when--today { color: var(--danger); font-weight: 700; }
.auction-card__when--tomorrow { color: var(--accent); font-weight: 600; }

/* ── Clickable auction cards (a.auction-card) ── */
a.auction-card {
  text-decoration: none;
  color: inherit;
  cursor: pointer;
}
a.auction-card:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px oklch(0.18 0.015 158 / 0.12);
}

/* ── Clickable county chips inside cards ── */
a.auction-card__chip {
  text-decoration: none;
  color: var(--ink-2);
  cursor: pointer;
  transition: all 140ms ease;
  position: relative;
  z-index: 2;
}
a.auction-card__chip:hover {
  background: var(--accent-soft);
  color: var(--accent-strong);
  transform: scale(1.06);
  box-shadow: 0 1px 4px oklch(0.18 0.015 158 / 0.08);
}

/* === Tooltip === */
.county-tooltip {
  position: fixed;
  z-index: 100;
  pointer-events: none;
  background: var(--surface-1);
  border: 1px solid var(--border-strong);
  border-radius: 12px;
  padding: 14px;
  min-width: 220px;
  box-shadow: var(--shadow-lg);
  transform: translate(12px, 12px);
  animation: tooltipIn 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  display: none;
}
.county-tooltip.visible { display: block; }
@keyframes tooltipIn {
  from { opacity: 0; transform: translate(8px, 8px); }
  to   { opacity: 1; transform: translate(12px, 12px); }
}
.county-tooltip__name {
  font-family: var(--font-display);
  font-size: 18px;
  margin-bottom: 10px;
  color: var(--ink-1);
}
.county-tooltip__suffix { color: var(--ink-3); font-size: 12px; font-family: var(--font-sans); }
.county-tooltip__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 14px;
  padding-bottom: 10px;
  margin-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.county-tooltip__grid > div { display: flex; flex-direction: column; gap: 1px; }
.county-tooltip__grid .t-full { grid-column: 1 / -1; }
.county-tooltip__grid .t-label {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.county-tooltip__grid strong {
  font-size: 16px;
  font-weight: 500;
  color: var(--ink-1);
  font-family: var(--font-display);
}
.county-tooltip__cta {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px;
  color: var(--accent);
  font-weight: 600;
}
.county-tooltip__cta svg { width: 12px; height: 12px; }

/* === Heat legend === */
.heat-legend {
  display: flex; align-items: center; gap: 14px;
  padding: 8px 14px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 999px;
  box-shadow: var(--shadow-sm);
  font-size: 11.5px;
  color: var(--ink-2);
}
.heat-legend__title {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.heat-legend__item { display: flex; align-items: center; gap: 5px; }
.heat-legend__item i {
  width: 12px; height: 12px;
  border-radius: 3px;
  display: inline-block;
  border: 1px solid var(--border);
  font-style: normal;
}

/* === Section title === */
.section-title {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}
.section-title__main {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  display: flex; align-items: center; gap: 8px;
}
.count-pill {
  background: var(--ink-1);
  color: white;
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 999px;
  font-weight: 600;
}

/* === Scroll utility === */
.scroll-y { overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--border-strong) transparent; }
.scroll-y::-webkit-scrollbar { width: 6px; }
.scroll-y::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

/* ═══════════════════════════════════════════
   ALT PANELS — Calendar & Table (Atlas themed)
   ═══════════════════════════════════════════ */
.atlas__alt-panel {
  padding: 1.5rem 2rem;
  background: var(--surface-1);
  min-height: 60vh;
}

/* ── Calendar override with Atlas tokens ── */
.atlas__alt-panel .r1-calendar-container {
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--surface-1);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.atlas__alt-panel .r1-calendar-header {
  background: var(--surface-2) !important;
  border-bottom: 1px solid var(--border) !important;
  font-family: var(--font-sans);
}
.atlas__alt-panel .r1-cal-month-title {
  font-family: var(--font-display) !important;
  color: var(--ink-1) !important;
}
.atlas__alt-panel .r1-cal-today-btn {
  background: var(--accent) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 6px !important;
  font-family: var(--font-sans) !important;
  font-weight: 600 !important;
  font-size: 0.75rem !important;
}
.atlas__alt-panel .r1-cal-nav-btn {
  color: var(--ink-2) !important;
  border-color: var(--border) !important;
}
.atlas__alt-panel .r1-cal-cell {
  border-color: var(--border) !important;
  font-family: var(--font-sans) !important;
}
.atlas__alt-panel .r1-cal-cell.today {
  background: oklch(0.97 0.02 158) !important;
  border-color: var(--accent) !important;
}
.atlas__alt-panel .r1-cal-day-header {
  font-family: var(--font-sans) !important;
  color: var(--ink-3) !important;
  font-weight: 600 !important;
}
.atlas__alt-panel .r1-cal-event {
  background: var(--accent) !important;
  color: #fff !important;
  border-radius: 4px !important;
}
.atlas__alt-panel .r1-cal-legend-dot {
  background: var(--accent) !important;
}

/* ── Table override with Atlas tokens ── */
.atlas__alt-panel .r1-table-container {
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--surface-1);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.atlas__alt-panel .r1-table-toolbar {
  background: var(--surface-2) !important;
  border-bottom: 1px solid var(--border) !important;
  padding: 0.75rem 1rem !important;
  font-family: var(--font-sans) !important;
  font-size: 0.8rem !important;
  color: var(--ink-2) !important;
}
.atlas__alt-panel #r1-auction-table {
  font-family: var(--font-sans) !important;
}
.atlas__alt-panel #r1-auction-thead th {
  background: var(--surface-2) !important;
  border-color: var(--border) !important;
  color: var(--ink-3) !important;
  font-size: 0.75rem !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.04em !important;
}
.atlas__alt-panel #r1-auction-tbody tr {
  border-color: var(--border) !important;
  transition: background 120ms ease;
}
.atlas__alt-panel #r1-auction-tbody tr:hover {
  background: oklch(0.97 0.015 158) !important;
}
.atlas__alt-panel .r1-td-jurisdiction {
  font-weight: 600 !important;
  color: var(--ink-1) !important;
}
.atlas__alt-panel .r1-td-date {
  color: var(--accent) !important;
  font-weight: 600 !important;
}
.atlas__alt-panel .r1-parcels-count {
  font-weight: 700 !important;
  color: var(--accent) !important;
  font-family: var(--font-mono) !important;
}
.atlas__alt-panel .r1-pagination-wrap {
  border-top: 1px solid var(--border) !important;
  font-family: var(--font-sans) !important;
}
.atlas__alt-panel .r1-page-btn {
  border-color: var(--border) !important;
  color: var(--ink-2) !important;
  border-radius: 6px !important;
}
.atlas__alt-panel .r1-page-btn.active {
  background: var(--accent) !important;
  color: #fff !important;
  border-color: var(--accent) !important;
}
.atlas__alt-panel .r1-page-btn:hover:not(.disabled):not(.active) {
  background: var(--surface-2) !important;
  border-color: var(--accent-soft) !important;
}
.atlas__alt-panel .r1-td-badge {
  background: var(--accent-soft) !important;
  color: var(--accent) !important;
  border-radius: 4px !important;
  font-size: 0.7rem !important;
  font-weight: 600 !important;
}

/* === Atlas Badge System (shared across modules) === */
.atlas-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 8px;
  border-radius: var(--radius-sm);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
}
.atlas-badge--success { background: var(--success-soft); color: var(--success); }
.atlas-badge--warning { background: var(--warning-soft); color: var(--warning); }
.atlas-badge--danger  { background: var(--danger-soft);  color: var(--danger); }
.atlas-badge--info    { background: var(--accent-soft);  color: var(--accent); }
.atlas-badge--neutral { background: var(--surface-2);    color: var(--ink-3); }

/* === Atlas Data Table (shared across modules) === */
.atlas-table-wrap {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.atlas-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  font-family: var(--font-sans);
}
.atlas-table th {
  background: var(--surface-2);
  padding: 10px 14px;
  text-align: left;
  font-weight: 600;
  font-size: 11px;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-family: var(--font-mono);
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
}
.atlas-table td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--ink-1);
  vertical-align: middle;
}
.atlas-table tr:last-child td { border-bottom: none; }
.atlas-table tr:hover td { background: var(--surface-2); }
.atlas-table .cell-link {
  color: var(--accent);
  font-weight: 500;
  text-decoration: none;
  cursor: pointer;
}
.atlas-table .cell-link:hover { text-decoration: underline; }
.atlas-table-empty {
  text-align: center;
  padding: 3rem 1rem;
  color: var(--ink-3);
  font-size: 13.5px;
}

/* === Atlas Section Card (shared across modules) === */
.atlas-section {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px 24px;
  margin-bottom: 12px;
  transition: all 160ms ease;
  box-shadow: var(--shadow-sm);
}
.atlas-section:hover {
  border-color: var(--border-strong);
}
.atlas-section__title {
  font-size: 13px;
  font-weight: 700;
  color: var(--ink-1);
  margin: 0 0 14px 0;
  display: flex;
  align-items: center;
  gap: 8px;
  letter-spacing: -0.01em;
}
.atlas-section__title .icon {
  font-size: 16px;
}

/* === Atlas Form Elements (shared across modules) === */
.atlas-input {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 13px;
  color: var(--ink-1);
  background: var(--surface-1);
  transition: border-color 160ms ease, box-shadow 160ms ease;
  outline: none;
}
.atlas-input:focus {
  border-color: var(--accent);
  box-shadow: var(--shadow-glow);
}
.atlas-input::placeholder { color: var(--ink-4); }

.atlas-select {
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 13px;
  color: var(--ink-1);
  background: var(--surface-1);
  outline: none;
  cursor: pointer;
}
.atlas-select:focus {
  border-color: var(--accent);
  box-shadow: var(--shadow-glow);
}

.atlas-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-bottom: 6px;
  font-weight: 600;
}

/* === Atlas Button variants === */
.atlas-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 160ms ease;
  text-decoration: none;
}
.atlas-btn--primary {
  background: var(--accent);
  color: white;
}
.atlas-btn--primary:hover {
  opacity: 0.9;
  box-shadow: var(--shadow-md);
}
.atlas-btn--ghost {
  background: var(--surface-1);
  color: var(--ink-2);
  border: 1px solid var(--border);
}
.atlas-btn--ghost:hover {
  background: var(--surface-2);
  color: var(--ink-1);
}
.atlas-btn--cta {
  background: #E67E22;
  color: white;
  font-weight: 700;
}
.atlas-btn--cta:hover {
  opacity: 0.9;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(230, 126, 34, 0.3);
}
.atlas-btn--sm {
  padding: 5px 10px;
  font-size: 12px;
  border-radius: var(--radius-sm);
}

/* === Atlas Data Row (key-value pair) === */
.atlas-data-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid oklch(0.91 0.008 158 / 0.6);
}
.atlas-data-row:last-child { border-bottom: none; }
.atlas-data-row__label {
  font-size: 12.5px;
  color: var(--ink-3);
  font-weight: 500;
}
.atlas-data-row__value {

<%# ── Sección geográfica del condado (Atlas) ────────────────────── %>
<%# Muestra condados limítrofes y links externos.                 %>

<div class="fc-section" style="margin-top: 1rem;">
  <%# ── Condados limítrofes ──── %>
  <% if @county.borders.present? %>
    <div style="background: var(--surface-2); border: 1px solid var(--border);
                border-radius: var(--radius-lg); padding: 1rem 1.2rem; margin-bottom: 1rem;">
      <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem;
                  font-weight: 600;">
        🗺️ Limita con
      </div>
      <div style="color: var(--ink-1); font-size: 13.5px; line-height: 1.5;">
        <%= @county.borders %>
      </div>
    </div>
  <% end %>

  <%# ── Links externos ──── %>
  <% links = @county.external_links %>
  <% if links.any? %>
    <div class="fc-ext-links">
      <% links.each do |link| %>
        <a href="<%= link[:url] %>" target="_blank" rel="noopener" class="fc-ext-link">
          🔗 <%= link[:label] %>
        </a>
      <% end %>
    </div>
  <% end %>
</div>

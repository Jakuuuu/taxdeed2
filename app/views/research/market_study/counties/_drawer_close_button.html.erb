<%# ═══════════════════════════════════════════════════════════════════════════
     Partial: _drawer_close_button — Botón sticky para cerrar el drawer (Atlas)
     Posición: sticky top, con backdrop-filter blur
    ═══════════════════════════════════════════════════════════════════════════ %>

<button onclick="if(window.closeCountyDrawer) closeCountyDrawer();"
        style="position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:center;
               width:100%;padding:10px 24px;background:oklch(0.97 0.005 280 / 0.97);border:none;
               border-bottom:1px solid var(--border);cursor:pointer;backdrop-filter:blur(8px);"
        aria-label="Cerrar ficha"
        id="ms-drawer-close-btn">
  <span style="display:flex;align-items:center;gap:8px;color:var(--ink-1);font-size:13px;
               font-family:var(--font-sans);font-weight:600;">
    <span style="font-size:16px;line-height:1;">✕</span>
    Cerrar ficha
  </span>
</button>

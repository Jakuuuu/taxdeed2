<%# ═══════════════════════════════════════════════════════════════════════════
     Partial 3/10: _county_kpi_cards — 6 KPIs financieros/demográficos (Atlas)
     Variables: county
    ═══════════════════════════════════════════════════════════════════════════ %>

<div class="fc-kpi-grid">
  <%# ── KPI 1: Precio Medio del Hogar ───────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid var(--accent);">
    <div class="fc-kpi-icon">🏠</div>
    <p class="fc-kpi-value"><%= county.format_currency(county.median_home_price) %></p>
    <div class="fc-kpi-label">Precio Medio del Hogar</div>
  </div>

  <%# ── KPI 2: Ingreso Medio ────────────────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid var(--success);">
    <div class="fc-kpi-icon">💰</div>
    <p class="fc-kpi-value"><%= county.format_currency(county.median_household_income) %></p>
    <div class="fc-kpi-label">Ingreso Medio del Hogar</div>
  </div>

  <%# ── KPI 3: Población ────────────────────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid oklch(0.55 0.18 300);">
    <div class="fc-kpi-icon">👥</div>
    <p class="fc-kpi-value"><%= county.format_population %></p>
    <div class="fc-kpi-label">Población</div>
  </div>

  <%# ── KPI 4: Crecimiento ──────────────────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid var(--warning);">
    <div class="fc-kpi-icon">📈</div>
    <p class="fc-kpi-value"><%= county.format_percentage(county.annual_growth_rate) %></p>
    <div class="fc-kpi-label">Crecimiento Anual</div>
  </div>

  <%# ── KPI 5: Presupuesto Público ──────────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid var(--accent-strong);">
    <div class="fc-kpi-icon">🏛️</div>
    <p class="fc-kpi-value"><%= county.format_large_currency(county.annual_budget) %></p>
    <div class="fc-kpi-label">Presupuesto Público</div>
  </div>

  <%# ── KPI 6: Días en Mercado ──────────────────────────────────────────── %>
  <div class="fc-kpi-card" style="border-top: 3px solid var(--danger);">
    <div class="fc-kpi-icon">⏱️</div>
    <p class="fc-kpi-value"><%= county.days_on_market || "—" %></p>
    <div class="fc-kpi-label">Días en Mercado</div>
  </div>
</div>

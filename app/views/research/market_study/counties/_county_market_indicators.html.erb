<%# ── Indicadores de mercado del condado (Atlas) ─────────────────── %>
<%# Muestra métricas demográficas y financieras en grid de 2 col.  %>

<div class="fc-section" style="margin-top: 1rem;">
  <h3 class="fc-section-title">
    <span class="icon">📊</span> Indicadores de mercado
  </h3>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0;">

    <%# ── Fila: Población ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Población
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.format_population %>
    </div>

    <%# ── Fila: PBI ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      PBI
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.format_large_currency(@county.gdp) %>
    </div>

    <%# ── Fila: Ingreso Medio ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Ingreso medio
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.format_currency(@county.median_household_income) %>
    </div>

    <%# ── Fila: Empleo / Desempleo ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Empleo / Desempleo
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.format_percentage(@county.employment_rate) %> / <%= @county.format_percentage(@county.unemployment_rate) %>
    </div>

    <%# ── Fila: Median Home Price ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Median home price
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border); color: var(--success); font-weight: 700;">
      <%= @county.format_currency(@county.median_home_price) %>
    </div>

    <%# ── Fila: Precio por Sqft ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Precio por sqft
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.format_currency(@county.price_per_sqft) %>
    </div>

    <%# ── Fila: Listados Activos ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Listados activos
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.active_listings.present? ? number_with_delimiter(@county.active_listings) : "—" %>
    </div>

    <%# ── Fila: Days on Market ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Days on market
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      <%= @county.days_on_market.present? ? "#{@county.days_on_market} días" : "—" %>
    </div>

    <%# ── Fila: Crecimiento Anual ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border);">
      Crecimiento anual
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0; border-bottom: 1px solid var(--border); color: var(--success); font-weight: 700;">
      <%= @county.format_percentage(@county.annual_growth_rate) %>
    </div>

    <%# ── Fila: Presupuesto Anual ──── %>
    <div class="fc-data-label" style="padding: 0.6rem 0;">
      Presupuesto anual
    </div>
    <div class="fc-data-value" style="padding: 0.6rem 0;">
      <%= @county.format_large_currency(@county.annual_budget) %>
    </div>

  </div>

  <%# ── Indicadores cualitativos (Criminalidad, Inundación) ──── %>
  <% if @county.crime_rating.present? || @county.flood_risk.present? %>
    <div style="display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.2rem;">
      <% if @county.crime_rating.present? %>
        <div style="background: var(--surface-2); border: 1px solid var(--border);
                    border-radius: var(--radius-lg); padding: 0.6rem 1rem; flex: 1; min-width: 200px;">
          <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                      text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">
            Criminalidad
          </div>
          <div style="color: var(--ink-1); font-size: 13.5px; font-weight: 600; margin-top: 0.2rem;">
            🛡️ <%= @county.crime_rating %>
          </div>
        </div>
      <% end %>
      <% if @county.flood_risk.present? %>
        <div style="background: var(--surface-2); border: 1px solid var(--border);
                    border-radius: var(--radius-lg); padding: 0.6rem 1rem; flex: 1; min-width: 200px;">
          <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                      text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">
            Riesgo de inundación
          </div>
          <div style="color: var(--ink-1); font-size: 13.5px; font-weight: 600; margin-top: 0.2rem;">
            🌊 <%= @county.flood_risk %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

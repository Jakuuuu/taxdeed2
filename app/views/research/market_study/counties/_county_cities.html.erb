<%# ── Ciudades principales del condado (Atlas) ──────────────────── %>
<%# Muestra las 3 ciudades top como pill tags con hover effects.  %>

<% cities = @county.cities_list %>
<% if cities.any? %>
  <div class="fc-section" style="margin-top: 1rem;">
    <h3 class="fc-section-title">
      <span class="icon">🏙️</span> Ciudades principales
    </h3>

    <div style="display: flex; flex-wrap: wrap; gap: 0.6rem;">
      <% cities.each do |city| %>
      <span style="display: inline-flex; align-items: center; gap: 0.4rem;
                     background: var(--surface-2); border: 1px solid var(--border);
                     border-radius: 999px; padding: 6px 14px; font-size: 13px;
                     color: var(--ink-2); font-weight: 500; transition: all 160ms ease;
                     cursor: default;">
          📍 <%= city %>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Ciudades principales del condado ──────────────────────────────── %>
<%# Muestra las 3 ciudades top como pill tags con hover effects.        %>
<%# Paleta: Navy #1E3A5F | Gold #C9A84C | Off-white #F5F7FA             %>

<% cities = @county.cities_list %>
<% if cities.any? %>
  <div class="fc-section" style="margin-top: 1rem;">
    <h3 class="fc-section-title">
      <span class="icon">🏙️</span> Ciudades principales
    </h3>

    <div style="display: flex; flex-wrap: wrap; gap: 0.6rem;">
      <% cities.each do |city| %>
      <span style="display: inline-flex; align-items: center; gap: 0.4rem;
                     background: rgba(30, 58, 95, 0.06); border: 1.5px solid #E2E8F0;
                     border-radius: 20px; padding: 0.4rem 1rem; font-size: 0.85rem;
                     color: #1E3A5F; font-weight: 500; transition: all 0.2s ease;
                     cursor: default;"
              onmouseover="this.style.background='#1E3A5F'; this.style.color='#fff'; this.style.borderColor='#1E3A5F'"
              onmouseout="this.style.background='rgba(30, 58, 95, 0.06)'; this.style.color='#1E3A5F'; this.style.borderColor='#E2E8F0'">
          📍 <%= city %>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════════════
     Partial 1/10: _county_styles — Atlas Design Tokens + CSS Base
     Migrated from Navy/Gold hex → Atlas OKLCH tokens
     Regla: CSS inline estricto — prohibido content_for :head
    ═══════════════════════════════════════════════════════════════════════════ %>

<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     FICHA DE CONDADO — Atlas Design System
     ═══════════════════════════════════════════════════════════════════════════ */

  /* ── Container Principal ────────────────────────────────────────────────── */
  .fc-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 32px 64px;
    background: var(--surface-0);
    min-height: 100vh;
    font-family: var(--font-sans);
    color: var(--ink-1);
  }

  /* ── Section Module (reusable) ──────────────────────────────────────────── */
  .fc-section {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 16px;
    transition: all 160ms ease;
    box-shadow: var(--shadow-sm);
  }

  .fc-section:hover {
    border-color: var(--border-strong);
  }

  .fc-section-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink-1);
    margin: 0 0 16px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: -0.01em;
  }

  .fc-section-title .icon {
    font-size: 18px;
  }

  /* ── Badges ─────────────────────────────────────────────────────────────── */
  .fc-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fc-badge-blue {
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .fc-badge-green {
    background: var(--success-soft);
    color: var(--success);
  }

  .fc-badge-orange {
    background: var(--warning-soft);
    color: var(--warning);
  }

  .fc-badge-red {
    background: var(--danger-soft);
    color: var(--danger);
  }

  /* ── Divider ────────────────────────────────────────────────────────────── */
  .fc-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 16px 0;
  }

  /* ── Back Link ──────────────────────────────────────────────────────────── */
  .fc-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink-3);
    font-size: 13px;
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 160ms ease;
  }

  .fc-back-link:hover {
    color: var(--accent);
  }

  /* ── Data Row (key-value pair) ──────────────────────────────────────────── */
  .fc-data-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid oklch(0.91 0.01 280 / 0.6);
  }

  .fc-data-row:last-child {
    border-bottom: none;
  }

  .fc-data-label {
    font-size: 12.5px;
    color: var(--ink-3);
    font-weight: 500;
  }

  .fc-data-value {
    font-size: 13.5px;
    color: var(--ink-1);
    font-weight: 600;
    text-align: right;
  }

  /* ── CTA Button (Regla Naranja — Immutable #E67E22) ────────────────────── */
  .fc-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    background: #E67E22;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    text-decoration: none;
    transition: all 160ms ease;
    letter-spacing: 0.02em;
    font-family: var(--font-sans);
  }

  .fc-cta-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(230, 126, 34, 0.3);
  }

  /* ── KPI Cards ──────────────────────────────────────────────────────────── */
  .fc-kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }

  .fc-kpi-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px 20px;
    border-top: 3px solid var(--accent);
    transition: all 160ms ease;
  }

  .fc-kpi-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }

  .fc-kpi-icon {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .fc-kpi-value {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--ink-1);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
    line-height: 1;
  }

  .fc-kpi-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── External Links ─────────────────────────────────────────────────────── */
  .fc-ext-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .fc-ext-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: all 160ms ease;
  }

  .fc-ext-link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .fc-container {
      padding: 16px;
    }
    .fc-kpi-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

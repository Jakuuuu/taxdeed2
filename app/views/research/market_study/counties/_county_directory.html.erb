<%# ── Directorio institucional del condado (Atlas) ──────────────── %>
<%# Muestra los 4 contactos fijos: Planning & Zoning, Building,   %>
<%# Clerk Office, Tax Collector. Cada uno puede ser email/tel.    %>

<% contacts = @county.institutional_contacts %>
<% if contacts.any? %>
  <div class="fc-section" style="margin-top: 1rem;">
    <h3 class="fc-section-title">
      <span class="icon">🏛️</span> Directorio institucional
    </h3>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
      <% contacts.each do |c| %>
        <div style="background: var(--surface-2); border: 1px solid var(--border);
                    border-radius: var(--radius-lg); padding: 1rem 1.2rem;">
          <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                      text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem;
                      font-weight: 600;">
            <%= c[:dept] %>
          </div>
          <div style="color: var(--ink-1); font-size: 13.5px;">
            <% contact_val = c[:contact] %>
            <% if contact_val.include?("@") %>
              <a href="mailto:<%= contact_val %>"
                 style="color: var(--accent); text-decoration: none; transition: opacity 160ms ease;
                        font-weight: 500;"
                 onmouseover="this.style.opacity='0.8'"
                 onmouseout="this.style.opacity='1'">
                📧 <%= contact_val %>
              </a>
            <% elsif contact_val.match?(/\(\d{3}\)/) %>
              <a href="tel:<%= contact_val.gsub(/[^\d+]/, '') %>"
                 style="color: var(--accent); text-decoration: none; transition: opacity 160ms ease;
                        font-weight: 500;"
                 onmouseover="this.style.opacity='0.8'"
                 onmouseout="this.style.opacity='1'">
                📞 <%= contact_val %>
              </a>
            <% else %>
              <%= contact_val %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

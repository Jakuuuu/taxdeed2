<%# ── Header de la ficha de condado (Atlas Design System) ──────── %>
<%# Título, badges de estado/modalidad, y quick-stats.            %>

<div style="margin-bottom: 1.5rem;">
  <%# ── Título principal ──── %>
  <h1 style="font-family: var(--font-display); color: var(--ink-1); font-size: 28px;
             font-weight: 400; margin: 0 0 0.5rem 0; letter-spacing: -0.02em;">
    <%= @county.county %>
    <span style="color: var(--ink-3); font-weight: 400;">, <%= @county.state %></span>
  </h1>

  <%# ── Badges ──── %>
  <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
    <%# Badge: Modalidad %>
    <% if @county.modalidad.present? %>
      <span style="display: inline-flex; align-items: center; gap: 0.3rem;
                   background: var(--accent-soft); border: 1px solid oklch(0.65 0.18 255 / 0.15);
                   border-radius: var(--radius-sm); padding: 3px 10px; font-size: 11px;
                   color: var(--accent-strong); font-weight: 600; text-transform: uppercase;
                   letter-spacing: 0.04em; font-family: var(--font-mono);">
        💻 <%= @county.modalidad %>
      </span>
    <% end %>

    <%# Badge: Estado del mercado %>
    <% if @county.market_status.present? %>
      <% is_active = @county.market_status.downcase.include?("activo") %>
      <span style="display: inline-flex; align-items: center; gap: 0.3rem;
                   background: var(<%= is_active ? '--success-soft' : '--danger-soft' %>);
                   border: 1px solid <%= is_active ? 'oklch(0.62 0.16 155 / 0.2)' : 'oklch(0.58 0.22 25 / 0.2)' %>;
                   border-radius: var(--radius-sm); padding: 3px 10px; font-size: 11px;
                   color: var(<%= is_active ? '--success' : '--danger' %>);
                   font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
                   font-family: var(--font-mono);">
        <span style="width: 6px; height: 6px; border-radius: 50%;
                     background: var(<%= is_active ? '--success' : '--danger' %>);
                     display: inline-block;"></span>
        Mercado <%= @county.market_status %>
      </span>
    <% end %>
  </div>

  <%# ── Quick Stats (3 tarjetas horizontales) ──── %>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem;">
    <%# Median Home %>
    <div style="background: var(--surface-1); border: 1px solid var(--border);
                border-radius: var(--radius-lg); padding: 0.8rem 1rem; text-align: center;
                border-top: 3px solid var(--success);">
      <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem;
                  font-weight: 600;">Median Home</div>
      <div style="color: var(--ink-1); font-family: var(--font-display); font-size: 22px;
                  font-weight: 400;">
        <%= @county.format_currency(@county.median_home_price) %>
      </div>
    </div>

    <%# Población %>
    <div style="background: var(--surface-1); border: 1px solid var(--border);
                border-radius: var(--radius-lg); padding: 0.8rem 1rem; text-align: center;
                border-top: 3px solid var(--accent);">
      <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem;
                  font-weight: 600;">Población</div>
      <div style="color: var(--ink-1); font-family: var(--font-display); font-size: 22px;
                  font-weight: 400;">
        <%= @county.format_population %>
      </div>
    </div>

    <%# Crecimiento %>
    <div style="background: var(--surface-1); border: 1px solid var(--border);
                border-radius: var(--radius-lg); padding: 0.8rem 1rem; text-align: center;
                border-top: 3px solid var(--warning);">
      <div style="font-family: var(--font-mono); color: var(--ink-3); font-size: 10.5px;
                  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem;
                  font-weight: 600;">Crecimiento</div>
      <div style="color: var(--success); font-family: var(--font-display); font-size: 22px;
                  font-weight: 400;">
        <%= @county.format_percentage(@county.annual_growth_rate) %>
      </div>
    </div>
  </div>

  <%# ── CTA: Ver propiedades en este condado ──── %>
  <div style="margin-top: 1.2rem; display: flex; gap: 0.75rem; align-items: center;">
    <a href="<%= research_parcels_path(county: @county.county, state: @county.state) %>"
       data-turbo="false"
       onclick="event.stopPropagation(); window.location.href = this.href; return false;"
       style="display: inline-flex; align-items: center; gap: 8px;
              padding: 12px 28px; background: var(--accent); color: #fff;
              font-family: var(--font-sans); font-size: 14px; font-weight: 700;
              border: none; border-radius: var(--radius-md); cursor: pointer;
              text-decoration: none; transition: all 160ms ease; letter-spacing: 0.02em;
              box-shadow: var(--shadow-md);"
       onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)';"
       onmouseout="this.style.opacity='1'; this.style.transform='none';">
      🔍 Ver propiedades
      <span style="background: rgba(255,255,255,0.2); padding: 2px 10px; border-radius: 12px;
                   font-size: 0.8rem; font-weight: 800;">
        <%= @total_properties %>
      </span>
    </a>
  </div>
</div>

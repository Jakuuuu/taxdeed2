<%# ── Lion Tip — Nota del analista sobre el condado (Atlas) ──────── %>
<%# Muestra el campo "ACERCA DE" del Sheet como insight contextual. %>

<% if @county.about.present? %>
  <div style="background: var(--surface-2);
              border: 1px solid var(--border); border-left: 3px solid var(--accent);
              border-radius: var(--radius-lg); padding: 1.2rem 1.4rem; margin-top: 1rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.6rem;">
      <span style="font-size: 1.2rem;">🦁</span>
      <span style="color: var(--accent-strong); font-family: var(--font-mono); font-size: 10.5px;
                   font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;">
        Acerca del condado
      </span>
    </div>
    <p style="color: var(--ink-2); font-size: 13.5px; line-height: 1.6; margin: 0;">
      <%= @county.about %>
    </p>
  </div>
<% end %>

<%# ══════════════════════════════════════════════════════════════════════
     RAMA 6 — Clear-to-Bid Catalog
     Pre-qualified opportunities, hand-curated by analysts.
     Branching:
       - @upgrade_required == true  → renderiza @parcels_teaser (blur + upsell)
       - @upgrade_required == false → renderiza @parcels_full   (datos íntegros)
     SEO/Layout: usa layout 'research' (header global ya inyectado).
     ══════════════════════════════════════════════════════════════════════ %>

<% content_for :title, "Clear-to-Bid Catalog — TaxDeed Lion" %>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ── Header ────────────────────────────────────────────────────────── %>
  <header class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900">
        Clear-to-Bid Catalog
      </h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200">
        Premier-only
      </span>
    </div>
    <p class="text-gray-500 text-sm md:text-base">
      Pre-qualified opportunities, hand-curated by our analysts.
    </p>
  </header>

  <%# ── Filter pills (only when user has access) ──────────────────────── %>
  <% unless @upgrade_required %>
    <nav class="flex flex-wrap gap-2 mb-6" aria-label="Grade filters"
         data-controller="grade-filter">
      <% [
            ['all',        'All',        'bg-gray-100 text-gray-800'],
            ['optimo',     'Óptimo',     'bg-green-100 text-green-800'],
            ['viable',     'Viable',     'bg-yellow-100 text-yellow-800']
         ].each do |(value, label, classes)| %>
        <button type="button"
                data-grade-filter-target="pill"
                data-grade-value="<%= value %>"
                class="<%= classes %> inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold transition hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-gray-300">
          <%= label %>
        </button>
      <% end %>
    </nav>
  <% end %>

  <%# ── Card Grid ─────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    <% if @upgrade_required %>
      <% Array(@parcels_teaser).each do |teaser| %>
        <%= render partial: "research/clear_to_bid/card_teaser",
                   locals: { teaser: teaser } %>
      <% end %>
    <% else %>
      <% Array(@parcels_full).each do |parcel_hash| %>
        <%= render partial: "research/clear_to_bid/card_full",
                   locals: { parcel: parcel_hash } %>
      <% end %>
    <% end %>

  </div>

  <%# ── Empty state ───────────────────────────────────────────────────── %>
  <% if (@upgrade_required ? Array(@parcels_teaser) : Array(@parcels_full)).empty? %>
    <div class="text-center py-16">
      <div class="mx-auto w-16 h-16 rounded-full bg-gray-100 grid place-items-center mb-4">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor"
             stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 7l9-4 9 4-9 4-9-4zm0 6l9 4 9-4M3 17l9 4 9-4"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">No clear-to-bid parcels yet</h3>
      <p class="text-gray-500 text-sm mt-1">
        Our analysts publish new opportunities every week. Check back soon.
      </p>
    </div>
  <% end %>

  <%# ── Sticky upgrade footer (teaser mode) ──────────────────────────── %>
  <% if @upgrade_required %>
    <div class="fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 shadow-lg z-30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
        <p class="text-sm text-gray-700">
          <strong>Premier members</strong> see the full address, polygon, opening bid &amp; analyst grade for every parcel.
        </p>
        <%= link_to "Upgrade to Premier",
                    research_settings_path(anchor: "billing"),
                    class: "inline-flex items-center px-5 py-2 rounded-md text-sm font-semibold text-white bg-[#E67E22] hover:bg-[#D86E0E] transition" %>
      </div>
    </div>
  <% end %>
</section>

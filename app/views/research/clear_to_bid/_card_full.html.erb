<%# ─ PARTIAL: _card_full.html.erb ─────────────────────────────────────────
    Premier card. Static-map photo (con polígono naranja servido por Google
    Maps Static API cuando hay polygon_encoded), badges flotantes (grade,
    lot id, lat/long), data table con 4 métricas, footer "View dossier"
    enlazado a Rama 2 (research_parcel_path).

    Locals: parcel — Hash construido por ClearToBidPayload#clear_to_bid_full
            con keys: :id, :parcel_id, :state, :county, :address,
                      :latitude, :longitude, :polygon_encoded, :opening_bid,
                      :market_value, :year_built, :lot_area_acres,
                      :property_type, :clear_to_bid_grade, :auction
─────────────────────────────────────────────────────────────────────────── %>

<% map_struct = OpenStruct.new(
     latitude:        parcel[:latitude],
     longitude:       parcel[:longitude],
     polygon_encoded: parcel[:polygon_encoded]
   ) %>
<% coords_label   = format_coords(parcel[:latitude], parcel[:longitude]) %>
<% lot_label      = lot_short_id(parcel[:parcel_id]) %>
<% subtitle       = property_type_label(parcel) %>
<% sale_date      = parcel.dig(:auction, :sale_date) %>
<% has_polygon    = parcel[:polygon_encoded].present? %>

<article class="card-lift group bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-lg flex flex-col"
         data-grade="<%= parcel[:clear_to_bid_grade].to_s %>"
         data-grade-filter-target="card">

  <%# ── Map preview (4:3) ──────────────────────────────────────────── %>
  <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
    <% if (map_url = static_map_url(map_struct)) %>
      <%= image_tag map_url,
            alt: "Aerial view of parcel #{parcel[:parcel_id]}",
            loading: "lazy",
            class: "absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300",
            onerror: "this.style.display='none'" %>
    <% else %>
      <div class="absolute inset-0 grid place-items-center text-slate-400 text-xs">
        <%= t('clear_to_bid.map_unavailable') %>
      </div>
    <% end %>

    <%# Decorative SVG polygon — solo cuando NO hay polígono real en la
        foto satélite (evita doble polígono superpuesto). %>
    <% unless has_polygon %>
      <svg viewBox="0 0 400 300" preserveAspectRatio="none" class="absolute inset-0 w-full h-full pointer-events-none">
        <polygon points="148,108 252,98 268,182 156,196 138,148"
                 fill="rgba(255,235,160,0.18)" stroke="#fff8d8"
                 stroke-width="2.5" stroke-linejoin="round"/>
        <polygon points="148,108 252,98 268,182 156,196 138,148"
                 fill="none" stroke="#f5cf4d" stroke-width="1.5"
                 stroke-linejoin="round"/>
      </svg>
    <% end %>

    <%# Top row: grade badge (left) + lot id (right) %>
    <div class="absolute top-3 left-3 right-3 flex items-start justify-between">
      <span class="inline-flex items-center gap-1.5 <%= grade_badge_classes(parcel[:clear_to_bid_grade]) %> px-2 py-1 rounded-md font-mono uppercase tracking-[0.1em] text-[10.5px] font-bold shadow-sm backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full <%= grade_dot_class(parcel[:clear_to_bid_grade]) %>"></span>
        <%= grade_label(parcel[:clear_to_bid_grade]) %>
      </span>
      <% if lot_label.present? %>
        <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-black/55 backdrop-blur-sm text-white text-[10px] font-mono">
          <svg viewBox="0 0 24 24" width="9" height="9" fill="currentColor" aria-hidden="true">
            <path d="M12 2 9 9l-7 .5 5.5 4.5L6 22l6-3.8L18 22l-1.5-8 5.5-4.5L15 9z"/>
          </svg>
          <%= lot_label %>
        </span>
      <% end %>
    </div>

    <%# Bottom row: lat/long (left) + Satellite indicator (right) %>
    <div class="absolute bottom-3 left-3 right-3 flex items-end justify-between text-white">
      <% if coords_label %>
        <div class="font-mono text-[10px] tracking-wider opacity-90 leading-tight px-1.5 py-0.5 rounded bg-black/35 backdrop-blur-sm">
          <%= coords_label %>
        </div>
      <% else %>
        <span></span>
      <% end %>
      <div class="flex items-center gap-1 px-1.5 py-0.5 rounded bg-white/90 text-slate-700 text-[10px] font-mono">
        <span class="w-1 h-1 rounded-full bg-emerald-500"></span> Satellite
      </div>
    </div>
  </div>

  <%# ── Body ───────────────────────────────────────────────────────── %>
  <div class="p-5 flex flex-col gap-4 flex-1">
    <div>
      <div class="flex items-center gap-1.5 text-[10.5px] font-mono uppercase tracking-[0.12em] text-slate-400 font-semibold mb-1.5">
        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        <%= [parcel[:county], parcel[:state]].compact.reject(&:blank?).join(" · ") %>
      </div>
      <h3 class="text-[16px] font-semibold leading-snug text-slate-900 line-clamp-2">
        <%= parcel[:address].presence || t('clear_to_bid.card_address_pending') %>
      </h3>
      <% if subtitle %>
        <div class="text-[12.5px] text-slate-500 mt-0.5"><%= subtitle %></div>
      <% end %>
    </div>

    <%# Data table — 2x2 grid con métricas verificables %>
    <dl class="grid grid-cols-2 gap-x-4 gap-y-3 pt-3 border-t border-slate-100">
      <div>
        <dt class="text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400 font-semibold"><%= t('clear_to_bid.card_min_bid') %></dt>
        <dd class="font-display text-[22px] leading-none mt-1 text-slate-900">
          <% if parcel[:opening_bid].present? %>
            <%= number_to_currency(parcel[:opening_bid], precision: 0) %>
          <% else %>
            <span class="text-slate-400 text-[14px] font-normal">TBD</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400 font-semibold"><%= t('clear_to_bid.card_market_value') %></dt>
        <dd class="font-display text-[22px] leading-none mt-1 text-slate-900">
          <% if parcel[:market_value].present? %>
            <%= number_to_currency(parcel[:market_value], precision: 0) %>
          <% else %>
            <span class="text-slate-400 text-[14px] font-normal">—</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400 font-semibold"><%= t('clear_to_bid.card_auction') %></dt>
        <dd class="text-[13px] mt-1 font-medium text-slate-900">
          <%= sale_date ? sale_date.strftime("%b %d, %Y") : "TBD" %>
        </dd>
      </div>
      <div>
        <dt class="text-[10px] font-mono uppercase tracking-[0.1em] text-slate-400 font-semibold"><%= t('clear_to_bid.card_type') %></dt>
        <dd class="text-[13px] mt-1 font-mono font-semibold text-slate-700 truncate">
          <%= parcel[:property_type].presence || "—" %>
        </dd>
      </div>
    </dl>

    <%# Footer ─ View dossier (Rama 2) + save (cosmético) %>
    <div class="flex items-center gap-2 pt-3 mt-auto border-t border-slate-100">
      <%= link_to research_parcel_path(parcel[:id]),
            class: "flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg bg-slate-900 text-white text-[12.5px] font-medium hover:bg-slate-800 transition" do %>
        <%= t('clear_to_bid.card_view_dossier') %>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      <% end %>
      <button type="button"
              class="w-9 h-9 grid place-items-center rounded-lg border border-slate-200 hover:bg-slate-50 transition"
              title="<%= t('clear_to_bid.save') %>"
              aria-label="<%= t('clear_to_bid.save') %>">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
        </svg>
      </button>
    </div>
  </div>
</article>

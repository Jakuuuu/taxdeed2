<%# ─ PARTIAL: _mini_crm.html.erb ────────────────────────────────────────────
    Mini CRM — SIEMPRE VISIBLE. Inmune al paywall (regla absoluta).
    Tags & Notes nunca se difuminan.
─────────────────────────────────────────────────────────────────────────── %>
<div class="fp-card" id="ficha-crm">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">🏷</span>
    <h3 class="fp-card__hdr-title">My CRM — Tags &amp; Notes</h3>
    <span class="fp-card__hdr-badge">Always Visible</span>
  </div>
  <div class="fp-card__body">

    <%# Tag chips — activables con colores semánticos %>
    <div class="crm-chips-row" id="crm-chips-row">
      <% tag_value = @current_tag&.tag %>
      <% [
        { key: "target",    label: "🎯 Target",       css: "target"    },
        { key: "diligence", label: "🔍 Due Diligence", css: "diligence" },
        { key: "ready",     label: "✅ Ready to Bid",  css: "ready"     },
        { key: "dismissed", label: "❌ Dismissed",     css: "dismissed" }
      ].each do |t| %>
        <%= button_to research_parcel_user_tags_path(parcel_id: @parcel.id),
            method: :post,
            params: { tag: t[:key] },
            class: "crm-chip crm-chip--#{t[:css]}#{tag_value == t[:key] ? ' active' : ''}",
            form: { class: "crm-chip-form" },
            data: { turbo_method: :post } do %>
          <%= t[:label] %>
        <% end %>
      <% end %>
    </div>

    <%# Existing notes %>
    <% if @notes.any? %>
    <div class="crm-notes-list">
      <% @notes.each do |note| %>
      <div class="crm-note-item">
        <div class="crm-note-item__body"><%= note.body %></div>
        <div class="crm-note-item__time"><%= note.created_at.strftime("%b %d, %Y · %I:%M %p") %></div>
      </div>
      <% end %>
    </div>
    <% end %>

    <%# New note form %>
    <%= form_with url: research_parcel_user_notes_path(parcel_id: @parcel.id), method: :post, local: false do |f| %>
      <%= f.text_area :body, class: "crm-textarea",
          placeholder: "Add a private note about this property…\n(Only visible to you)" %>
      <%= f.submit "Save Note", class: "crm-save-btn" %>
    <% end %>

    <%# ── Add to Pipeline button (Rama 5 integration) ─────────────────── %>
    <% pipeline_prop = current_user.pipeline_properties.find_by(parcel_id: @parcel.id) %>
    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);">
      <% if pipeline_prop %>
        <div style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--ink-2);">
          <span style="background:var(--success-soft); color:var(--success); padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600;">
            ✓ In Pipeline
          </span>
          <span>Stage: <strong><%= pipeline_prop.pipeline_stage.name %></strong></span>
        </div>
      <% else %>
        <button type="button"
                id="btn-add-to-pipeline"
                onclick="addToPipeline(<%= @parcel.id %>)"
                style="width:100%; padding:10px; background:var(--surface-2); color:var(--ink-2);
                       border:1px dashed var(--border); border-radius:8px; cursor:pointer;
                       font:500 12px var(--font-sans); transition:all 200ms;"
                onmouseenter="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)';"
                onmouseleave="this.style.borderColor='var(--border)'; this.style.color='var(--ink-2)';">
          🏗️ Add to My Pipeline
        </button>
        <script>
        function addToPipeline(parcelId) {
          var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
          var btn = document.getElementById('btn-add-to-pipeline');
          btn.disabled = true;
          btn.textContent = '⏳ Adding...';

          fetch('/research/portfolio/properties', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': csrfToken,
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ parcel_id: parcelId })
          })
          .then(function(r) {
            if (!r.ok) throw new Error('Failed');
            return r.json();
          })
          .then(function(data) {
            btn.outerHTML = '<div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink-2);">'
              + '<span style="background:var(--success-soft);color:var(--success);padding:3px 8px;border-radius:6px;font-size:11px;font-weight:600;">✓ In Pipeline</span>'
              + '<span>Stage: <strong>' + (data.stage_name || 'New Lead') + '</strong></span>'
              + '</div>';
          })
          .catch(function() {
            btn.disabled = false;
            btn.textContent = '❌ Failed — Try again';
          });
        }
        </script>
      <% end %>
    </div>
  </div>
</div>

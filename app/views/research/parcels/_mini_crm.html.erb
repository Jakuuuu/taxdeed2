<%# ─ PARTIAL: _mini_crm.html.erb ────────────────────────────────────────────
    Mini CRM — SIEMPRE VISIBLE. Inmune al paywall (regla absoluta).
    Tags & Notes nunca se difuminan.
─────────────────────────────────────────────────────────────────────────── %>
<div class="fp-card" id="ficha-crm">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">🏷</span>
    <h3 class="fp-card__hdr-title"><%= t('crm.title') %></h3>
    <span class="fp-card__hdr-badge"><%= t('crm.always_visible') %></span>
  </div>
  <div class="fp-card__body">

    <%# Tag chips — activables con colores semánticos %>
    <div class="crm-chips-row" id="crm-chips-row">
      <% tag_value = @current_tag&.tag %>
      <% [
        { key: "target",    label: "🎯 Target",       css: "target"    },
        { key: "diligence", label: "🔍 Due Diligence", css: "diligence" },
        { key: "ready",     label: "✅ Ready to Bid",  css: "ready"     },
        { key: "dismissed", label: "❌ Dismissed",     css: "dismissed" }
      ].each do |t| %>
        <%= button_to research_parcel_user_tags_path(parcel_id: @parcel.id),
            method: :post,
            params: { tag: t[:key] },
            class: "crm-chip crm-chip--#{t[:css]}#{tag_value == t[:key] ? ' active' : ''}",
            form: { class: "crm-chip-form" },
            data: { turbo_method: :post } do %>
          <%= t[:label] %>
        <% end %>
      <% end %>
    </div>

    <%# Existing notes %>
    <% if @notes.any? %>
    <div class="crm-notes-list">
      <% @notes.each do |note| %>
      <div class="crm-note-item">
        <div class="crm-note-item__body"><%= note.body %></div>
        <div class="crm-note-item__time"><%= note.created_at.strftime("%b %d, %Y · %I:%M %p") %></div>
      </div>
      <% end %>
    </div>
    <% end %>

    <%# New note form %>
    <%= form_with url: research_parcel_user_notes_path(parcel_id: @parcel.id), method: :post, local: false do |f| %>
      <%= f.text_area :body, class: "crm-textarea",
          placeholder: t('crm.add_note_placeholder') %>
      <%= f.submit t('crm.save_note'), class: "crm-save-btn" %>
    <% end %>

    <%# ── Auction Reminder toggle (Mini CRM, inmune a paywall) ─────────
        - NO consume créditos
        - Si la parcel no tiene auction_id → toggle deshabilitado
        - Email_enabled visible pero la entrega real es Fase 2 %>
    <% has_auction = @parcel.auction&.sale_date.present? %>
    <% watching = @watch.present? %>
    <% current_days = @watch&.notify_days_before || (current_user.default_notify_days_before || 7) %>
    <% email_on   = @watch&.email_enabled || false %>
    <div id="crm-watch-block"
         data-parcel-id="<%= @parcel.id %>"
         data-watching="<%= watching %>"
         style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);">
      <% if has_auction %>
        <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
          <label style="display:flex; align-items:center; gap:8px; font:600 12px var(--font-sans); color:var(--ink-1); cursor:pointer; user-select:none;">
            <input type="checkbox"
                   id="crm-watch-toggle"
                   <%= "checked" if watching %>
                   style="width:16px; height:16px; cursor:pointer; accent-color: var(--accent);">
            🔔 <%= t('crm.notify_before_auction') %>
          </label>
          <span id="crm-watch-status"
                style="font:500 11px var(--font-sans); color:var(--ink-3);">
            <%= watching ? t('crm.notify_before_auction_active') : "" %>
          </span>
        </div>

        <div id="crm-watch-config"
             style="<%= watching ? '' : 'display:none;' %> padding:8px 10px; background:var(--surface-2); border-radius:8px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
            <label for="crm-watch-days" style="font:500 11px var(--font-sans); color:var(--ink-2); white-space:nowrap;">
              <%= t('crm.notify_before_label') %>
            </label>
            <select id="crm-watch-days"
                    style="flex:1; padding:4px 6px; border:1px solid var(--border); border-radius:6px; font:500 12px var(--font-sans); background:var(--surface-1); color:var(--ink-1); cursor:pointer;">
              <% [1, 3, 7, 14, 30].each do |d| %>
                <option value="<%= d %>" <%= "selected" if d == current_days %>><%= d == 1 ? t('crm.days_before_one', count: d) : t('crm.days_before_other', count: d) %></option>
              <% end %>
            </select>
          </div>
          <label style="display:flex; align-items:center; gap:6px; font:500 11px var(--font-sans); color:var(--ink-3); cursor:not-allowed; opacity:0.65;"
                 title="<%= t('crm.notify_email_unavailable_tooltip') %>">
            <input type="checkbox"
                   id="crm-watch-email"
                   <%= "checked" if email_on %>
                   disabled
                   style="width:14px; height:14px; accent-color: var(--accent);">
            <%= t('crm.notify_email_also') %> <span style="font-size:10px; color:var(--ink-3);"><%= t('common.coming_soon') %></span>
          </label>
        </div>
      <% else %>
        <div style="display:flex; align-items:center; gap:8px; padding:8px 10px; background:var(--surface-2); border-radius:8px; font:500 12px var(--font-sans); color:var(--ink-3);">
          🔔 <span><%= t('crm.no_auction_no_reminders') %></span>
        </div>
      <% end %>
    </div>

    <% if has_auction %>
    <script>
    (function() {
      var block  = document.getElementById('crm-watch-block');
      if (!block || block.dataset.bound === '1') return;
      block.dataset.bound = '1';

      var parcelId = block.dataset.parcelId;
      var toggle   = document.getElementById('crm-watch-toggle');
      var status   = document.getElementById('crm-watch-status');
      var config   = document.getElementById('crm-watch-config');
      var daysSel  = document.getElementById('crm-watch-days');
      var csrf     = document.querySelector('meta[name="csrf-token"]')?.content || '';

      function send(method) {
        var body = new FormData();
        body.append('notify_days_before', daysSel.value);
        body.append('email_enabled', 'false');
        return fetch('/research/parcels/' + parcelId + '/watch', {
          method: method,
          headers: { 'X-CSRF-Token': csrf, 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
          body: body
        }).then(function(r) {
          if (!r.ok) throw new Error('watch failed');
          return r.json();
        });
      }

      toggle.addEventListener('change', function() {
        if (toggle.checked) {
          config.style.display = '';
          status.textContent = '⏳';
          send('POST').then(function() {
            status.textContent = 'Activo';
          }).catch(function() {
            toggle.checked = false;
            config.style.display = 'none';
            status.textContent = 'Error';
          });
        } else {
          status.textContent = '⏳';
          fetch('/research/parcels/' + parcelId + '/watch', {
            method: 'DELETE',
            headers: { 'X-CSRF-Token': csrf, 'X-Requested-With': 'XMLHttpRequest' }
          }).then(function() {
            config.style.display = 'none';
            status.textContent = '';
          });
        }
      });

      daysSel.addEventListener('change', function() {
        if (!toggle.checked) return;
        status.textContent = '⏳';
        send('PATCH').then(function() { status.textContent = 'Activo'; });
      });
    })();
    </script>
    <% end %>

    <%# ── Add to Pipeline button (Rama 5 integration) ─────────────────── %>
    <% pipeline_prop = current_user.pipeline_properties.find_by(parcel_id: @parcel.id) %>
    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);">
      <% if pipeline_prop %>
        <div style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--ink-2);">
          <span style="background:var(--success-soft); color:var(--success); padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600;">
            ✓ In Pipeline
          </span>
          <span>Stage: <strong><%= pipeline_prop.pipeline_stage.name %></strong></span>
        </div>
      <% else %>
        <button type="button"
                id="btn-add-to-pipeline"
                onclick="addToPipeline(<%= @parcel.id %>)"
                style="width:100%; padding:10px; background:var(--surface-2); color:var(--ink-2);
                       border:1px dashed var(--border); border-radius:8px; cursor:pointer;
                       font:500 12px var(--font-sans); transition:all 200ms;"
                onmouseenter="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)';"
                onmouseleave="this.style.borderColor='var(--border)'; this.style.color='var(--ink-2)';">
          🏗️ Add to My Pipeline
        </button>
        <script>
        function addToPipeline(parcelId) {
          var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
          var btn = document.getElementById('btn-add-to-pipeline');
          btn.disabled = true;
          btn.textContent = '⏳ Adding...';

          fetch('/research/portfolio/properties', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': csrfToken,
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ parcel_id: parcelId })
          })
          .then(function(r) {
            if (!r.ok) throw new Error('Failed');
            return r.json();
          })
          .then(function(data) {
            btn.outerHTML = '<div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink-2);">'
              + '<span style="background:var(--success-soft);color:var(--success);padding:3px 8px;border-radius:6px;font-size:11px;font-weight:600;">✓ In Pipeline</span>'
              + '<span>Stage: <strong>' + (data.stage_name || 'New Lead') + '</strong></span>'
              + '</div>';
          })
          .catch(function() {
            btn.disabled = false;
            btn.textContent = '❌ Failed — Try again';
          });
        }
        </script>
      <% end %>
    </div>
  </div>
</div>

<% content_for :title, "Tax Sale Resources" %>

<div style="
  min-height: 100vh;
  background: #0f2044;
  font-family: 'Inter', sans-serif;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
">
  <!-- Logo -->
  <div style="margin-bottom: 2.5rem; text-align: center;">
    <h1 style="color: #fff; font-size: 1.75rem; font-weight: 800; margin: 0;">
      Tax Sale <span style="color: #c9a84c;">Resources</span>
    </h1>
  </div>

  <!-- Card -->
  <div style="
    background: #fff;
    border-radius: 16px;
    padding: 2.5rem 3rem;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  ">
    <div style="font-size: 2.5rem; margin-bottom: 1rem;">🏠</div>
    <h2 style="color: #0f2044; font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem;">
      Account active
    </h2>
    <p style="color: #718096; font-size: 0.9rem; margin: 0 0 0.5rem; line-height: 1.6;">
      Welcome, <strong><%= current_user.first_name %></strong>.
      Your account is set up and your subscription is being configured.
    </p>
    <% if current_user.subscription %>
      <p style="color: #718096; font-size: 0.85rem; margin: 0 0 2rem;">
        Plan: <strong style="color: #0f2044;"><%= current_user.subscription.plan_name&.capitalize %></strong>
        &nbsp;·&nbsp;
        Status: <strong style="color: #276749;"><%= current_user.subscription.status&.capitalize %></strong>
      </p>
    <% else %>
      <p style="color: #718096; font-size: 0.85rem; margin: 0 0 2rem;">
        Setting up your subscription...
      </p>
    <% end %>

    <div style="padding: 1rem; background: #f0f4f8; border-radius: 10px; margin-bottom: 2rem; font-size: 0.82rem; color: #4a5568; line-height: 1.5;">
      🚧 The research platform is being prepared.<br>You'll be notified when it's ready.
    </div>

    <%= link_to destroy_user_session_path,
        data: { turbo_method: :delete },
        style: "
          display: inline-block;
          padding: 10px 24px;
          background: #0f2044;
          color: #fff;
          border-radius: 8px;
          text-decoration: none;
          font-size: 0.875rem;
          font-weight: 600;
        " do %>
      Sign out
    <% end %>
  </div>
</div>

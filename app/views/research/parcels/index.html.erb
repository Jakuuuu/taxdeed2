document.addEventListener('DOMContentLoaded', function() {
  applyView(currentView, false);
});

function setView(view) {
  currentView = view;
  localStorage.setItem(STORAGE_KEY, view);
  applyView(view, true);
}

function applyView(view, loadMap) {
  var tableZone = document.getElementById('parcels-table-zone');
  var mapZone   = document.getElementById('parcels-map');
  var btnList   = document.getElementById('toggle-list');
  var btnMap    = document.getElementById('toggle-map');
  if (!tableZone || !mapZone) return;

  if (view === 'map') {
    tableZone.classList.remove('active');
    mapZone.classList.add('active');
    if (btnList) btnList.classList.remove('active');
    if (btnMap)  btnMap.classList.add('active');
    if (loadMap && HAS_CONTEXT && !mapInitialized) initParcelMap();
  } else {
    mapZone.classList.remove('active');
    tableZone.classList.add('active');
    if (btnMap)  btnMap.classList.remove('active');
    if (btnList) btnList.classList.add('active');
  }
}

// ── MAPA GIS CON CLUSTERING ───────────────────────────────────
function initParcelMap() {
  if (mapInitialized) return;

  var mapDiv = document.getElementById('parcels-map');

  // Loading overlay
  var overlay = document.createElement('div');
  overlay.className = 'map-loading-overlay';
  overlay.id = 'map-loading';
  overlay.innerHTML = '<div class="map-spinner"></div><span>Loading parcels map…</span>';
  mapDiv.appendChild(overlay);

  // Cargar Google Maps dinámicamente
  if (typeof google === 'undefined') {
    var s = document.createElement('script');
    s.src = 'https://maps.googleapis.com/maps/api/js?key=' + MAPS_API_KEY + '&callback=gMapsReady';
    s.async = true; s.defer = true;
    document.head.appendChild(s);
  } else {
    gMapsReady();
  }
}

window.gMapsReady = function() {
  var mapDiv   = document.getElementById('parcels-map');
  var gmap = new google.maps.Map(mapDiv, {
    zoom: 10,
    center: { lat: 27.5, lng: -81.5 },  // Florida por defecto
    mapTypeId: 'roadmap',
    streetViewControl: false,
    fullscreenControl: true,
    mapTypeControl: false
  });

  // Fetch parcelas GeoJSON — soporta auction_id o state
  var fetchUrl = MAP_DATA_URL;
  if (AUCTION_ID) {
    fetchUrl += '?auction_id=' + AUCTION_ID;
  } else if (SELECTED_STATE) {
    fetchUrl += '?state=' + SELECTED_STATE;
  }

  fetch(fetchUrl, {
    headers: { 'Accept': 'application/json' }
  })
  .then(function(r) { return r.json(); })
  .then(function(parcels) {
    var overlay = document.getElementById('map-loading');
    if (overlay) overlay.remove();

    if (!parcels.length) return;

    // Centrar mapa: usar centroide del estado si modo state, si no primera parcela
    if (!AUCTION_ID && SELECTED_STATE && STATE_CENTERS[SELECTED_STATE]) {
      gmap.setCenter(STATE_CENTERS[SELECTED_STATE]);
      gmap.setZoom(7);
    } else {
      gmap.setCenter({ lat: parcels[0].lat, lng: parcels[0].lng });
    }

    // Crear markers
    var markers = parcels.map(function(p) {
      var marker = new google.maps.Marker({
        position: { lat: p.lat, lng: p.lng },
        title: p.address
      });

      var infoContent = '<div style="font-family:var(--font, sans-serif);min-width:200px;">' +
        '<div style="font-weight:700;color:#1E3A5F;font-size:.9rem;margin-bottom:.3rem;">' + (p.address || '—') + '</div>' +
        '<div style="font-size:.78rem;color:#6C757D;margin-bottom:.45rem;">' + [p.county, p.state].filter(Boolean).join(', ') + '</div>' +
        (p.opening_bid ? '<div style="font-size:.85rem;font-weight:700;color:#0F5132;">Opening Bid: $' + Math.round(p.opening_bid).toLocaleString() + '</div>' : '') +
        '<a href="javascript:void(0)" onclick="openParcelDrawer(\'/research/parcels/' + p.id + '\')" style="display:inline-block;margin-top:.5rem;font-size:.78rem;font-weight:600;color:#1E3A5F;text-decoration:none;">View Details →</a>' +
        '</div>';

      var infoWindow = new google.maps.InfoWindow({ content: infoContent });
      marker.addListener('click', function() { infoWindow.open(gmap, marker); });
      return marker;
    });

    mapInitialized = true;
  })
  .catch(function(err) {
    var overlay = document.getElementById('map-loading');
    if (overlay) { overlay.innerHTML = '<span style="color:var(--color-danger);">⚠️ Failed to load map data.</span>'; }
  });
};

// ── PARCEL DRAWER (Overlay) ──────────────────────────────────
function openParcelDrawer(url) {
  var overlay = document.getElementById('property-detail-overlay');
  var backdrop = document.getElementById('map-backdrop');
  var content = document.getElementById('property-detail-content');
  
  backdrop.classList.add('is-open');
  overlay.classList.add('is-open');
  
  // Set internally URL
  window.history.pushState({ path: url }, '', url);
  
  content.innerHTML = '<div style="display:flex;height:100%;align-items:center;justify-content:center;color:var(--color-text-muted);"><div class="map-spinner"></div></div>';
  
  fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(r => r.text())
    .then(html => {
      content.innerHTML = html;
    })
    .catch(err => {
      content.innerHTML = '<div style="padding:2rem;color:var(--color-danger);text-align:center;">Failed to load property details. <br><button onclick="closeParcelDrawer()" class="btn-sm btn-sm-outline" style="margin-top:1rem;">Close</button></div>';
    });
}

function closeParcelDrawer() {
  var overlay = document.getElementById('property-detail-overlay');
  var backdrop = document.getElementById('map-backdrop');
  if (overlay) overlay.classList.remove('is-open');
  if (backdrop) backdrop.classList.remove('is-open');
  
  var currentUrl = new URL(window.location);
  currentUrl.pathname = '<%= research_parcels_path %>';
  window.history.pushState({}, '', currentUrl.href);
}

window.addEventListener('popstate', function(e) {
  if (window.location.pathname === '<%= research_parcels_path %>') {
    closeParcelDrawer();
  }
});

// ── AUCTION PICKER ────────────────────────────────────────────
function openAuctionPicker() {
  document.getElementById('auction-picker-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeAuctionPickerBackdrop(e) {
  if (e.target === document.getElementById('auction-picker-modal')) closeAuctionPickerDirect();
}
function closeAuctionPickerDirect() {
  document.getElementById('auction-picker-modal').classList.remove('open');
  document.body.style.overflow = '';
}
function selectAuction(id) {
  closeAuctionPickerDirect();
  window.location.href = '<%= research_parcels_path %>?auction_id=' + id;
}
function showStateAuctions(event, stateId) {
  document.querySelectorAll('.master-col-item').forEach(function(el) { el.classList.remove('active'); });
  event.currentTarget.classList.add('active');

  document.querySelectorAll('.picker-state-details').forEach(function(el) { el.style.display = 'none'; });
  document.getElementById('state-auctions-' + stateId).style.display = 'block';

  var searchInput = document.getElementById('picker-search-input');
  if (searchInput.value) {
    searchInput.value = '';
    filterPickerRows('');
  }
}
function filterPickerRows(query) {
  var q = query.toLowerCase().trim();
  var activeDetails = document.querySelector('.picker-state-details[style*="display: block"]');
  if (activeDetails) {
    var rows = activeDetails.querySelectorAll('.picker-auction-row');
    rows.forEach(function(row) {
      var match = row.dataset.auctionName.includes(q);
      row.style.display = match ? '' : 'none';
    });
  }
}

// ── CREDIT USAGE BANNER ──────────────────────────────────────
<% if current_user.subscription %>
(function() {
  var used  = <%= current_user.subscription.used_parcels %>;
  var limit = <%= current_user.subscription.limit_parcels %>;
  var pct   = limit > 0 ? Math.round(used / limit * 100) : 0;
  if (pct >= 70) {
    var banner = document.createElement('div');
    banner.style.cssText = 'background:' + (pct >= 90 ? '#FEE2E2' : '#FEF3C7') + ';color:' + (pct >= 90 ? '#991B1B' : '#92400E') + ';padding:.55rem 1.1rem;font-size:.78rem;font-weight:500;text-align:center;border-bottom:1px solid ' + (pct >= 90 ? '#FECACA' : '#FDE68A') + ';';
    banner.textContent = (pct >= 90 ? '🔴' : '🟡') + ' Property Reports: ' + used + ' / ' + limit + ' used (' + pct + '%)' + (pct >= 90 ? ' — Upgrade recommended.' : ' — Running low.');
    document.querySelector('.parcels-topbar')?.before(banner);
  }
})();
<% end %>
</script>

<%# ─ PARTIAL: _external_links.html.erb ──────────────────────────────────────
    External Links grid + Title Report CTA (Regla Naranja).
    Title Report solo visible si @unlocked == true.
─────────────────────────────────────────────────────────────────────────── %>

<%# ── External Links ─────────────────────────────────────────────────────── %>
<div class="fp-card" id="ficha-links">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">🔗</span>
    <h3 class="fp-card__hdr-title">External Links</h3>
  </div>
  <div class="fp-card__body">
    <div class="fp-links-grid">
      <% if @parcel.auction&.bidding_url.present? %>
      <a href="<%= @parcel.auction.bidding_url %>" target="_blank" rel="noopener" class="fp-link fp-link--cta">
        <span class="fp-link__icon">🏛</span>
        <div>
          <div class="fp-link__label fp-link__label--cta">Bid at Auction</div>
          <div class="fp-link__sub"><%= @parcel.auction.jurisdiction.presence || @parcel.county %></div>
        </div>
      </a>
      <% end %>
      <% if @parcel.regrid_url.present? %>
      <a href="<%= @parcel.regrid_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">🗺</span>
        <div>
          <div class="fp-link__label">Regrid</div>
          <div class="fp-link__sub">Parcel boundaries</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.google_maps_url.present? %>
      <a href="<%= @parcel.google_maps_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">📍</span>
        <div>
          <div class="fp-link__label">Google Maps</div>
          <div class="fp-link__sub">View location</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.clerk_url.present? %>
      <a href="<%= @parcel.clerk_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">⚖️</span>
        <div>
          <div class="fp-link__label">Clerk of Courts</div>
          <div class="fp-link__sub">Public records</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.tax_collector_url.present? %>
      <a href="<%= @parcel.tax_collector_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">🧾</span>
        <div>
          <div class="fp-link__label">Tax Collector</div>
          <div class="fp-link__sub">Tax records</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.fema_url.present? %>
      <a href="<%= @parcel.fema_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">💧</span>
        <div>
          <div class="fp-link__label">FEMA Map</div>
          <div class="fp-link__sub">Flood zone</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.gis_image_url.present? %>
      <a href="<%= @parcel.gis_image_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">🖼</span>
        <div>
          <div class="fp-link__label">GIS Image</div>
          <div class="fp-link__sub">Aerial view</div>
        </div>
      </a>
      <% end %>
      <% if @parcel.property_image_url.present? %>
      <a href="<%= @parcel.property_image_url %>" target="_blank" rel="noopener" class="fp-link">
        <span class="fp-link__icon">🏠</span>
        <div>
          <div class="fp-link__label">Property Photo</div>
          <div class="fp-link__sub">Street-level image</div>
        </div>
      </a>
      <% end %>
    </div>
  </div>
</div>

<%# ── Title Report CTA — Regla Naranja (solo si unlocked) ───────────────── %>
<div class="fp-title-report<%= ' fp-hidden' unless @unlocked %>" id="ficha-title-report">
  <div class="fp-title-report__info">
    <h4>📄 Generate Title Report</h4>
    <p>Order a professional title search to verify liens, mortgages, and ownership history. Delivered as PDF.</p>
  </div>
  <% existing_title_report = @parcel.reports.where(user: current_user, report_type: :title_search).last %>
  <% if existing_title_report&.generated? %>
    <%= link_to "⬇ Download PDF", existing_title_report.download_url,
        target: "_blank",
        class: "fp-title-report__btn" %>
  <% elsif existing_title_report %>
    <button class="fp-title-report__btn" disabled>⏳ Processing…</button>
  <% else %>
    <%# REGLA NARANJA — segundo uso exclusivo %>
    <%= button_to "Generate Title Report →",
        research_purchased_reports_path(parcel_id: @parcel.id, report_type: "title_search"),
        method: :post,
        class: "fp-title-report__btn",
        form: { data: { turbo_confirm: "Order a Title Report for this property?" } } %>
  <% end %>
</div>

<%# ─ PARTIAL: _card_legal.html.erb ───────────────────────────────────────────
    Análisis Legal — Clear Title, Homestead, Jurisdicción, Legal Description.
    Premium/blur.
─────────────────────────────────────────────────────────────────────────── %>

<div class="fp-card fp-premium <%= @unlocked ? 'fp-unlocked' : 'fp-locked' %>" id="ficha-card-legal">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">⚖️</span>
    <h3 class="fp-card__hdr-title">Legal Analysis</h3>
  </div>
  <div class="fp-card__body">
    <div class="fp-data-grid fp-data-grid--compact">
      <div class="fp-data-label">Homestead</div>
      <div class="fp-data-value">
        <% if @parcel.homestead_flag.present? %>
          <% hc = @parcel.homestead_flag.downcase == "homestead" ? "success" : "info" %>
          <span class="fp-badge fp-badge--<%= hc %>"><%= @parcel.homestead_flag.titleize %></span>
        <% else %>—<% end %>
      </div>

      <div class="fp-data-label">Jurisdiction</div>
      <div class="fp-data-value"><%= @parcel.jurisdiction.presence || "—" %></div>

      <% if @parcel.legal_description.present? %>
      <div class="fp-data-label">Legal Desc.</div>
      <div class="fp-data-value" style="font-size:11px;line-height:1.4;"><%= @parcel.legal_description %></div>
      <% end %>
    </div>
  </div>
</div>

<%# ─ PARTIAL: _va_analysis.html.erb ─────────────────────────────────────────
    VA Analysis — SIEMPRE VISIBLE. Datos del equipo, no paywall.
    Solo se renderiza si comments_do_va tiene contenido.
─────────────────────────────────────────────────────────────────────────── %>
<% if @parcel.comments_do_va.present? %>
<div class="fp-card" id="ficha-va-comments">
  <div class="fp-card__hdr" style="background: linear-gradient(135deg, #FFF8E1 0%, #FFF3CD 100%); border-bottom-color: rgba(218,165,32,0.25);">
    <span class="fp-card__hdr-icon">📋</span>
    <h3 class="fp-card__hdr-title" style="color: #856404;">VA Analysis</h3>
    <span class="fp-card__hdr-badge" style="background: rgba(218,165,32,0.12); color: #856404; border-color: rgba(218,165,32,0.3);">Research Notes</span>
  </div>
  <div class="fp-card__body">
    <div style="
      background: #FFFDE7;
      border: 1px solid rgba(218,165,32,0.3);
      border-left: 4px solid #F9A825;
      border-radius: 8px;
      padding: 16px 18px;
      font-size: 13.5px;
      line-height: 1.65;
      color: #4A3800;
      white-space: pre-wrap;
      font-family: var(--fp-font);
    "><%= @parcel.comments_do_va %></div>
    <p style="font-size: 11px; color: var(--fp-text-dim); margin: 10px 0 0; text-align: right;">
      📌 Análisis del equipo de Virtual Assistants — no editable por el usuario
    </p>
  </div>
</div>
<% end %>

<%# ─ PARTIAL: _title_report_cta.html.erb ─────────────────────────────────────
    CTA para ordenar Title Report — Regla Naranja (#E67E22).
    Solo visible si está unlocked.
─────────────────────────────────────────────────────────────────────────── %>

<% if @unlocked %>
<div class="fp-title-report-cta">
  <div class="fp-title-report-cta__inner">
    <div>
      <h3 class="fp-title-report-cta__title">📋 Order Title Report</h3>
      <p class="fp-title-report-cta__desc">
        Get a comprehensive title search report for this property.
        Verify liens, encumbrances, and chain of title.
      </p>
    </div>
    <%= link_to research_purchased_reports_path(parcel_id: @parcel.id, report_type: "title_search"),
        class: "fp-btn fp-btn--orange fp-btn--lg",
        data: { turbo_method: :post, turbo_frame: "_top" } do %>
      🔍 Generate Title Report
    <% end %>
  </div>
</div>
<% end %>

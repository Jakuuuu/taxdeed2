<%# ─ PARTIAL: _header_hero.html.erb ─────────────────────────────────────────
    "Property Intelligence Report" header — estilo reporte de inteligencia.
    Dark banner + golden badge de status + APN pill + address + meta badges.
─────────────────────────────────────────────────────────────────────────── %>

<% back_path = session[:last_parcels_path] || research_parcels_path(auction_id: @parcel.auction_id) %>
<%= link_to back_path, class: "fp-back" do %>← Back to Properties<% end %>

<div class="fp-hero">
  <%# ── Top bar: brand + status badge ─────────────────────────────── %>
  <div class="fp-hero__topbar">
    <div class="fp-hero__brand">
      <span class="fp-hero__brand-icon">L</span>
      <span class="fp-hero__brand-name">LION LEGACY TAXDEED</span>
    </div>
    <div class="fp-hero__status-badge">
      <span class="fp-hero__status-label">ANALYSIS STATUS</span>
      <span class="fp-hero__status-value">
        <%= @unlocked ? "COMPLETE ✓" : "LOCKED 🔒" %>
      </span>
    </div>
  </div>

  <%# ── Address & Location ───────────────────────────────────────────── %>
  <h1 class="fp-hero__title" style="display: flex; align-items: center; gap: 8px;">
    <span class="fp-hero__pin">📍</span>
    <%= @parcel.address.presence || "Address not available" %>
  </h1>
  <% if @parcel.county.present? %>
    <p class="fp-hero__location" style="margin-top: 4px; opacity: 0.85;">
      <%= @parcel.county %> County, <%= @parcel.state.presence || "FL" %>
    </p>
  <% end %>

  <%# ── Meta pills row ───────────────────────────────────────────── %>
  <div class="fp-hero__meta-row">
    <div class="fp-hero__pill fp-hero__pill--apn">
      <div class="fp-hero__pill-dot"></div>
      APN: <%= @parcel.parcel_id.presence || "—" %>
    </div>
    <% if @parcel.auction&.sale_date.present? %>
      <div class="fp-hero__pill">📅 <%= @parcel.auction.sale_date.strftime("%b %d, %Y") %></div>
    <% end %>
    <% if @parcel.property_type.present? %>
      <div class="fp-hero__pill">🏠 <%= @parcel.property_type %></div>
    <% end %>
    <% ds = @parcel.display_auction_status %>
    <% s_cls = case ds; when "available" then "success"; when "sold" then "danger"; when "expired" then "muted"; else "muted"; end %>
    <span class="fp-badge fp-badge--<%= s_cls %>"><%= ds == "expired" ? "No Disponible" : ds&.titleize %></span>
    <% if @parcel.crime_level.present? %>
      <% c_cls = case @parcel.crime_level.downcase; when "low" then "success"; when "moderate" then "warning"; when "high" then "danger"; else "muted"; end %>
      <span class="fp-badge fp-badge--<%= c_cls %>">Crime: <%= @parcel.crime_level.titleize %></span>
    <% end %>
    <% if @admin_override %>
      <span class="fp-admin-badge">Admin Override</span>
    <% end %>
  </div>

  <%# ── Opening Bid — prominent ──────────────────────────────────── %>
  <div class="fp-hero__bid">
    <span class="fp-hero__bid-label">Minimum Bid</span>
    <span class="fp-hero__bid-amount">
      <%= @parcel.opening_bid ? number_to_currency(@parcel.opening_bid) : "—" %>
    </span>
  </div>
</div>

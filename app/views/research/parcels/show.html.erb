<%# ═══ show.html.erb — Property Intelligence Report (Two-Column Layout) ═══
    Drawer AJAX 95vw · render layout:false · CSS inline obligatorio
    Diseño: Two-Column Grid (datos físicos izq · financieros+sidebar der)
    Responsive: colapsa a single-column < 900px
═══════════════════════════════════════════════════════════════════════════ %>
<% content_for :title, "#{@parcel.address} — TaxDeed Lion" %>

<%= render "research/parcels/ficha_styles" %>

<div class="ficha-root">
  <div class="ficha-container">

    <%# ── HEADER: Intelligence Report banner ──────────────────────────── %>
    <%= render "research/parcels/header_hero" %>

    <%# ── FULL WIDTH: Mini CRM (siempre visible — debajo del header) ──── %>
    <%= render "research/parcels/mini_crm" %>

    <%# ── PAYWALL CTA — Vault (si locked) ─────────────────────────────── %>
    <%= render "research/parcels/paywall_cta" %>

    <%# ── TWO-COLUMN ZONE: Premium Data ─────────────────────────────── %>
    <div class="ficha-two-col">

      <%# Premium Data: internally renders left + right columns %>
      <%#   Si locked: blur en cada card · Gated Disclaimer si aplica   %>
      <%= render "research/parcels/premium_data" %>

    </div>

    <%# ── FULL WIDTH: VA Analysis (siempre visible, condicional) ──────── %>
    <%= render "research/parcels/va_analysis" %>

    <%# ── GIS Map & Street View ───────────────────────────────────────── %>
    <%= render "research/parcels/gis_and_streetview" %>

    <%# ── FULL WIDTH: Title Report CTA (solo si unlocked) ─────────────── %>
    <%= render "research/parcels/title_report_cta" %>

    <%# ── FULL WIDTH: Download PDF CTA (solo si unlocked + disclaimer) ── %>
    <%# Regla: solo visible cuando la ficha está desbloqueada y el        %>
    <%# disclaimer legal ha sido aceptado. Admin siempre puede descargar. %>
    <% if (@unlocked && current_user.premium_disclaimer_accepted_at.present?) || @admin_override %>
      <style>
        .fp-pdf-btn {
          display: flex; align-items: center; justify-content: center; gap: 10px;
          width: 100%; padding: 16px 24px;
          background: linear-gradient(135deg, var(--fp-navy) 0%, var(--fp-navy-light) 100%);
          color: #ffffff; font-size: 1rem; font-weight: 700;
          border: none; border-radius: var(--fp-radius);
          text-decoration: none; cursor: pointer;
          box-shadow: var(--fp-shadow-md);
          transition: all 0.25s ease;
          letter-spacing: 0.03em; text-align: center;
        }
        .fp-pdf-btn:hover, .fp-pdf-btn:focus {
          filter: brightness(0.9);
          transform: translateY(-2px);
          box-shadow: 0 8px 20px oklch(0.30 0.08 280 / 0.4);
        }
      </style>
      <div style="margin-top: 20px; width: 100%;">
        <a href="<%= download_pdf_research_parcel_path(@parcel) %>"
           id="btn-download-ficha-pdf"
           class="fp-pdf-btn">
          📄 Descargar Reporte PDF
        </a>
      </div>
    <% end %>

  </div>
</div>

<%= render "research/parcels/ficha_javascript" %>

<%# ── JavaScript ──────────────────────────────────────────────────────── %>
<script>
  // ─── Toggle CRM chips (optimistic, real save via form submit) ──────
  document.querySelectorAll('.crm-chip').forEach(chip => {
    // Tags are submitted via button_to — visual toggle on click
    chip.addEventListener('click', function() {
      document.querySelectorAll('.crm-chip').forEach(c => c.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // ─── Unlock action ─────────────────────────────────────────────────
  function fichaUnlock(parcelId) {
    const btn = document.getElementById('ficha-unlock-btn');
    btn.disabled = true;
    btn.textContent = 'Unlocking…';

    fetch(`/research/parcels/${parcelId}/unlock`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
      }
    })
    .then(res => res.json())
    .then(data => {
      if (data.unlocked) {
        fichaRevealAll();
      } else {
        btn.disabled = false;
        btn.textContent = '🔓 Unlock Full Report — 1 Credit';
        alert(data.error || 'Could not unlock. Please check your credits.');
      }
    })
    .catch(() => {
      btn.disabled = false;
      btn.textContent = '🔓 Unlock Full Report — 1 Credit';
      alert('Network error. Please try again.');
    });
  }

  function fichaRevealAll() {
    // Hide paywall CTA
    document.getElementById('ficha-paywall-cta')?.classList.add('ficha-hidden');
    // Show unlocked banner
    document.getElementById('ficha-unlocked-banner')?.classList.add('ficha-visible');
    // Show title report CTA
    document.getElementById('ficha-title-report')?.classList.remove('ficha-hidden');

    // Reveal premium sections with staggered animation
    const sections = document.querySelectorAll('.ficha-premium');
    sections.forEach((s, i) => {
      setTimeout(() => {
        s.classList.remove('ficha-locked');
        s.classList.add('ficha-unlocked', 'ficha-animating');
        setTimeout(() => s.classList.remove('ficha-animating'), 600);
      }, i * 120);
    });
  }

  <% if @parcel.has_coords? %>
  // ─── Leaflet GIS Map ──────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function () {
    const lat = <%= @parcel.latitude %>;
    const lng = <%= @parcel.longitude %>;

    const map = L.map('ficha-map', {
      center: [lat, lng],
      zoom: 16,
      scrollWheelZoom: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '© <a href="https://carto.com/">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);

    const markerHtml = `<div style="
      width:14px;height:14px;border-radius:50%;
      background:#E67E22;border:2px solid white;
      box-shadow:0 0 8px rgba(230,126,34,0.6);">
    </div>`;
    const icon = L.divIcon({ html: markerHtml, iconSize: [14, 14], className: '' });

    L.marker([lat, lng], { icon })
      .addTo(map)
      .bindPopup(`<strong><%= j @parcel.address %></strong><br>APN: <%= j @parcel.parcel_id.to_s %>`)
      .openPopup();

    <% if ENV['REGRID_API_KEY'].present? %>
    // Regrid parcel boundary layer
    fetch(`https://app.regrid.com/api/v1/parcel/query.geojson?lat=${lat}&lon=${lng}&token=<%= ENV['REGRID_API_KEY'] %>`)
      .then(r => r.json())
      .then(geojson => {
        L.geoJSON(geojson, {
          style: { color: '#E67E22', weight: 2, fillOpacity: 0.12, fillColor: '#E67E22' }
        }).addTo(map);
      })
      .catch(() => {}); // silently ignore if Regrid unavailable
    <% end %>
  });
  <% end %>
</script>

<% content_for :title, "#{@parcel.address} — TaxDeed Lion" %>

<% content_for :head do %>
<%# Leaflet.js CDN for Regrid parcel boundary map %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<style>
  /* ─── CSS Variables (local scope) ──────────────────────────────── */
  :root {
    --ficha-bg:           #0F1117;
    --ficha-surface:      #1A1F2E;
    --ficha-surface-2:    #222940;
    --ficha-border:       rgba(255,255,255,0.08);
    --ficha-text:         #E8EAF0;
    --ficha-text-muted:   #8B93A8;
    --ficha-text-subtle:  #4A5568;
    --ficha-cta:          #E67E22;
    --ficha-cta-glow:     rgba(230,126,34,0.35);
    --ficha-success:      #27AE60;
    --ficha-radius-md:    12px;
    --ficha-radius-lg:    20px;
    --ficha-trans-fast:   150ms ease;
    --ficha-trans-normal: 300ms ease-in-out;
  }

  /* ─── Page Layout ────────────────────────────────────────────── */
  .ficha-page {
    background: var(--ficha-bg);
    min-height: 100vh;
    padding: 0 0 80px;
  }
  .ficha-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ─── Back Button ─────────────────────────────────────────── */
  .ficha-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 50px;
    border: 1px solid var(--ficha-border);
    background: transparent;
    color: var(--ficha-text-muted);
    font-size: 13px;
    text-decoration: none;
    transition: all var(--ficha-trans-fast);
    align-self: flex-start;
  }
  .ficha-back:hover { border-color: rgba(255,255,255,0.2); color: var(--ficha-text); }

  /* ─── Section Card ────────────────────────────────────────── */
  .ficha-card {
    background: var(--ficha-surface);
    border: 1px solid var(--ficha-border);
    border-radius: var(--ficha-radius-lg);
    overflow: hidden;
  }
  .ficha-card__hdr {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 20px;
    border-bottom: 1px solid var(--ficha-border);
    background: var(--ficha-surface-2);
  }
  .ficha-card__hdr-icon { font-size: 15px; opacity: 0.8; }
  .ficha-card__hdr-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ficha-text-muted);
    margin: 0;
  }
  .ficha-card__body { padding: 20px; }

  /* ─── Property Header ─────────────────────────────────────── */
  .ficha-header-card {
    background: linear-gradient(135deg, #1C2235 0%, #1A1F2E 100%);
    border: 1px solid var(--ficha-border);
    border-radius: var(--ficha-radius-lg);
    padding: 28px;
    position: relative;
    overflow: hidden;
  }
  .ficha-header-card::before {
    content: '';
    position: absolute; top: -40px; right: -40px;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(230,126,34,0.06), transparent 70%);
    pointer-events: none;
  }
  .ficha-apn-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--ficha-border);
    border-radius: 50px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ficha-text-muted);
    margin-bottom: 14px;
  }
  .ficha-apn-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--ficha-success);
    animation: ficha-pulse 2s infinite;
  }
  @keyframes ficha-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .ficha-address { font-size: 22px; font-weight: 700; color: var(--ficha-text); margin-bottom: 6px; line-height: 1.3; }
  .ficha-location { font-size: 14px; color: var(--ficha-text-muted); margin-bottom: 24px; }
  .ficha-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
    margin-bottom: 24px;
  }
  .ficha-meta-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--ficha-border);
    border-radius: var(--ficha-radius-md);
    padding: 11px 13px;
  }
  .ficha-meta-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ficha-text-subtle); margin-bottom: 4px; }
  .ficha-meta-value { font-size: 13px; font-weight: 500; color: var(--ficha-text); }
  .ficha-bid { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .ficha-bid-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ficha-text-subtle); }
  .ficha-bid-amount { font-family: 'DM Serif Display', serif; font-size: 42px; color: var(--ficha-text); line-height: 1; }

  /* ─── Mini CRM ────────────────────────────────────────────── */
  .crm-tags-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .crm-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 14px; border-radius: 50px; border: 1px solid;
    font-size: 12px; font-weight: 500; cursor: pointer;
    transition: all var(--ficha-trans-fast);
    opacity: 0.45;
    background: transparent;
    font-family: inherit;
  }
  .crm-chip.active { opacity: 1; }
  .crm-chip.crm-chip--target    { border-color: #2E86C1; color: #2E86C1; }
  .crm-chip.crm-chip--target.active    { background: rgba(46,134,193,0.12); }
  .crm-chip.crm-chip--diligence { border-color: var(--ficha-cta); color: var(--ficha-cta); }
  .crm-chip.crm-chip--diligence.active { background: rgba(230,126,34,0.12); }
  .crm-chip.crm-chip--ready     { border-color: #27AE60; color: #27AE60; }
  .crm-chip.crm-chip--ready.active     { background: rgba(39,174,96,0.12); }
  .crm-chip.crm-chip--dismissed { border-color: #6C757D; color: #6C757D; }
  .crm-chip.crm-chip--dismissed.active { background: rgba(108,117,125,0.12); }

  .crm-notes-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
  .crm-note-item {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--ficha-border);
    border-radius: 10px;
    padding: 10px 14px;
  }
  .crm-note-item__body { font-size: 13px; color: var(--ficha-text); line-height: 1.5; }
  .crm-note-item__time { font-size: 11px; color: var(--ficha-text-subtle); margin-top: 4px; }

  .crm-textarea {
    width: 100%; background: rgba(255,255,255,0.03);
    border: 1px solid var(--ficha-border); border-radius: 10px;
    padding: 11px 14px; color: var(--ficha-text); font-family: inherit;
    font-size: 13px; resize: vertical; min-height: 76px; outline: none;
    transition: border-color var(--ficha-trans-fast);
  }
  .crm-textarea:focus { border-color: rgba(255,255,255,0.2); }
  .crm-textarea::placeholder { color: var(--ficha-text-subtle); }
  .crm-save-btn {
    margin-top: 8px; padding: 7px 18px; border-radius: 50px;
    border: 1px solid var(--ficha-border); background: rgba(255,255,255,0.06);
    color: var(--ficha-text-muted); font-family: inherit; font-size: 12px;
    cursor: pointer; transition: all var(--ficha-trans-fast);
  }
  .crm-save-btn:hover { background: rgba(255,255,255,0.1); color: var(--ficha-text); }

  /* ─── Paywall CTA ─────────────────────────────────────────── */
  .ficha-paywall-cta {
    background: linear-gradient(135deg, rgba(230,126,34,0.08), rgba(211,84,0,0.04));
    border: 1px solid rgba(230,126,34,0.3);
    border-radius: var(--ficha-radius-lg);
    padding: 26px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .ficha-paywall-cta.ficha-hidden { display: none; }
  .paywall-info__title { font-size: 15px; font-weight: 600; color: var(--ficha-text); margin-bottom: 6px; }
  .paywall-info__desc  { font-size: 13px; color: var(--ficha-text-muted); line-height: 1.5; }
  .paywall-info__items { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
  .paywall-item-badge {
    display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px;
    border-radius: 50px; background: rgba(230,126,34,0.08);
    border: 1px solid rgba(230,126,34,0.15);
    font-size: 11px; color: #E67E22;
  }
  .ficha-unlock-wrap { display: flex; flex-direction: column; align-items: center; gap: 4px; flex-shrink: 0; }
  .ficha-unlock-btn {
    padding: 14px 28px; border-radius: 50px; border: none;
    background: linear-gradient(135deg, #E67E22, #D35400);
    color: white; font-family: inherit; font-size: 15px; font-weight: 700;
    cursor: pointer; box-shadow: 0 4px 20px var(--ficha-cta-glow);
    transition: all var(--ficha-trans-fast); white-space: nowrap;
  }
  .ficha-unlock-btn:hover {
    background: linear-gradient(135deg, #F39C12, #E67E22);
    box-shadow: 0 6px 28px var(--ficha-cta-glow); transform: translateY(-1px);
  }
  .ficha-unlock-btn:active { transform: translateY(0); }
  .ficha-unlock-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .ficha-credit-hint { font-size: 11px; color: var(--ficha-text-subtle); text-align: center; }

  /* ─── Unlocked Banner ─────────────────────────────────────── */
  .ficha-unlocked-banner {
    display: none; align-items: center; gap: 10px; padding: 12px 20px;
    background: rgba(39,174,96,0.08); border: 1px solid rgba(39,174,96,0.25);
    border-radius: 10px; color: #2ECC71; font-size: 13px; font-weight: 500;
  }
  .ficha-unlocked-banner.ficha-visible { display: flex; }

  /* ─── Data Grid ───────────────────────────────────────────── */
  .ficha-data-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .ficha-data-label, .ficha-data-value {
    padding: 11px 16px; font-size: 12.5px;
    border-bottom: 1px solid var(--ficha-border);
  }
  .ficha-data-label {
    color: var(--ficha-text-muted); font-weight: 500;
    background: rgba(255,255,255,0.015);
  }
  .ficha-data-value {
    color: var(--ficha-text);
    font-family: 'JetBrains Mono', monospace;
    transition: filter var(--ficha-trans-normal);
  }

  /* ─── Paywall sections ────────────────────────────────────── */
  .ficha-premium {
    position: relative;
    transition: all var(--ficha-trans-normal);
  }
  .ficha-premium.ficha-locked .ficha-data-value,
  .ficha-premium.ficha-locked .ficha-badge,
  .ficha-premium.ficha-locked .ficha-calc-value,
  .ficha-premium.ficha-locked .ficha-data-value * {
    filter: blur(5px);
    user-select: none;
    pointer-events: none;
  }
  .ficha-premium.ficha-locked .ficha-card__body::after,
  .ficha-premium.ficha-locked .ficha-premium-body::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(15,17,23,0.28);
    border-radius: 0 0 var(--ficha-radius-lg) var(--ficha-radius-lg);
    pointer-events: auto; cursor: not-allowed;
    z-index: 2;
  }
  .ficha-premium.ficha-unlocked .ficha-data-value,
  .ficha-premium.ficha-unlocked .ficha-badge,
  .ficha-premium.ficha-unlocked .ficha-calc-value {
    filter: none;
    user-select: auto;
    pointer-events: auto;
  }
  @keyframes fichaReveal {
    from { filter: blur(5px); opacity: 0.6; }
    to   { filter: none;     opacity: 1; }
  }
  .ficha-premium.ficha-animating .ficha-data-value,
  .ficha-premium.ficha-animating .ficha-badge,
  .ficha-premium.ficha-animating .ficha-calc-value {
    animation: fichaReveal 500ms ease-out forwards;
  }

  /* ─── Badges ──────────────────────────────────────────────── */
  .ficha-badge {
    display: inline-flex; align-items: center; padding: 2px 8px;
    border-radius: 50px; font-size: 11px; font-family: inherit;
    font-weight: 500; transition: filter var(--ficha-trans-normal);
  }
  .ficha-badge--success { background: rgba(39,174,96,0.15); color: #2ECC71; border: 1px solid rgba(39,174,96,0.3); }
  .ficha-badge--danger  { background: rgba(231,76,60,0.15);  color: #E74C3C; border: 1px solid rgba(231,76,60,0.3); }
  .ficha-badge--warning { background: rgba(243,156,18,0.15); color: #F39C12; border: 1px solid rgba(243,156,18,0.3); }
  .ficha-badge--info    { background: rgba(46,134,193,0.15); color: #3498DB; border: 1px solid rgba(46,134,193,0.3); }
  .ficha-badge--muted   { background: rgba(139,147,168,0.15);color: #8B93A8; border: 1px solid rgba(139,147,168,0.3); }

  /* ─── Investment Calculator ───────────────────────────────── */
  .ficha-calc-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
  .ficha-calc-card {
    background: rgba(255,255,255,0.03); border: 1px solid var(--ficha-border);
    border-radius: var(--ficha-radius-md); padding: 14px; text-align: center;
  }
  .ficha-calc-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ficha-text-subtle); margin-bottom: 8px; }
  .ficha-calc-value { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--ficha-text); }

  /* ─── Map ─────────────────────────────────────────────────── */
  #ficha-map { width: 100%; height: 320px; }
  .ficha-map-placeholder {
    width: 100%; height: 320px;
    background: linear-gradient(135deg, #1C2235, #222940);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; color: var(--ficha-text-muted); font-size: 13px;
  }

  /* ─── External Links ──────────────────────────────────────── */
  .ficha-links-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(175px, 1fr)); gap: 10px; }
  .ficha-link {
    display: flex; align-items: center; gap: 10px; padding: 12px 14px;
    background: rgba(255,255,255,0.03); border: 1px solid var(--ficha-border);
    border-radius: var(--ficha-radius-md); text-decoration: none;
    color: var(--ficha-text-muted); font-size: 13px; transition: all var(--ficha-trans-fast);
  }
  .ficha-link:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.15); color: var(--ficha-text); }
  .ficha-link--cta { border-color: rgba(230,126,34,0.3); background: rgba(230,126,34,0.05); color: #E67E22; }
  .ficha-link--cta:hover { background: rgba(230,126,34,0.1); border-color: rgba(230,126,34,0.5); }
  .ficha-link__icon { font-size: 17px; opacity: 0.8; flex-shrink: 0; }
  .ficha-link__label { font-weight: 500; }
  .ficha-link__sub   { font-size: 11px; color: var(--ficha-text-subtle); }

  /* ─── Title Report CTA ────────────────────────────────────── */
  .ficha-title-report {
    background: linear-gradient(135deg, rgba(230,126,34,0.06), rgba(211,84,0,0.03));
    border: 1px solid rgba(230,126,34,0.25);
    border-radius: var(--ficha-radius-lg); padding: 24px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .ficha-title-report.ficha-hidden { display: none; }
  .ficha-title-report__info h4    { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
  .ficha-title-report__info p     { font-size: 13px; color: var(--ficha-text-muted); }
  .ficha-title-report__btn {
    padding: 12px 28px; border-radius: 50px; border: none;
    background: linear-gradient(135deg, #E67E22, #D35400);
    color: white; font-family: inherit; font-size: 14px; font-weight: 700;
    cursor: pointer; box-shadow: 0 4px 20px var(--ficha-cta-glow);
    transition: all var(--ficha-trans-fast); white-space: nowrap; flex-shrink: 0;
  }
  .ficha-title-report__btn:hover {
    background: linear-gradient(135deg, #F39C12, #E67E22);
    box-shadow: 0 6px 28px var(--ficha-cta-glow); transform: translateY(-1px);
  }
  .ficha-title-report__btn:active { transform: translateY(0); }

  /* ─── Responsive ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .ficha-paywall-cta  { flex-direction: column; }
    .ficha-title-report { flex-direction: column; }
    .ficha-calc-grid    { grid-template-columns: 1fr 1fr; }
    .ficha-data-grid    { grid-template-columns: 1fr; }
    .ficha-bid-amount   { font-size: 32px; }
    .ficha-meta-grid    { grid-template-columns: 1fr 1fr; }
  }
</style>
<% end %>

<!-- ── Page ──────────────────────────────────────────────────────────── -->
<div class="ficha-page">
  <div class="ficha-container">

    <%# ── Back Button ────────────────────────────────────────────────── %>
    <% back_path = session[:last_parcels_path] || research_parcels_path(auction_id: @parcel.auction_id) %>
    <%= link_to back_path, class: "ficha-back" do %>
      ← Ver parcelas
    <% end %>

    <%# ─ 1. HEADER — Datos Básicos (GRATUITO) ────────────────────────── %>
    <div class="ficha-header-card">
      <div class="ficha-apn-badge">
        <div class="ficha-apn-dot"></div>
        APN: <%= @parcel.parcel_id.presence || "—" %>
      </div>
      <div class="ficha-address"><%= @parcel.address.presence || "Address not available" %></div>
      <div class="ficha-location">
        <%= [@parcel.county, @parcel.state, @parcel.zip_code].select(&:present?).join(", ") %>
      </div>

      <div class="ficha-meta-grid">
        <% if @parcel.auction&.sale_date.present? %>
        <div class="ficha-meta-item">
          <div class="ficha-meta-label">Sale Date</div>
          <div class="ficha-meta-value"><%= @parcel.auction.sale_date.strftime("%b %d, %Y") %></div>
        </div>
        <% end %>
        <% if @parcel.property_type.present? %>
        <div class="ficha-meta-item">
          <div class="ficha-meta-label">Property Type</div>
          <div class="ficha-meta-value"><%= @parcel.property_type %></div>
        </div>
        <% end %>
        <div class="ficha-meta-item">
          <div class="ficha-meta-label">Auction Status</div>
          <div class="ficha-meta-value">
            <% status_class = @parcel.auction_status == "available" ? "success" : (@parcel.auction_status == "sold" ? "danger" : "muted") %>
            <span class="ficha-badge ficha-badge--<%= status_class %>"><%= @parcel.auction_status&.titleize %></span>
          </div>
        </div>
        <% if @parcel.crime_level.present? %>
        <div class="ficha-meta-item">
          <div class="ficha-meta-label">Crime Level</div>
          <div class="ficha-meta-value">
            <% crime_class = case @parcel.crime_level.downcase; when "low" then "success"; when "moderate" then "warning"; when "high" then "danger"; else "muted"; end %>
            <span class="ficha-badge ficha-badge--<%= crime_class %>"><%= @parcel.crime_level.titleize %></span>
          </div>
        </div>
        <% end %>
      </div>

      <div class="ficha-bid">
        <div class="ficha-bid-label">Minimum Bid</div>
        <div class="ficha-bid-amount">
          <%= @parcel.opening_bid ? number_to_currency(@parcel.opening_bid) : "—" %>
        </div>
      </div>
    </div>

    <%# ─ 2. MINI CRM — SIEMPRE VISIBLE (aislado del paywall) ─────────── %>
    <div class="ficha-card" id="ficha-crm">
      <div class="ficha-card__hdr">
        <span class="ficha-card__hdr-icon">🏷</span>
        <h3 class="ficha-card__hdr-title">My CRM — Tags & Notes</h3>
      </div>
      <div class="ficha-card__body">
        <%# Tags %>
        <div class="crm-tags-row">
          <% tag_value = @current_tag&.tag %>
          <% [
            { key: "target",     label: "🎯 Target",     css: "target"    },
            { key: "diligence",  label: "🔍 Due Diligence", css: "diligence" },
            { key: "ready",      label: "✅ Ready to Bid", css: "ready"    },
            { key: "dismissed",  label: "❌ Dismissed",   css: "dismissed" }
          ].each do |t| %>
            <%= button_to research_parcel_user_tags_path(parcel_id: @parcel.id),
                method: :post,
                params: { tag: t[:key] },
                class: "crm-chip crm-chip--#{t[:css]}#{tag_value == t[:key] ? ' active' : ''}",
                data: { turbo_method: :post } do %>
              <%= t[:label] %>
            <% end %>
          <% end %>
        </div>

        <%# Existing notes %>
        <% if @notes.any? %>
        <div class="crm-notes-list">
          <% @notes.each do |note| %>
          <div class="crm-note-item">
            <div class="crm-note-item__body"><%= note.body %></div>
            <div class="crm-note-item__time"><%= note.created_at.strftime("%b %d, %Y at %I:%M %p") %></div>
          </div>
          <% end %>
        </div>
        <% end %>

        <%# New note form %>

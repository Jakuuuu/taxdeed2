<%# ═══ show.html.erb — Property Intelligence Report (Multi-Column Layout) ═══
    Drawer AJAX 95vw · render layout:false · CSS inline obligatorio
    Diseño: ficha maestra con uso horizontal del espacio (3-col / 2-col grids)
═══════════════════════════════════════════════════════════════════════════ %>
<% content_for :title, "#{@parcel.address} — TaxDeed Lion" %>

<%= render "research/parcels/ficha_styles" %>

<div class="ficha-root">
  <div class="ficha-container">

    <%# ── HEADER: Intelligence Report banner ──────────────────────────── %>
    <%= render "research/parcels/header_hero" %>

    <%# ── PAYWALL CTA (si locked) ─────────────────────────────────────── %>
    <%= render "research/parcels/paywall_cta" %>

    <%# ── ROW 1: 3 columnas — Investment | Property Info | Legal ──────── %>
    <div class="fp-grid fp-grid--3">
      <%= render "research/parcels/card_investment" %>
      <%= render "research/parcels/card_property_info" %>
      <%= render "research/parcels/card_legal" %>
    </div>

    <%# ── PREMIUM DATA (con Gated Disclaimer si aplica) ──────────────── %>
    <%#   Si el usuario desbloqueó pero NO aceptó el disclaimer legal,     %>
    <%#   _premium_data renderiza un overlay opaco con el texto legal.      %>
    <%#   Si ya aceptó, renderiza los datos normalmente con blur/unlock.    %>
    <%= render "research/parcels/premium_data" %>

    <%# ── ROW: Resource Center ────────────────────────────────────────── %>
    <div class="fp-grid fp-grid--2">
      <%= render "research/parcels/resource_center" %>
    </div>

    <%# ── FULL WIDTH: Mini CRM (siempre visible) ──────────────────────── %>
    <%= render "research/parcels/mini_crm" %>

    <%# ── FULL WIDTH: VA Analysis (siempre visible, condicional) ──────── %>
    <%= render "research/parcels/va_analysis" %>

    <%# ── ROW 4: 2 columnas — GIS Map | Street View ──────────────────── %>
    <div class="fp-grid fp-grid--2">
      <%= render "research/parcels/gis_and_streetview" %>
    </div>

    <%# ── FULL WIDTH: Title Report CTA (solo si unlocked) ─────────────── %>
    <%= render "research/parcels/title_report_cta" %>

  </div>
</div>

<%= render "research/parcels/ficha_javascript" %>

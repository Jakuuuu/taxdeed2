<% content_for :title, "#{@parcel.address} — Tax Sale Resources" %>

<% content_for :head do %>
<style>
  /* ── Layout 3 columnas ── */
  .ficha-layout {
    display: grid;
    grid-template-columns: 260px 1fr 300px;
    gap: 0;
    height: calc(100vh - var(--rn-header-h));
    overflow: hidden;
  }

  /* Col izquierda: Mini CRM */
  .ficha-col-crm {
    background: #F8F9FA;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .ficha-col-crm__header {
    padding: 1rem 1.1rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    background: #fff;
    position: sticky; top: 0; z-index: 1;
  }
  .ficha-col-crm__title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin: 0 0 0.15rem; }
  .ficha-col-crm__addr  { font-size: 0.8rem; font-weight: 600; color: var(--color-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ficha-col-crm__body  { padding: 1rem 1.1rem; flex: 1; }

  /* Tags */
  .crm-tags { display: flex; flex-direction: column; gap: 0.45rem; margin-bottom: 1.25rem; }
  .crm-tag-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1.5px solid var(--color-border);
    background: #fff;
    font-size: 0.8125rem; font-family: var(--font); font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    width: 100%; text-align: left;
  }
  .crm-tag-btn:hover { transform: translateX(2px); }
  .crm-tag-btn.active { border-color: transparent; color: #fff; }
  .crm-tag-btn .crm-tag-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* Separador */
  .crm-divider { border: none; border-top: 1px solid var(--color-border); margin: 1rem 0; }

  /* Notas */
  .crm-notes-list { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1rem; }
  .crm-note-item { background: #fff; border: 1px solid var(--color-border); border-radius: 8px; padding: 0.65rem 0.75rem; }
  .crm-note-item__body { font-size: 0.8125rem; color: var(--color-text); line-height: 1.5; }
  .crm-note-item__time { font-size: 0.7rem; color: var(--color-text-muted); margin-top: 0.3rem; }
  .crm-note-form textarea {
    width: 100%; box-sizing: border-box;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    font-size: 0.8125rem; font-family: var(--font);
    resize: vertical; min-height: 80px;
    outline: none; transition: border-color 0.15s;
  }
  .crm-note-form textarea:focus { border-color: var(--color-primary); }
  .crm-note-form button {
    margin-top: 0.5rem; width: 100%;
    padding: 0.5rem; border-radius: 8px;
    background: var(--color-primary); color: #fff;
    border: none; font-size: 0.8125rem; font-family: var(--font); font-weight: 600;
    cursor: pointer; transition: opacity 0.15s;
  }
  .crm-note-form button:hover { opacity: 0.9; }

  /* Back link */
  .ficha-back {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.75rem; color: var(--color-text-muted);
    padding: 0.65rem 1.1rem;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer; text-decoration: none;
    transition: color 0.15s;
  }
  .ficha-back:hover { color: var(--color-primary); }

  /* Col central: datos técnicos */
  .ficha-col-main {
    overflow-y: auto;
    padding: 1.5rem 1.75rem;
    background: #fff;
  }

  /* Col derecha: visual geo */
  .ficha-col-geo {
    background: #F8F9FA;
    border-left: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1.25rem 1.1rem;
  }
  .ficha-col-geo__section { margin-bottom: 1.25rem; }
  .ficha-col-geo__label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-text-muted); margin-bottom: 0.5rem; }
  .ficha-col-geo iframe { border-radius: 10px; border: none; width: 100%; height: 180px; }

  /* Responsive: en tablet colapsa a 1 columna */
  @media (max-width: 1024px) {
    .ficha-layout { grid-template-columns: 1fr; height: auto; }
    .ficha-col-crm, .ficha-col-geo { border: none; border-top: 1px solid var(--color-border); }
    .ficha-col-crm { height: auto; overflow-y: visible; }
  }

  /* Report buttons */
  .report-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .btn-report-order { padding: 0.5rem 1rem; border-radius: 8px; border: 1.5px solid var(--color-primary); background: #fff; color: var(--color-primary); font-size: 0.8125rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .btn-report-order:hover { background: var(--color-primary); color: #fff; }
  .btn-report-ordered { padding: 0.5rem 1rem; border-radius: 8px; border: 1.5px solid #E0E0E0; background: #F1F3F4; color: #6C757D; font-size: 0.8125rem; cursor: default; }
  .btn-report-download { padding: 0.5rem 1rem; border-radius: 8px; border: 1.5px solid var(--color-success); background: var(--color-success); color: #fff; font-size: 0.8125rem; font-weight: 600; text-decoration: none; display: inline-block; }

  /* Investment box */
  .invest-box { background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 10px; padding: 0.9rem 1rem; margin-top: 1rem; }
  .invest-box__title { font-size: 0.75rem; font-weight: 700; color: #166534; margin-bottom: 0.5rem; }
  .invest-box__row { display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.85rem; color: #166534; }
</style>
<% end %>

<div class="property-detail-grid" style="height:100vh;">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- COLUMNA IZQUIERDA — Mini CRM                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <aside class="ficha-col-crm" style="background: var(--color-zone-crm);">
    <% unless request.xhr? %>
      <% if @parcel.auction %>
        <%= link_to research_parcels_path(auction_id: @parcel.auction_id), class: "ficha-back" do %>
          ← Back to Parcels
        <% end %>
      <% else %>
        <%= link_to research_parcels_path, class: "ficha-back" do %>
          ← Back
        <% end %>
      <% end %>
    <% end %>

    <div class="ficha-col-crm__header" style="display:flex; justify-content:space-between; align-items:flex-start;">
      <div>
        <p class="ficha-col-crm__title">Mini CRM</p>
        <p class="ficha-col-crm__addr"><%= @parcel.address || "—" %></p>
      </div>
      <% if request.xhr? %>
        <button class="modal-close" onclick="closeParcelDrawer()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--color-text-muted);">&times;</button>
      <% end %>
    </div>

    <div class="ficha-col-crm__body">
      <!-- Tags -->
      <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--color-text-muted);margin-bottom:.6rem;">Status Tag</p>
      <div class="crm-tags" id="crm-tags">
        <% ParcelUserTag::VALID_TAGS.each do |tag_val| %>
          <%
            color      = ParcelUserTag::TAG_COLORS[tag_val]
            label      = ParcelUserTag::TAG_LABELS[tag_val]
            is_active  = @crm_tag&.tag == tag_val
          %>
          <button class="crm-tag-btn <%= 'active' if is_active %>"
                  id="crm-tag-<%= tag_val %>"
                  style="<%= is_active ? "background:#{color};border-color:#{color};" : "border-color:#{color}15;" %>"
                  onclick="setCrmTag('<%= tag_val %>', '<%= color %>', '<%= j label %>')">
            <span class="crm-tag-dot" style="background:<%= color %>;"></span>
            <%= label %>
            <% if is_active %><span style="margin-left:auto;font-size:0.7rem;">✓</span><% end %>
          </button>
        <% end %>
        <!-- Botón para quitar tag -->
        <button class="crm-tag-btn" style="border-color:#dee2e6;color:var(--color-text-muted);font-size:0.75rem;"
                onclick="setCrmTag('', '', '')" id="crm-tag-clear">
          <span class="crm-tag-dot" style="background:#dee2e6;"></span>
          Clear tag
        </button>
      </div>

      <hr class="crm-divider">

      <!-- Notas -->
      <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--color-text-muted);margin-bottom:.6rem;">Private Notes</p>

      <div class="crm-notes-list" id="crm-notes-list">
        <% if @crm_notes.any? %>
          <% @crm_notes.each do |note| %>
            <div class="crm-note-item" id="crm-note-<%= note.id %>">
              <div class="crm-note-item__body"><%= simple_format(note.body) %></div>
              <div class="crm-note-item__time"><%= note.created_at.strftime("%b %d, %Y %H:%M") %></div>
            </div>
          <% end %>
        <% else %>
          <p id="crm-notes-empty" style="font-size:0.8rem;color:var(--color-text-muted);">No notes yet.</p>
        <% end %>
      </div>

      <div class="crm-note-form">
        <textarea id="crm-note-input" placeholder="Add a private evaluation note…" rows="3"></textarea>
        <button onclick="saveCrmNote()">Save Note</button>
      </div>
    </div>
  </aside>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- COLUMNA CENTRAL — Datos Técnicos + Solicitud de Reportes  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <main class="ficha-col-main" style="background: var(--color-zone-data);">
    <!-- Header de la propiedad -->
    <h1 style="font-size:1.25rem;font-weight:800;color:var(--color-primary);margin-bottom:0.2rem;">
      <%= @parcel.address || "Parcel #{@parcel.id}" %>
    </h1>
    <p style="font-size:0.85rem;color:var(--color-text-muted);margin-bottom:1.5rem;">
      <% if @parcel.parcel_id %>
        <strong>APN:</strong> <%= @parcel.parcel_id %> &nbsp;·&nbsp;
      <% end %>
      <%= [@parcel.county, @parcel.state, @parcel.zip_code].compact.join(", ") %>
      <% if @parcel.auction %>
        &nbsp;·&nbsp; Sale: <strong><%= @parcel.auction.sale_date&.strftime("%b %d, %Y") %></strong>
      <% end %>
    </p>

    <!-- ── Solicitud de Reportes ── -->
    <div class="data-table-wrap" style="margin-bottom:1.25rem;">
      <div style="padding:.85rem 1.1rem;border-bottom:1px solid var(--color-border);">
        <h2 style="font-size:.8125rem;font-weight:700;color:var(--color-primary);margin:0;">📋 Reports</h2>
      </div>
      <div style="padding:.85rem 1.1rem;">
        <div class="report-actions" id="report-actions">
          <%
            report_defs = [
              { type: "avm",            label: "Order AVM Report",   short: "AVM" },
              { type: "property_scope", label: "Order Property Scope", short: "Scope" },
              { type: "title_search",   label: "Order Title Search", short: "Title" }
            ]
            report_defs.each do |rd|
              existing = @reports.find { |r| r.report_type == rd[:type] }
          %>
            <% if existing&.generated? %>
              <%= link_to "⬇ Download #{rd[:short]}",
                  existing.pdf_url || '#',
                  target: '_blank', class: "btn-report-download" %>
            <% elsif existing %>
              <span class="btn-report-ordered">⏳ <%= rd[:short] %> Ordered</span>
            <% else %>
              <button class="btn-order-report"
                      id="report-btn-<%= rd[:type] %>"
                      onclick="orderReport(<%= @parcel.id %>, '<%= rd[:type] %>', this)">
                💳 <%= rd[:label] %>
              </button>
            <% end %>
          <% end %>
        </div>
        <p style="font-size:.7rem;color:var(--color-text-muted);">Credits are consumed when ordered, not downloaded.</p>
      </div>
    </div>

    <!-- ── Grid: Características + Valuación ── -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">

      <!-- Características -->
      <div class="data-table-wrap">
        <div style="padding:.75rem 1rem;border-bottom:1px solid var(--color-border);">
          <h2 style="font-size:.8125rem;font-weight:700;color:var(--color-primary);margin:0;">🏠 Property Characteristics</h2>
        </div>
        <div style="padding:.75rem 1rem;">
          <div class="detail-grid">
            <div class="detail-item"><div class="detail-item__label">Property Type</div><div class="detail-item__value"><%= @parcel.property_type || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Land Use</div><div class="detail-item__value"><%= @parcel.land_use || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Zoning</div><div class="detail-item__value"><%= @parcel.zoning || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Year Built</div><div class="detail-item__value"><%= @parcel.year_built || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Living Area</div><div class="detail-item__value"><%= @parcel.living_area_sqft ? "#{number_with_delimiter(@parcel.living_area_sqft)} sqft" : '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Lot Area</div><div class="detail-item__value"><%= @parcel.lot_area_acres ? "#{@parcel.lot_area_acres} acres" : '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Bedrooms</div><div class="detail-item__value"><%= @parcel.bedrooms || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Bathrooms</div><div class="detail-item__value"><%= @parcel.bathrooms || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Owner</div><div class="detail-item__value"><%= @parcel.owner_name || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">HOA</div><div class="detail-item__value"><%= @parcel.hoa || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Homestead</div><div class="detail-item__value"><%= @parcel.homestead_flag || '—' %></div></div>
            <div class="detail-item"><div class="detail-item__label">Crime Level</div><div class="detail-item__value"><%= @parcel.crime_level || '—' %></div></div>
          </div>
          <% if @parcel.legal_description.present? %>
            <div style="margin-top:.75rem;padding:.65rem .85rem;background:#F8F9FA;border-radius:8px;font-size:.75rem;color:var(--color-text-muted);line-height:1.5;">
              <strong style="color:var(--color-text);">Legal Description:</strong><br><%= @parcel.legal_description %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Valuación -->
      <div class="data-table-wrap">
        <div style="padding:.75rem 1rem;border-bottom:1px solid var(--color-border);">
          <h2 style="font-size:.8125rem;font-weight:700;color:var(--color-primary);margin:0;">💰 Property Valuation</h2>
        </div>
        <div style="padding:.75rem 1rem;">
          <div class="detail-grid">
            <div class="detail-item"><div class="detail-item__label">Opening Bid</div><div class="detail-item__value" style="color:var(--color-primary);font-weight:800;"><% if @parcel.opening_bid %><span class="money-value">$<%= number_with_delimiter(@parcel.opening_bid.to_i) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Assessed Value</div><div class="detail-item__value"><% if @parcel.assessed_value %><span class="money-value">$<%= number_with_delimiter(@parcel.assessed_value.to_i) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Market Value</div><div class="detail-item__value"><% if @parcel.market_value %><span class="money-value" style="font-size:1.25rem;">$<%= number_with_delimiter(@parcel.market_value.to_i) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Land Value</div><div class="detail-item__value"><% if @parcel.land_value %><span class="money-value">$<%= number_with_delimiter(@parcel.land_value.to_i) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Improvement Value</div><div class="detail-item__value"><% if @parcel.improvement_value %><span class="money-value">$<%= number_with_delimiter(@parcel.improvement_value.to_i) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Delinquent Amount</div><div class="detail-item__value" style="color:var(--color-danger);"><% if @parcel.delinquent_amount %><span class="money-value">$<%= number_with_delimiter(@parcel.delinquent_amount.to_f.round(2)) %></span><% else %>—<% end %></div></div>
            <div class="detail-item"><div class="detail-item__label">Tax Year</div><div class="detail-item__value"><%= @parcel.tax_year || '—' %></div></div>
          </div>
          <div class="invest-box data-premium-locked" style="position:relative;">
            <p class="invest-box__title">📊 Investment Calculator (Premium)</p>
            <div class="invest-box__row data-value">
              <span>Max Bid 30%: <strong><% if @parcel.max_bid_30 %>$<%= number_with_delimiter(@parcel.max_bid_30.to_i) %><% else %>—<% end %></strong></span>
              <span>Max Bid 35%: <strong><% if @parcel.max_bid_35 %>$<%= number_with_delimiter(@parcel.max_bid_35.to_i) %><% else %>—<% end %></strong></span>
              <span>Bid +16%: <strong><% if @parcel.adjusted_value_16 %>$<%= number_with_delimiter(@parcel.adjusted_value_16.to_i) %><% else %>—<% end %></strong></span>
            </div>
            <% unless @reports.find { |r| r.report_type == 'avm' } %>
            <div class="unlock-overlay" onclick="document.getElementById('report-btn-avm').click()">
              <span>🔒 Order AVM Report to Unlock Calculator</span>
            </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Liens ── -->
    <div class="data-table-wrap" style="margin-bottom:1.25rem;">
      <div style="padding:.75rem 1rem;border-bottom:1px solid var(--color-border);">
        <h2 style="font-size:.8125rem;font-weight:700;color:var(--color-primary);margin:0;">📎 Mortgages & Liens (Premium)</h2>
      </div>
      <div class="data-premium-locked" style="position:relative; padding:0;">
        <div class="data-value">
          <% if @parcel.parcel_liens.any? %>
            <table class="data-table">
              <thead>
                <tr><th>Lender</th><th>Type</th><th>Amount</th><th>Recorded</th><th>Status</th></tr>
              </thead>
              <tbody>
                <% @parcel.parcel_liens.each do |lien| %>
                  <tr>
                    <td><%= lien.lender || '—' %></td>
                    <td><%= lien.lien_type || '—' %></td>
                    <td><% if lien.amount %><span class="money-value">$<%= number_with_delimiter(lien.amount.to_f.round(2)) %></span><% else %>—<% end %></td>
                    <td style="white-space:nowrap;font-size:.8rem;"><%= lien.recorded_date&.strftime("%b %d, %Y") || '—' %></td>
                    <td><span class="badge badge-<%= lien.status == 'active' ? 'active' : 'completed' %>"><%= lien.status&.capitalize || '—' %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p style="padding:.85rem 1.1rem;color:var(--color-text-muted);font-size:.875rem;">No recorded liens found for this parcel.</p>
          <% end %>
          <p style="padding:0 1.1rem .75rem;margin-top:.75rem;font-size:.7rem;color:var(--color-text-muted);">ℹ️ In Tax Deed sales, most liens are extinguished at auction. Shown for pre-sale title risk assessment only.</p>
        </div>
        <% unless @reports.find { |r| r.report_type == 'title_search' } %>
          <div class="unlock-overlay" onclick="document.getElementById('report-btn-title_search').click()">
            <span>🔒 Order Title Search to Unlock</span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- ── Utilidades (Electric, Water, Sewer, FEMA) ── -->
    <% if [@parcel.electric, @parcel.water, @parcel.sewer, @parcel.fema_risk_level].any?(&:present?) %>
    <div class="data-table-wrap">
      <div style="padding:.75rem 1rem;border-bottom:1px solid var(--color-border);">
        <h2 style="font-size:.8125rem;font-weight:700;color:var(--color-primary);margin:0;">⚡ Utilities & Risk</h2>
      </div>
      <div style="padding:.75rem 1rem;">
        <div class="detail-grid">
          <div class="detail-item"><div class="detail-item__label">Electric</div><div class="detail-item__value"><%= @parcel.electric&.capitalize || '—' %></div></div>
          <div class="detail-item"><div class="detail-item__label">Water</div><div class="detail-item__value"><%= @parcel.water&.capitalize || '—' %></div></div>
          <div class="detail-item"><div class="detail-item__label">Sewer</div><div class="detail-item__value"><%= @parcel.sewer&.capitalize || '—' %></div></div>
          <div class="detail-item"><div class="detail-item__label">Wetlands</div><div class="detail-item__value"><%= @parcel.wetlands? ? '⚠️ Yes' : 'No' %></div></div>
          <div class="detail-item"><div class="detail-item__label">FEMA Risk</div><div class="detail-item__value"><%= @parcel.fema_risk_level || '—' %></div></div>
        </div>
      </div>
    </div>
    <% end %>
  </main>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- COLUMNA DERECHA — Visualización Geográfica                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <aside class="ficha-col-geo" style="background: var(--color-zone-visual);">
    <% if @parcel.has_coords? && @api_key.present? %>
      <div class="ficha-col-geo__section">
        <p class="ficha-col-geo__label">Street View</p>
        <iframe src="<%= @parcel.street_view_url(@api_key) %>" allowfullscreen loading="lazy"></iframe>
      </div>
      <div class="ficha-col-geo__section">
        <p class="ficha-col-geo__label">Parcel Map</p>
        <iframe src="https://www.google.com/maps/embed/v1/place?key=<%= @api_key %>&q=<%= @parcel.latitude %>,<%= @parcel.longitude %>&zoom=16" allowfullscreen loading="lazy"></iframe>
      </div>
    <% else %>
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:50%;text-align:center;padding:2rem;color:var(--color-text-muted);">
        <div style="font-size:2.5rem;margin-bottom:.75rem;">🗺</div>
        <p style="font-size:.85rem;">No coordinates available for this parcel.</p>
      </div>
    <% end %>

    <!-- Links externos -->
    <div class="ficha-col-geo__section" style="margin-top:.5rem;">
      <p class="ficha-col-geo__label">External Links</p>
      <div style="display:flex;flex-direction:column;gap:.4rem;">
        <% if @parcel.regrid_url.present? %>
          <%= link_to "🗺 Regrid Parcel Data", @parcel.regrid_url, target: "_blank",
              style: "font-size:.8rem;color:var(--color-accent);" %>
        <% end %>
        <% if @parcel.clerk_url.present? %>
          <%= link_to "📄 County Clerk", @parcel.clerk_url, target: "_blank",
              style: "font-size:.8rem;color:var(--color-accent);" %>
        <% end %>
        <% if @parcel.tax_collector_url.present? %>
          <%= link_to "🏛 Tax Collector", @parcel.tax_collector_url, target: "_blank",
              style: "font-size:.8rem;color:var(--color-accent);" %>
        <% end %>
        <% if @parcel.auction&.bidding_url.present? %>
          <%= link_to "🔨 Auction Bidding Portal", @parcel.auction.bidding_url, target: "_blank",
              style: "font-size:.8rem;color:var(--color-primary);font-weight:600;" %>
        <% end %>
      </div>
    </div>
  </aside>

</div><!-- /.ficha-layout -->

<script>
// ── MINI CRM: Tags ────────────────────────────────────────────
var PARCEL_ID   = <%= @parcel.id %>;
var TAG_URL     = '<%= tag_research_parcel_path(@parcel) %>';
var NOTES_URL   = '<%= notes_research_parcel_path(@parcel) %>';
var CSRF_TOKEN  = document.querySelector('meta[name="csrf-token"]')?.content;
var currentTag  = '<%= @crm_tag&.tag.to_s %>';

function setCrmTag(tagVal, color, label) {
  fetch(TAG_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN, 'Accept': 'application/json' },
    body: JSON.stringify({ tag: tagVal })
  })
  .then(r => r.json())
  .then(function(d) {
    currentTag = tagVal;
    // Actualizar estilos de los botones
    document.querySelectorAll('.crm-tag-btn').forEach(function(btn) {
      btn.classList.remove('active');
      btn.style.background = '#fff';
      btn.style.borderColor = '';
      btn.style.color = '';
      btn.querySelector('span:last-child')?.remove?.();
    });
    if (tagVal) {
      var activeBtn = document.getElementById('crm-tag-' + tagVal);
      if (activeBtn) {
        activeBtn.classList.add('active');
        activeBtn.style.background = color;
        activeBtn.style.borderColor = color;
        activeBtn.style.color = '#fff';
        var check = document.createElement('span');
        check.style.marginLeft = 'auto';
        check.style.fontSize = '0.7rem';
        check.textContent = '✓';
        activeBtn.appendChild(check);
      }
    }
  });
}

// ── MINI CRM: Notas ───────────────────────────────────────────
function saveCrmNote() {
  var body = document.getElementById('crm-note-input').value.trim();
  if (!body) return;

  fetch(NOTES_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN, 'Accept': 'application/json' },
    body: JSON.stringify({ body: body })
  })
  .then(r => r.json())
  .then(function(d) {
    if (d.error) { alert(d.error); return; }
    // Quitar mensaje vacío si existe
    var emptyMsg = document.getElementById('crm-notes-empty');
    if (emptyMsg) emptyMsg.remove();
    // Agregar nota al final de la lista
    var list = document.getElementById('crm-notes-list');
    var item = document.createElement('div');
    item.className = 'crm-note-item';
    item.id = 'crm-note-' + d.id;
    item.innerHTML = '<div class="crm-note-item__body">' + escapeHtml(d.body).replace(/\n/g, '<br>') + '</div>' +
                     '<div class="crm-note-item__time">' + d.created_at + '</div>';
    list.appendChild(item);
    document.getElementById('crm-note-input').value = '';
  });
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── REPORTS ────────────────────────────────────────────────────
function orderReport(parcelId, reportType, btn) {
  btn.disabled = true;
  btn.textContent = '⏳ Ordering…';
  fetch('<%= research_purchased_reports_path %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN, 'Accept': 'application/json' },
    body: JSON.stringify({ parcel_id: parcelId, report_type: reportType })
  })
  .then(r => r.json())
  .then(function(d) {
    if (d.error) {
      btn.disabled = false;
      btn.textContent = btn.dataset.originalLabel || 'Order';
      alert(d.error);
    } else {
      btn.className    = 'btn-report-ordered';
      btn.textContent  = '⏳ Ordered';
    }
  });
}
</script>

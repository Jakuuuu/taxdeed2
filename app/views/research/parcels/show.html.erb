<%# ═══ show.html.erb — Property Intelligence Report (Multi-Column Layout) ═══
    Drawer AJAX 95vw · render layout:false · CSS inline obligatorio
    Diseño: ficha maestra con uso horizontal del espacio (3-col / 2-col grids)
═══════════════════════════════════════════════════════════════════════════ %>
<% content_for :title, "#{@parcel.address} — TaxDeed Lion" %>

<%= render "research/parcels/ficha_styles" %>

<div class="ficha-root">
  <div class="ficha-container">

    <%# ── HEADER: Intelligence Report banner ──────────────────────────── %>
    <%= render "research/parcels/header_hero" %>

    <%# ── PAYWALL CTA (si locked) ─────────────────────────────────────── %>
    <%= render "research/parcels/paywall_cta" %>

    <%# ── PREMIUM DATA (con Gated Disclaimer si aplica) ──────────────── %>
    <%#   Si el usuario desbloqueó pero NO aceptó el disclaimer legal,     %>
    <%#   _premium_data renderiza un overlay opaco con el texto legal.      %>
    <%#   Si ya aceptó, renderiza los datos normalmente con blur/unlock.    %>
    <%= render "research/parcels/premium_data" %>

    <%# ── Resource Center ─────────────────────────────────────────────── %>
    <%= render "research/parcels/resource_center" %>

    <%# ── FULL WIDTH: Mini CRM (siempre visible) ──────────────────────── %>
    <%= render "research/parcels/mini_crm" %>

    <%# ── FULL WIDTH: VA Analysis (siempre visible, condicional) ──────── %>
    <%= render "research/parcels/va_analysis" %>

    <%# ── GIS Map & Street View ───────────────────────────────────────── %>
    <%= render "research/parcels/gis_and_streetview" %>

    <%# ── FULL WIDTH: Title Report CTA (solo si unlocked) ─────────────── %>
    <%= render "research/parcels/title_report_cta" %>

    <%# ── FULL WIDTH: Download PDF CTA (solo si unlocked + disclaimer) ── %>
    <%# Regla: solo visible cuando la ficha está desbloqueada y el        %>
    <%# disclaimer legal ha sido aceptado. Admin siempre puede descargar. %>
    <% if (@unlocked && current_user.premium_disclaimer_accepted_at.present?) || @admin_override %>
      <div style="
        margin-top: 20px;
        padding: 0;
        width: 100%;
      ">
        <a href="<%= download_pdf_research_parcel_path(@parcel) %>"
           id="btn-download-ficha-pdf"
           style="
             display: flex;
             align-items: center;
             justify-content: center;
             gap: 10px;
             width: 100%;
             padding: 16px 24px;
             background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
             color: #ffffff;
             font-size: 1rem;
             font-weight: 700;
             border: none;
             border-radius: 10px;
             text-decoration: none;
             cursor: pointer;
             box-shadow: 0 4px 14px rgba(230,126,34,0.30);
             transition: all 0.25s ease;
             letter-spacing: 0.03em;
             text-align: center;
           "
           onmouseover="this.style.background='linear-gradient(135deg, #D35400 0%, #C0392B 100%)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(230,126,34,0.40)';"
           onmouseout="this.style.background='linear-gradient(135deg, #E67E22 0%, #D35400 100%)'; this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 14px rgba(230,126,34,0.30)';"
        >
          📄 Descargar Reporte PDF
        </a>
      </div>
    <% end %>

  </div>
</div>

<%= render "research/parcels/ficha_javascript" %>

<%# ══════════════════════════════════════════════════════════════════════════
    show.html.erb — Ficha de Propiedad (Drawer AJAX, 95vw, render layout:false)
    ARQUITECTURA: Orquestador de partials. Este archivo no contiene lógica ni
    CSS — solo delega a sub-partials para mantener tokens bajo control.
    GOTCHA: CSS INLINE en _ficha_styles — nunca content_for :head.
═══════════════════════════════════════════════════════════════════════════ %>
<% content_for :title, "#{@parcel.address} — TaxDeed Lion" %>

<%# 0. CSS inline — OBLIGATORIO para drawer AJAX (render layout:false) %>
<%= render "research/parcels/ficha_styles" %>

<div class="ficha-root">
  <div class="ficha-container">

    <%# 1. HEADER — Back button + Hero (APN, dirección, bid) — GRATUITO %>
    <%= render "research/parcels/header_hero" %>

    <%# 2. MINI CRM — Tags & Notes — SIEMPRE VISIBLE (inmune al paywall) %>
    <%= render "research/parcels/mini_crm" %>

    <%# 3. PAYWALL CTA (Regla Naranja) + Unlocked banner %>
    <%#    CRM y Mapa NUNCA quedan bajo este difuminado %>
    <%= render "research/parcels/paywall_cta" %>

    <%# 4. DATOS AVANZADOS — blur si locked, claro si unlocked %>
    <%#    Protección: .fp-premium.fp-locked { overflow: visible } %>
    <%= render "research/parcels/premium_data" %>

    <%# 5. VA ANALYSIS — SIEMPRE VISIBLE (datos equipo, no paywall) %>
    <%= render "research/parcels/va_analysis" %>

    <%# 6. GIS MAP + STREET VIEW — SIEMPRE VISIBLES (regla absoluta) %>
    <%= render "research/parcels/gis_and_streetview" %>

    <%# 7. EXTERNAL LINKS + TITLE REPORT CTA (Regla Naranja, solo si unlocked) %>
    <%= render "research/parcels/external_links" %>

  </div><%# .ficha-container %>
</div><%# .ficha-root %>

<%# 8. JavaScript inline — CRM optimistic UI, unlock flow, Google Maps, Regrid %>
<%= render "research/parcels/ficha_javascript" %>

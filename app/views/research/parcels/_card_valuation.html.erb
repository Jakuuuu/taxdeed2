<%# ─ PARTIAL: _card_valuation.html.erb ───────────────────────────────────────
    Valuación financiera y fiscal — premium/blur.
─────────────────────────────────────────────────────────────────────────── %>

<div class="fp-card fp-premium <%= @unlocked ? 'fp-unlocked' : 'fp-locked' %>" id="ficha-card-valuation">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">📊</span>
    <h3 class="fp-card__hdr-title">Valuation & Tax</h3>
  </div>
  <div class="fp-card__body">
    <div class="fp-data-grid">
      <div class="fp-data-label">Assessed Value</div>
      <div class="fp-data-value"><%= @parcel.assessed_value ? number_to_currency(@parcel.assessed_value) : "—" %></div>

      <div class="fp-data-label">Market Value</div>
      <div class="fp-data-value"><%= @parcel.market_value ? number_to_currency(@parcel.market_value) : "—" %></div>

      <div class="fp-data-label">Land Value</div>
      <div class="fp-data-value"><%= @parcel.land_value ? number_to_currency(@parcel.land_value) : "—" %></div>

      <div class="fp-data-label">Improvement Value</div>
      <div class="fp-data-value"><%= @parcel.improvement_value ? number_to_currency(@parcel.improvement_value) : "—" %></div>

      <div class="fp-data-label">Delinquent Amount</div>
      <div class="fp-data-value" style="color:#E74C3C;font-weight:600;">
        <%= @parcel.delinquent_amount ? number_to_currency(@parcel.delinquent_amount) : "—" %>
      </div>

      <% if @parcel.winning_bid.present? %>
      <div class="fp-data-label">Winning Bid</div>
      <div class="fp-data-value" style="color:#2ECC71;font-weight:700;"><%= number_to_currency(@parcel.winning_bid) %></div>
      <% end %>
    </div>
  </div>
</div>

<%# ─ PARTIAL: _resource_center.html.erb ──────────────────────────────────────
    Centro de Recursos — links externos como mini-cards con íconos.
    Estilo de la imagen de referencia: sidebar con tarjetas clickeables.
    Siempre visible (no premium).
─────────────────────────────────────────────────────────────────────────── %>

<div class="fp-card" id="ficha-resource-center">
  <div class="fp-card__hdr">
    <span class="fp-card__hdr-icon">🔗</span>
    <h3 class="fp-card__hdr-title"><%= t('ficha_cards.resource_center') %></h3>
    <span class="fp-card__hdr-sub"><%= @parcel.county.presence || "" %></span>
  </div>
  <div class="fp-card__body fp-resource-list">
    <% resources = [
      { icon: "🏛", title: t('resource_center.bid_at_auction_title'),  desc: t('resource_center.bid_at_auction_desc'),  url: @parcel.auction&.bidding_url },
      { icon: "🗺", title: t('resource_center.regrid_title'),          desc: t('resource_center.regrid_desc'),          url: @parcel.regrid_url           },
      { icon: "📋", title: t('resource_center.appraiser_title'),       desc: t('resource_center.appraiser_desc'),       url: @parcel.property_appraiser_url },
      { icon: "⚖",  title: t('resource_center.clerk_title'),           desc: t('resource_center.clerk_desc'),           url: @parcel.clerk_url            },
      { icon: "🧾", title: t('resource_center.tax_collector_title'),   desc: t('resource_center.tax_collector_desc'),   url: @parcel.tax_collector_url     },
      { icon: "📍", title: t('resource_center.google_maps_title'),     desc: t('resource_center.google_maps_desc'),     url: @parcel.google_maps_url      },
      { icon: "🌊", title: t('resource_center.fema_title'),            desc: t('resource_center.fema_desc'),            url: @parcel.fema_url             }
    ] %>

    <% has_resources = resources.any? { |r| r[:url].present? } %>

    <% if has_resources %>
      <% resources.each do |r| %>
        <% if r[:url].present? %>
          <a href="<%= r[:url] %>" target="_blank" rel="noopener" class="fp-resource-item">
            <span class="fp-resource-icon"><%= r[:icon] %></span>
            <div class="fp-resource-text">
              <div class="fp-resource-title"><%= r[:title] %></div>
              <div class="fp-resource-desc"><%= r[:desc] %></div>
            </div>
            <span class="fp-resource-arrow">↗</span>
          </a>
        <% end %>
      <% end %>
    <% else %>
      <div class="fp-empty-state" style="padding: 24px 16px; text-align: center; color: var(--fp-text-muted);">
        <div style="font-size: 24px; margin-bottom: 8px; opacity: 0.5;">📭</div>
        <p style="margin: 0; font-size: 13px;"><%= t('resource_center.no_resources') %></p>
      </div>
    <% end %>
  </div>
</div>

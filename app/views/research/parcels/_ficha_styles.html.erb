<style>
/* ═══════════════════════════════════════════════════════════════════════════
   FICHA MAESTRA — Property Intelligence Report
   Light mode · Aligned with TaxDeed Lion Design System (Navy / Gold / White)
   Multi-column grid · Inline CSS (drawer AJAX, no content_for)
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── Design Tokens (inherits from application.css :root) ──────────────── */
:root {
  --fp-bg:          #F5F7FA;
  --fp-surface:     #FFFFFF;
  --fp-surface-2:   #F0F2F5;
  --fp-border:      #E2E8F0;
  --fp-text:        #1A202C;
  --fp-text-dim:    #6B7280;
  --fp-navy:        #1E3A5F;
  --fp-navy-light:  #2C5282;
  --fp-gold:        #C9A84C;
  --fp-gold-light:  #DEC06A;
  --fp-gold-dim:    rgba(201,168,76,.08);
  --fp-orange:      #E67E22;
  --fp-green:       #38A169;
  --fp-red:         #E53E3E;
  --fp-blue:        #2E86C1;
  --fp-radius:      10px;
  --fp-radius-lg:   16px;
  --fp-radius-sm:   6px;
  --fp-shadow:      0 2px 12px rgba(0,0,0,.06);
  --fp-shadow-md:   0 4px 16px rgba(0,0,0,.10);
  --fp-font:        'Inter', system-ui, sans-serif;
  --fp-font-money:  'DM Serif Display', serif;
  --fp-font-mono:   'JetBrains Mono', monospace;
}

/* ── Root & Container ─────────────────────────────────────────────────── */
.ficha-root {
  background: var(--fp-bg);
  color: var(--fp-text);
  font-family: var(--fp-font);
  font-size: 14px;
  line-height: 1.55;
  min-height: 100vh;
}
.ficha-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 20px 28px 48px;
}

/* ── Back Button ──────────────────────────────────────────────────────── */
.fp-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--fp-text-dim);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 16px;
  transition: color .2s;
}
.fp-back:hover { color: var(--fp-navy); }

/* ── Hero: Intelligence Report Header ─────────────────────────────────── */
.fp-hero {
  background: linear-gradient(135deg, var(--fp-navy) 0%, var(--fp-navy-light) 100%);
  border: 1px solid rgba(30,58,95,.15);
  border-radius: var(--fp-radius-lg);
  padding: 28px 32px 24px;
  margin-bottom: 20px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(30,58,95,.15);
}
.fp-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--fp-gold), var(--fp-orange), var(--fp-gold));
}
/* Decorative circle — brand subtlety */
.fp-hero::after {
  content: '';
  position: absolute;
  top: -40%; right: -8%;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(201,168,76,.06);
  pointer-events: none;
}

.fp-hero__topbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; position:relative; z-index:1; }
.fp-hero__brand { display:flex; align-items:center; gap:10px; }
.fp-hero__brand-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:32px; height:32px;
  background: var(--fp-gold);
  color: var(--fp-navy);
  font-weight:800; font-size:16px;
  border-radius:6px;
}
.fp-hero__brand-name { font-size:13px; font-weight:700; letter-spacing:1.5px; color:rgba(255,255,255,.65); }

.fp-hero__status-badge {
  display:flex; flex-direction:column; align-items:flex-end;
  background:rgba(255,255,255,.1);
  border:1px solid var(--fp-gold);
  border-radius:8px;
  padding:6px 14px;
  backdrop-filter: blur(4px);
}
.fp-hero__status-label { font-size:9px; letter-spacing:1.5px; color:var(--fp-gold); font-weight:600; }
.fp-hero__status-value { font-size:14px; font-weight:700; color:var(--fp-gold-light); }

.fp-hero__title {
  font-size:22px; font-weight:800; letter-spacing:1px;
  margin:0 0 8px;
  color:#FFFFFF;
  position:relative; z-index:1;
}
.fp-hero__address-line { display:flex; align-items:center; gap:8px; position:relative; z-index:1; }
.fp-hero__pin { font-size:16px; }
.fp-hero__address { font-size:16px; font-weight:600; color:#FFFFFF; }
.fp-hero__location { font-size:13px; color:rgba(255,255,255,.65); margin:0 0 14px; padding-left:24px; position:relative; z-index:1; }

.fp-hero__meta-row { display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:16px; position:relative; z-index:1; }
.fp-hero__pill {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(255,255,255,.1);
  border:1px solid rgba(255,255,255,.2);
  border-radius:20px;
  padding:4px 12px;
  font-size:12px;
  color:rgba(255,255,255,.85);
  font-weight:500;
  backdrop-filter: blur(4px);
}
.fp-hero__pill--apn { border-color:var(--fp-gold); color:var(--fp-gold-light); }
.fp-hero__pill-dot { width:7px; height:7px; border-radius:50%; background:var(--fp-green); animation:pulse-dot 2s infinite; }
@keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.4} }

.fp-hero__bid {
  display:flex; align-items:baseline; gap:12px;
  padding-top:12px;
  border-top:1px solid rgba(255,255,255,.15);
  position:relative; z-index:1;
}
.fp-hero__bid-label { font-size:12px; color:rgba(255,255,255,.6); text-transform:uppercase; letter-spacing:1px; font-weight:600; }
.fp-hero__bid-amount {
  font-size:28px; font-weight:800;
  color:var(--fp-gold-light);
  font-family: var(--fp-font-money);
  font-variant-numeric:tabular-nums;
}



/* ── Two-Column Grid System ──────────────────────────────────────────── */
.ficha-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: start;
}
.ficha-col {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
/* Premium wrapper spans full width of parent grid */
#premium-data-wrapper {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: start;
}
/* Resource center — lives inside right .ficha-col, no blur */
#ficha-resource-center {
  /* No extra margin needed; .ficha-col gap handles spacing */
}

/* ── Card Base ────────────────────────────────────────────────────────── */
.fp-card {
  background: var(--fp-surface);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius);
  overflow: visible;
  display: flex;
  flex-direction: column;
  transition: border-color .25s, box-shadow .25s;
  margin-bottom: 0; /* gap handles spacing inside #premium-data-wrapper */
}
.fp-card + .fp-card { margin-top: 0; } /* prevent double margins */
.ficha-container > .fp-card { margin-bottom: 16px; } /* top-level cards outside wrapper */
.fp-card:hover {
  border-color: rgba(201,168,76,.35);
  box-shadow: var(--fp-shadow-md);
}

.fp-card__hdr {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--fp-border);
  background: var(--fp-surface);
}
.fp-card__hdr--accent {
  background: linear-gradient(135deg, rgba(30,58,95,.04) 0%, rgba(201,168,76,.06) 100%);
}
.fp-card__hdr-icon { font-size:18px; flex-shrink:0; }
.fp-card__hdr-title {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: var(--fp-navy);
  margin: 0;
  flex: 1;
}
.fp-card__hdr-sub { font-size:11px; color:var(--fp-text-dim); }
.fp-card__body { padding:16px 18px; flex:1; }

/* ── Data Grid (key-value pairs) ──────────────────────────────────────── */
.fp-data-grid {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 8px 16px;
  align-items: baseline;
  max-width: 680px;
  margin: 0 auto;
}
.fp-data-grid--compact { grid-template-columns: 120px 1fr; }
.fp-data-label { font-size: 12px; color: var(--fp-text-dim); font-weight: 500; padding: 2px 0; }
.fp-data-value { font-size: 13px; color: var(--fp-text); font-weight: 600; word-break: break-word; padding: 2px 0; }

/* ── KPI Cells (Investment Summary) ───────────────────────────────────── */
.fp-kpi-highlight {
  text-align: center;
  padding: 12px 0 16px;
  border-bottom: 1px solid var(--fp-border);
  margin-bottom: 14px;
}
.fp-kpi-value--big {
  font-size: 26px;
  font-weight: 800;
  color: var(--fp-navy);
  font-family: var(--fp-font-money);
  font-variant-numeric: tabular-nums;
}
.fp-kpi-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; max-width:680px; margin:0 auto; }
.fp-kpi-cell {
  background: var(--fp-surface-2);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius-sm);
  padding: 10px 12px;
  text-align: center;
  transition: border-color .2s, box-shadow .2s;
}
.fp-kpi-cell:hover {
  border-color: rgba(201,168,76,.4);
  box-shadow: 0 2px 8px rgba(201,168,76,.08);
}
.fp-kpi-cell--success { border-color:var(--fp-green); background:rgba(56,161,105,.04); }
.fp-kpi-label { font-size:11px; color:var(--fp-text-dim); font-weight:500; margin-bottom:4px; text-transform:uppercase; letter-spacing:.3px; }
.fp-kpi-value {
  font-size: 15px;
  font-weight: 700;
  color: var(--fp-navy);
  font-family: var(--fp-font-mono);
  font-variant-numeric: tabular-nums;
}

/* ── Investment Calculator Grid ──────────────────────────────────────── */
.fp-calc-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; max-width:680px; margin:0 auto; }
.fp-calc-card {
  background: var(--fp-surface-2);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius-sm);
  padding: 14px 16px;
  text-align: center;
  transition: border-color .2s, box-shadow .2s;
}
.fp-calc-card:hover {
  border-color: rgba(201,168,76,.4);
  box-shadow: 0 2px 8px rgba(201,168,76,.08);
}
.fp-calc-label { font-size:11px; color:var(--fp-text-dim); font-weight:500; margin-bottom:4px; text-transform:uppercase; letter-spacing:.3px; }
.fp-calc-value {
  font-size: 17px;
  font-weight: 700;
  color: var(--fp-navy);
  font-family: var(--fp-font-mono);
  font-variant-numeric: tabular-nums;
}

/* ── Legal Badge ──────────────────────────────────────────────────────── */
.fp-legal-badge-wrap { margin-bottom:14px; }
.fp-legal-badge {
  display:flex; align-items:center; gap:10px;
  background:rgba(56,161,105,.06);
  border:1px solid rgba(56,161,105,.25);
  border-radius:var(--fp-radius-sm);
  padding:10px 14px;
}
.fp-legal-badge__icon {
  display:flex; align-items:center; justify-content:center;
  width:28px; height:28px;
  background:var(--fp-green); color:#fff;
  font-size:14px; font-weight:800;
  border-radius:50%; flex-shrink:0;
}
.fp-legal-badge__title { font-size:10px; letter-spacing:1.5px; font-weight:700; color:var(--fp-text-dim); text-transform:uppercase; }
.fp-legal-badge__subtitle { font-size:13px; font-weight:600; color:var(--fp-green); font-style:italic; }

/* ── Resource Center ──────────────────────────────────────────────────── */
.fp-resource-list { display:flex; flex-direction:column; gap:6px; padding:12px 14px; }
.fp-resource-item {
  display:flex; align-items:center; gap:12px;
  padding:10px 14px;
  background:var(--fp-surface-2);
  border:1px solid var(--fp-border);
  border-radius:var(--fp-radius-sm);
  text-decoration:none;
  color:var(--fp-text);
  transition:all .2s;
}
.fp-resource-item:hover {
  border-color: var(--fp-navy-light);
  background: rgba(30,58,95,.04);
  transform: translateX(3px);
  box-shadow: 0 2px 8px rgba(30,58,95,.08);
}
.fp-resource-icon { font-size:20px; flex-shrink:0; }
.fp-resource-text { flex:1; min-width:0; }
.fp-resource-title { font-size:13px; font-weight:600; color:var(--fp-navy); }
.fp-resource-desc { font-size:11px; color:var(--fp-text-dim); }
.fp-resource-arrow { color:var(--fp-text-dim); font-size:14px; transition:color .2s; }
.fp-resource-item:hover .fp-resource-arrow { color:var(--fp-navy); }

/* ── Badges ───────────────────────────────────────────────────────────── */
.fp-badge { display:inline-block; padding:2px 10px; border-radius:12px; font-size:11px; font-weight:600; letter-spacing:.3px; }
.fp-badge--success { background:rgba(56,161,105,.1); color:#276749; border:1px solid rgba(56,161,105,.25); }
.fp-badge--warning { background:rgba(201,168,76,.1); color:#92600B; border:1px solid rgba(201,168,76,.3); }
.fp-badge--danger  { background:rgba(229,62,62,.08); color:#9B2C2C; border:1px solid rgba(229,62,62,.2); }
.fp-badge--info    { background:rgba(46,134,193,.08); color:#1A5276; border:1px solid rgba(46,134,193,.2); }
.fp-badge--muted   { background:var(--fp-surface-2); color:var(--fp-text-dim); border:1px solid var(--fp-border); }
.fp-admin-badge { background:rgba(229,62,62,.08); color:var(--fp-red); border:1px solid rgba(229,62,62,.2); border-radius:12px; padding:2px 10px; font-size:11px; font-weight:600; }

/* ── Paywall / Blur ───────────────────────────────────────────────────── */
.fp-premium-gated { filter:blur(6px); pointer-events:none; user-select:none; opacity:0.4; }
.fp-premium.fp-locked .fp-card__body { filter:blur(6px); pointer-events:none; user-select:none; }
.fp-premium.fp-unlocked .fp-card__body { filter:none; }

/* ── Paywall Vault (Redesigned CTA) ──────────────────────────────────── */
.fp-paywall-vault {
  background: linear-gradient(135deg, var(--fp-navy) 0%, var(--fp-navy-light) 100%);
  border: 1px solid rgba(201,168,76,.25);
  border-radius: var(--fp-radius-lg);
  padding: 36px 32px 32px;
  margin-bottom: 20px;
  box-shadow: 0 8px 32px rgba(30,58,95,.18);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.fp-paywall-vault::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--fp-gold), var(--fp-orange), var(--fp-gold));
}
.fp-paywall-vault::after {
  content: '';
  position: absolute;
  bottom: -30%; right: -10%;
  width: 320px; height: 320px;
  border-radius: 50%;
  background: rgba(201,168,76,.06);
  pointer-events: none;
}
.fp-vault__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px; height: 56px;
  border-radius: 50%;
  background: rgba(201,168,76,.12);
  border: 2px solid rgba(201,168,76,.25);
  font-size: 28px;
  margin-bottom: 16px;
}
.fp-vault__title {
  font-size: 22px;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin: 0 0 6px;
  position: relative; z-index: 1;
}
.fp-vault__sub {
  font-size: 14px;
  color: rgba(255,255,255,.65);
  margin: 0 0 24px;
  font-weight: 500;
  position: relative; z-index: 1;
}
.fp-vault-features {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 520px;
  margin: 0 auto 28px;
  position: relative; z-index: 1;
}
.fp-vault-feature {
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--fp-radius);
  padding: 16px 12px;
  backdrop-filter: blur(4px);
  transition: all .2s;
}
.fp-vault-feature:hover {
  background: rgba(255,255,255,.14);
  border-color: rgba(201,168,76,.35);
  transform: translateY(-2px);
}
.fp-vault-feature__icon { font-size: 24px; margin-bottom: 8px; }
.fp-vault-feature__label {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,.85);
  text-transform: uppercase;
  letter-spacing: .5px;
}
.fp-vault-feature__count {
  font-size: 10px;
  color: var(--fp-gold-light);
  margin-top: 2px;
}
.fp-unlock-wrap { position: relative; z-index: 1; }
.fp-unlock-btn {
  display: block;
  width: 100%;
  max-width: 420px;
  margin: 0 auto;
  padding: 16px 28px;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  color: #ffffff;
  font-size: 16px;
  font-weight: 800;
  border: none;
  border-radius: var(--fp-radius);
  cursor: pointer;
  box-shadow: 0 6px 24px rgba(230,126,34,.35);
  transition: all .25s ease;
  font-family: var(--fp-font);
  letter-spacing: 0.02em;
}
.fp-unlock-btn:hover {
  background: linear-gradient(135deg, #D35400 0%, #C0392B 100%);
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(230,126,34,.45);
}
.fp-credit-hint {
  font-size: 12px;
  color: rgba(255,255,255,.5);
  margin-top: 10px;
  font-weight: 500;
}

/* Old paywall compat */
.fp-paywall-cta { display: none; } /* Replaced by .fp-paywall-vault */
.fp-hidden { display: none !important; }
.fp-visible { display: flex !important; }

/* ── Buttons ──────────────────────────────────────────────────────────── */
.fp-btn {
  display:inline-flex; align-items:center; gap:8px;
  padding:10px 22px;
  border-radius:var(--fp-radius-sm);
  font-size:14px; font-weight:700;
  text-decoration:none; border:none;
  cursor:pointer;
  transition:all .2s;
  font-family: var(--fp-font);
}
.fp-btn--orange { background:var(--fp-orange); color:#fff; }
.fp-btn--orange:hover {
  background:#D35400;
  transform:translateY(-1px);
  box-shadow:0 4px 14px rgba(230,126,34,.3);
  color:#fff;
}
.fp-btn--navy { background:var(--fp-navy); color:#fff; }
.fp-btn--navy:hover { background:var(--fp-navy-light); transform:translateY(-1px); box-shadow:var(--fp-shadow-md); color:#fff; }
.fp-btn--lg { padding:14px 28px; font-size:15px; }

/* ── Title Report CTA ─────────────────────────────────────────────────── */
.fp-title-report-cta { margin-top:12px; margin-bottom:16px; }
.fp-title-report-cta__inner {
  display:flex; align-items:center; justify-content:space-between;
  background: var(--fp-surface);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius);
  padding: 20px 24px;
  gap: 20px;
  box-shadow: var(--fp-shadow);
  transition: border-color .2s, box-shadow .2s;
}
.fp-title-report-cta__inner:hover {
  border-color: rgba(230,126,34,.35);
  box-shadow: 0 4px 16px rgba(230,126,34,.1);
}
.fp-title-report-cta__title { font-size:16px; font-weight:700; margin:0 0 4px; color:var(--fp-navy); }
.fp-title-report-cta__desc { font-size:13px; color:var(--fp-text-dim); margin:0; }

/* ── Mini CRM ─────────────────────────────────────────────────────────── */
.fp-crm-card {
  background: var(--fp-surface);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius);
  padding: 18px 20px;
  margin-bottom: 16px;
  box-shadow: var(--fp-shadow);
}
.fp-crm-tags { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:12px; }
.fp-crm-tag {
  padding: 6px 16px;
  border-radius: 20px;
  border: 1.5px solid var(--fp-border);
  background: var(--fp-surface-2);
  color: var(--fp-text-dim);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all .2s;
}
.fp-crm-tag:hover { border-color:var(--fp-navy-light); color:var(--fp-navy); background:rgba(30,58,95,.04); }
.fp-crm-tag.active { background:rgba(30,58,95,.08); border-color:var(--fp-navy); color:var(--fp-navy); font-weight:600; }
.fp-crm-notes textarea {
  width:100%;
  background:var(--fp-surface-2);
  border:1.5px solid var(--fp-border);
  border-radius:var(--fp-radius-sm);
  color:var(--fp-text);
  padding:10px;
  font-family:var(--fp-font);
  font-size:13px;
  resize:vertical;
  min-height:60px;
  transition:border-color .2s, box-shadow .2s;
}
.fp-crm-notes textarea:focus { outline:none; border-color:var(--fp-navy); box-shadow:0 0 0 3px rgba(30,58,95,.08); }

/* ── VA Analysis ──────────────────────────────────────────────────────── */
.fp-va-card {
  background: var(--fp-surface);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius);
  padding: 18px 20px;
  margin-bottom: 16px;
  box-shadow: var(--fp-shadow);
}

/* ── GIS Map & Street View ────────────────────────────────────────────── */
.fp-gis-panel {
  background: var(--fp-surface);
  border: 1px solid var(--fp-border);
  border-radius: var(--fp-radius);
  overflow: hidden;
  box-shadow: var(--fp-shadow);
}
.fp-gis-panel__map { width:100%; height:340px; background:var(--fp-surface-2); }
.fp-gis-panel__title {
  padding:10px 16px;
  font-size:12px; font-weight:600;
  color:var(--fp-navy);

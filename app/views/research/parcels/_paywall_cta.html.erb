<%# ─ PARTIAL: _paywall_cta.html.erb ─────────────────────────────────────────
    Paywall CTA (Regla Naranja #E67E22) + Unlocked banner.
    CRÍTICO: CRM y Mapa NUNCA quedan bajo este difuminado.
    Admin Override: oculta el paywall completamente.
─────────────────────────────────────────────────────────────────────────── %>

<%# REGLA NARANJA — CTA transaccional: solo este botón y Title Report %>
<% unless @admin_override %>
<div class="fp-paywall-cta<%= ' fp-hidden' if @unlocked %>" id="ficha-paywall-cta">
  <div style="position:relative;z-index:1;">
    <p class="fp-paywall-info__title">🔓 Unlock Full Property Report</p>
    <p class="fp-paywall-info__desc">Access complete property data, investment metrics, and the ability to order a Title Report.</p>
    <div class="fp-paywall-items">
      <span class="fp-paywall-item">✓ Property Characteristics</span>
      <span class="fp-paywall-item">✓ Valuation Data</span>
      <span class="fp-paywall-item">✓ Investment Calculator</span>
      <span class="fp-paywall-item">✓ Mortgages &amp; Liens</span>
      <span class="fp-paywall-item">✓ FEMA / Risk Data</span>
      <span class="fp-paywall-item">✓ Owner Info</span>
      <span class="fp-paywall-item">✓ Title Report Access</span>
    </div>
  </div>
  <div class="fp-unlock-wrap">
    <%# REGLA NARANJA (#E67E22) — exclusivo para este CTA transaccional %>
    <button class="fp-unlock-btn" id="ficha-unlock-btn"
            onclick="fichaUnlock(<%= @parcel.id %>)">
      🔓 Desbloquear Ficha Completa — 1 Crédito
    </button>
    <% credits_left = current_user.subscription&.limit_parcels.to_i - current_user.subscription&.used_parcels.to_i %>
    <div class="fp-credit-hint"><%= credits_left %> créditos disponibles</div>
  </div>
</div>
<% end %>

<%# Unlocked / Admin banner %>
<% if @admin_override %>
  <div class="fp-admin-banner" id="ficha-unlocked-banner">
    <span>⚡</span>
    <span>Admin Override — Viewing full premium data. No credits consumed.</span>
  </div>
<% else %>
  <div class="fp-unlocked-banner<%= ' fp-visible' if @unlocked %>" id="ficha-unlocked-banner">
    <span>✅</span>
    <span>Ficha completa desbloqueada — todos los datos avanzados están disponibles.</span>
  </div>
<% end %>

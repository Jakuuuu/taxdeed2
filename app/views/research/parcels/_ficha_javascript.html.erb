<%# ─ PARTIAL: _ficha_javascript.html.erb ────────────────────────────────────
    Scripts inline de la Ficha: CRM Optimistic UI, Unlock flow,
    Google Maps GIS init, Local GIS boundary layer (ArcGIS REST proxy)
    + Lot Area hidratación.
    GOTCHA: innerHTML no ejecuta <script> — el drawer JS recrea los tags.
─────────────────────────────────────────────────────────────────────────── %>
<script>
  // ─── CRM chip — Optimistic UI visual toggle ────────────────────────────
  document.querySelectorAll('.crm-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      document.querySelectorAll('.crm-chip').forEach(function(c) { c.classList.remove('active'); });
      this.classList.add('active');
    });
  });

  // ─── Estado mutable de unlock (consultado por initFichaMap y reveal) ───
  window.__fichaUnlocked = <%= @unlocked ? 'true' : 'false' %>;

  // ─── Unlock action ─────────────────────────────────────────────────────
  function fichaUnlock(parcelId) {
    var btn = document.getElementById('ficha-unlock-btn');
    btn.disabled = true;
    btn.textContent = 'Desbloqueando…';

    fetch('/research/parcels/' + parcelId + '/unlock', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') || {}).content
      }
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.unlocked) {
        fichaRevealAll();
      } else {
        btn.disabled = false;
        btn.textContent = '🔓 Desbloquear Ficha Completa — 1 Crédito';
        alert(data.error || 'No se pudo desbloquear. Verifica tus créditos.');
      }
    })
    .catch(function() {
      btn.disabled = false;
      btn.textContent = '🔓 Desbloquear Ficha Completa — 1 Crédito';
      alert('Error de red. Intenta nuevamente.');
    });
  }

  function fichaRevealAll() {
    // Hide paywall CTA
    var cta = document.getElementById('ficha-paywall-cta');
    if (cta) cta.classList.add('fp-hidden');

    // Show unlocked banner
    var banner = document.getElementById('ficha-unlocked-banner');
    if (banner) banner.classList.add('fp-visible');

    // Show title report CTA
    var tr = document.getElementById('ficha-title-report');
    if (tr) tr.classList.remove('fp-hidden');

    // Staggered reveal of premium sections
    var sections = document.querySelectorAll('.fp-premium');
    sections.forEach(function(s, i) {
      setTimeout(function() {
        s.classList.remove('fp-locked');
        s.classList.add('fp-unlocked', 'fp-animating');
        setTimeout(function() { s.classList.remove('fp-animating'); }, 600);
      }, i * 120);
    });

    // Nota: fichaLoadParcelGeometry ya se carga en init (siempre visible).
    // No se requiere re-carga post-unlock.
    window.__fichaUnlocked = true;
  }

  // ─── Carga del polígono local GIS + cálculo de área ─────────────────
  //     Reemplaza Regrid: consulta ArcGIS REST vía nuestro proxy backend.
  //     Usa map.data (singleton) para evitar capas huérfanas en AJAX reloads.
  function fichaLoadParcelGeometry(map) {
    var coords = window.__fichaParcelCoords;
    if (!coords || !map) return;

    // Leer county/state de los data-attributes del contenedor del mapa
    var mapEl  = document.getElementById('ficha-map');
    var county      = mapEl ? mapEl.getAttribute('data-county') : null;
    var state       = mapEl ? mapEl.getAttribute('data-state')  : null;
    var auctionDate = mapEl ? mapEl.getAttribute('data-auction-date') : null;

    if (!county || !state) {
      console.warn('[Ficha GIS] Missing county/state data attributes — skipping polygon');
      return;
    }

    // Limpiar features previos del Data Layer (previene leaks en AJAX reload)
    fichaCleanupGisLayer(map);

    var url = '/api/local_gis/parcel_geometry'
      + '?lat=' + coords.lat
      + '&lng=' + coords.lng
      + '&county=' + encodeURIComponent(county)
      + '&state='  + encodeURIComponent(state);
    if (auctionDate) url += '&auction_date=' + encodeURIComponent(auctionDate);

    fetch(url, {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
    })
      .then(function(r) {
        if (!r.ok) {
          console.error('[Ficha GIS] HTTP', r.status, r.statusText, 'for', url);
          return null;
        }
        return r.json();
      })
      .then(function(geojson) {
        var card  = document.querySelector('[data-fp-lot-card]');
        var empty = document.querySelector('[data-fp-lot-empty]');

        function showEmpty() {
          if (empty) empty.hidden = false;
          if (card)  card.classList.add('fp-lot-empty-state');
        }

        if (!geojson || !geojson.features || geojson.features.length === 0) {
          showEmpty();
          return;
        }

        // Agregar features al Data Layer singleton del mapa
        map.data.addGeoJson(geojson);
        map.data.setStyle({
          strokeColor:   '#1E3A5F',
          strokeWeight:  2,
          strokeOpacity: 0.9,
          fillColor:     '#1E3A5F',
          fillOpacity:   0.15
        });

        // Auto-fit del mapa al extent del polígono (crítico para lotes pequeños)
        var bounds = new google.maps.LatLngBounds();
        map.data.forEach(function(feature) {
          var geom = feature.getGeometry();
          if (geom) {
            geom.forEachLatLng(function(latlng) {
              bounds.extend(latlng);
            });
          }
        });
        if (!bounds.isEmpty()) {
          map.fitBounds(bounds, { top: 30, right: 30, bottom: 30, left: 30 });
          // Prevenir zoom excesivo en lotes muy pequeños (regla: maxZoom 19)
          var listener = google.maps.event.addListenerOnce(map, 'idle', function() {
            if (map.getZoom() > 19) map.setZoom(19);
          });
        }

        if (!google.maps.geometry || !google.maps.geometry.spherical) return;

        // Suma rings exteriores, resta holes (convención GeoJSON RFC 7946)
        var totalAreaM2 = 0;
        map.data.forEach(function(feature) {
          var geom = feature.getGeometry();
          if (!geom) return;
          var type  = geom.getType();
          var polys = (type === 'MultiPolygon') ? geom.getArray() : [geom];
          polys.forEach(function(poly) {
            var rings = poly.getArray();
            rings.forEach(function(ring, idx) {
              var path = ring.getArray();
              var area = google.maps.geometry.spherical.computeArea(path);
              totalAreaM2 += (idx === 0 ? area : -area);
            });
          });
        });

        if (totalAreaM2 > 0) {
          var sqft  = Math.round(totalAreaM2 * 10.7639);
          var acres = (totalAreaM2 / 4046.86).toFixed(2);
          var sqftEl = document.querySelector('[data-fp-lot-area-sqft]');
          var acEl   = document.querySelector('[data-fp-lot-area-acres]');
          if (sqftEl) sqftEl.textContent = sqft.toLocaleString('en-US');
          if (acEl)   acEl.textContent   = acres;
        } else {
          showEmpty();
        }
      })
      .catch(function(err) {
        console.warn('[Ficha GIS] Polygon fetch error:', err);
      });
  }

  // ─── Limpieza de capa GIS (previene memory leaks en AJAX drawer) ────
  //     Debe llamarse antes de cada carga Y al cerrar el drawer.
  function fichaCleanupGisLayer(map) {
    if (!map || !map.data) return;
    map.data.forEach(function(feature) {
      map.data.remove(feature);
    });
  }

  <% if @parcel.has_coords? %>
  // ─── Google Maps GIS Map ──────────────────────────────────────────────
  (function() {
    function initFichaMap() {
      if (typeof google === 'undefined' || !google.maps) {
        console.warn('[Ficha] Google Maps API not loaded — skipping map init.');
        return;
      }

      var lat = <%= @parcel.latitude %>;
      var lng = <%= @parcel.longitude %>;
      window.__fichaParcelCoords = { lat: lat, lng: lng };

      var mapOptions = {
        center: { lat: lat, lng: lng },
        zoom: 16,
        scrollwheel: false,
        gestureHandling: 'cooperative',
        mapTypeId: 'roadmap',
        zoomControl: true,
        mapTypeControl: true,
        mapTypeControlOptions: { style: google.maps.MapTypeControlStyle.HORIZONTAL_BAR },
        streetViewControl: false,
        fullscreenControl: true
      };

      var mapIdMeta = document.querySelector('meta[name="google-maps-map-id"]');
      if (mapIdMeta && mapIdMeta.content) {
        mapOptions.mapId = mapIdMeta.content;
      }

      var map = new google.maps.Map(document.getElementById('ficha-map'), mapOptions);
      window.__fichaMap = map;

      // Advanced Marker with classic fallback
      var useAdvanced = google.maps.marker && google.maps.marker.AdvancedMarkerElement;
      var marker;

      if (useAdvanced) {
        var markerEl = document.createElement('div');
        markerEl.style.cssText = [
          'width:16px;height:16px;border-radius:50%;',
          'background:#1E3A5F;border:2.5px solid white;',
          'box-shadow:0 2px 8px rgba(30,58,95,0.5);'
        ].join('');
        marker = new google.maps.marker.AdvancedMarkerElement({
          map: map,
          position: { lat: lat, lng: lng },
          content: markerEl
        });
      } else {
        marker = new google.maps.Marker({
          map: map,
          position: { lat: lat, lng: lng },
          icon: {
            path: google.maps.SymbolPath.CIRCLE,
            scale: 7,
            fillColor: '#1E3A5F',
            fillOpacity: 1,
            strokeColor: '#ffffff',
            strokeWeight: 2.5
          }
        });
      }

      var infoWin = new google.maps.InfoWindow({
        content: '<strong><%= j @parcel.address %></strong><br><span style="font-size:11px;color:#6C757D;">APN: <%= j @parcel.parcel_id.to_s %></span>'
      });
      infoWin.open({ anchor: marker, map: map });
      marker.addListener('click', function() { infoWin.open({ anchor: marker, map: map }); });

      // Polígono del lote: siempre visible (no requiere unlock).
      // Geometría no contiene datos personales sensibles.
      fichaLoadParcelGeometry(map);
    }

    if (typeof google !== 'undefined' && google.maps) {
      initFichaMap();
    } else {
      document.addEventListener('google-maps:ready', initFichaMap, { once: true });
    }
  })();
  <% end %>
</script>

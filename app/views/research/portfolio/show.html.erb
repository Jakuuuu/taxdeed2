<%# ═══ Rama 5: My Portfolio — Pipeline Kanban CRM ═══════════════════════
    Layout: research (heredado). Drawer AJAX reutilizado de Rama 2.
    CSS inline obligatorio por: ningún yield :head fuera del layout.
    Atlas Design System tokens (OKLCH).
═══════════════════════════════════════════════════════════════════════ %>
<% content_for :title, "My Pipeline — LionTaxdeed" %>

<%# ── Inline CSS ── %>
<%= render "research/portfolio/pipeline_styles" %>

<%# ── Drawer backdrop & container (idéntico a Rama 2) ── %>
<div id="pf-backdrop" class="pf-backdrop" onclick="pfCloseDrawer()"></div>
<div id="pf-drawer" class="pf-drawer">
  <div id="pf-drawer-content" class="pf-drawer-content"></div>
</div>

<%# ── Add Stage Modal ── %>
<div id="pl-add-stage-modal" class="pl-modal-backdrop">
  <div class="pl-modal">
    <h3>➕ Add Stage</h3>
    <label for="pl-stage-name-input">Stage Name</label>
    <input type="text" id="pl-stage-name-input" placeholder="e.g., Under Contract" maxlength="40">
    <label for="pl-stage-emoji-input">Emoji (optional)</label>
    <input type="text" id="pl-stage-emoji-input" placeholder="e.g., 📃" maxlength="4">
    <div class="pl-modal__actions">
      <button class="pl-btn pl-btn--ghost" onclick="plCloseModal()">Cancel</button>
      <button class="pl-btn pl-btn--primary" onclick="plSubmitNewStage()">Create Stage</button>
    </div>
  </div>
</div>

<%# ── Toast ── %>
<div id="pl-toast" class="pl-toast"></div>

<%# ── Toolbar ── %>
<div class="pipeline__toolbar">
  <div class="pipeline__toolbar-title">🏗️ My Pipeline</div>
  <input type="search" class="pipeline__search" id="pl-search"
         placeholder="🔍 Search properties..." oninput="plFilter(this.value)">
</div>

<%# ── KPI Strip ── %>
<div class="pipeline__kpis">
  <div class="kpi-mini">
    <span class="kpi-mini__value" id="kpi-total"><%= @kpi_total %></span>
    <span class="kpi-mini__label">Total properties</span>
  </div>
  <div class="kpi-mini">
    <span class="kpi-mini__value" id="kpi-bids"><%= number_to_currency(@kpi_total_bids, precision: 0) %></span>
    <span class="kpi-mini__label">Total bids</span>
  </div>
  <div class="kpi-mini">
    <span class="kpi-mini__value" id="kpi-ready"><%= @kpi_ready %></span>
    <span class="kpi-mini__label">Ready to Bid</span>
  </div>
</div>

<%# ── Próximas subastas (colapsable, muestra 5 por defecto) ── %>
<% if @upcoming_pipeline.any? %>
<% upcoming_limit = 5 %>
<section class="upcoming-auctions" style="margin: 16px 24px; padding: 16px 18px; background: var(--surface-1); border: 1px solid var(--border); border-radius: 12px;">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; cursor:pointer; user-select:none;"
       onclick="plToggleUpcoming()" id="upcoming-header">
    <h3 style="font:600 14px var(--font-sans); color:var(--ink-1); margin:0;">
      📅 Próximas subastas
      <span style="font:500 11px var(--font-mono); color:var(--ink-3); margin-left:6px;">
        (<%= @upcoming_pipeline.size %>)
      </span>
    </h3>
    <span id="upcoming-toggle-icon"
          style="font-size:18px; color:var(--ink-3); transition:transform 0.3s ease; transform:rotate(0deg);">
      ▾
    </span>
  </div>
  <div id="upcoming-list" style="display:flex; flex-direction:column; gap:6px; overflow:hidden; transition: max-height 0.4s ease, opacity 0.3s ease;">
    <% @upcoming_pipeline.each_with_index do |pp, idx| %>
      <% p = pp.parcel; a = p.auction; days = (a.sale_date - Date.current).to_i %>
      <% watch = @watch_by_parcel[p.id] %>
      <% urgent = days == 0 || (watch && days <= watch.notify_days_before) %>
      <a href="<%= research_parcel_path(p) %>"
         class="upcoming-auction-row"
         data-upcoming-idx="<%= idx %>"
         style="display:grid; grid-template-columns: 90px 1fr auto auto; align-items:center; gap:12px;
                padding:10px 12px; border-radius:8px; text-decoration:none; color:var(--ink-1);
                background: <%= urgent ? 'oklch(0.95 0.05 60)' : 'var(--surface-2)' %>;
                border-left: 3px solid <%= urgent ? '#E67E22' : 'var(--border)' %>;
                transition: opacity 0.25s ease, max-height 0.3s ease;
                <%= idx >= upcoming_limit ? 'display:none;' : '' %>">
        <span style="font:600 12px var(--font-mono); color: <%= urgent ? '#E67E22' : 'var(--ink-2)' %>;">
          <%= days == 0 ? "HOY" : (days == 1 ? "Mañana" : "en #{days}d") %>
        </span>
        <span style="font:600 13px var(--font-sans); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
          <%= p.county %>, <%= p.state %> · <%= a.sale_date.strftime("%b %d, %Y") %>
        </span>
        <span style="font:500 11px var(--font-mono); color:var(--ink-3);">
          <%= watch ? "🔔 #{watch.notify_days_before}d" : "" %>
        </span>
        <span style="font:500 11px var(--font-sans); color:var(--accent);">Ver Ficha →</span>
      </a>
    <% end %>
  </div>
  <% if @upcoming_pipeline.size > upcoming_limit %>
    <button id="upcoming-show-more"
            onclick="event.stopPropagation(); plToggleUpcomingAll()"
            style="display:flex; align-items:center; justify-content:center; gap:6px;
                   width:100%; margin-top:10px; padding:8px 0; border:1px dashed var(--border);
                   border-radius:8px; background:transparent; color:var(--ink-2);
                   font:500 12px var(--font-sans); cursor:pointer; transition:all 0.2s ease;">
      <span id="upcoming-btn-text">Mostrar todas (<%= @upcoming_pipeline.size - upcoming_limit %> más)</span>
      <span id="upcoming-btn-icon" style="font-size:14px; transition:transform 0.3s ease;">▼</span>
    </button>
  <% end %>
</section>
<% end %>

<%# ── Pipeline Board ── %>
<div class="pipeline__board" id="pl-board">
  <% @stages.each do |stage| %>
    <div class="pipeline__column"
         data-stage-id="<%= stage.id %>"
         data-stage-default="<%= stage.is_default? %>"
         ondragover="plDragOver(event)" ondragleave="plDragLeave(event)" ondrop="plDrop(event)">
      <%# Column Header %>
      <div class="pipeline__column-header">
        <span class="pipeline__column-emoji"><%= stage.emoji %></span>
        <span class="pipeline__column-name"
              contenteditable="<%= !stage.is_default? %>"
              data-stage-id="<%= stage.id %>"
              onblur="plRenameStage(this, <%= stage.id %>)"
              title="<%= stage.is_default? ? 'Default stage' : 'Click to rename' %>"><%= stage.name %></span>
        <span class="count-pill" data-count-for="<%= stage.id %>"><%= stage.pipeline_properties.size %></span>
        <% unless stage.is_default? %>
          <button class="pipeline__column-menu" onclick="plDeleteStage(<%= stage.id %>, this)" title="Delete stage">🗑</button>
        <% end %>
      </div>

      <%# Column Body (cards) %>
      <div class="pipeline__column-body">
        <% stage.pipeline_properties.order(:position).each do |pp| %>
          <% parcel = pp.parcel %>
          <% tag    = @tags_by_parcel[parcel.id] %>
          <% note   = @notes_by_parcel[parcel.id] %>
          <div class="pipeline__card"
               draggable="true"
               data-property-id="<%= pp.id %>"
               data-parcel-id="<%= parcel.id %>"
               data-searchable="<%= [parcel.address, parcel.city, parcel.parcel_id].compact.join(' ').downcase %>"
               ondragstart="plDragStart(event)" ondragend="plDragEnd(event)">

            <%# Address + APN %>
            <div class="pipeline__card-address" title="<%= parcel.address %>">
              <%= parcel.address.presence || "—" %>
            </div>
            <% if parcel.parcel_id.present? %>
              <div class="pipeline__card-apn">APN: <%= parcel.parcel_id %></div>
            <% end %>

            <%# Tag chip + county %>
            <div class="pipeline__card-metrics">
              <% if tag %>
                <% tag_colors = { "target" => "accent", "diligence" => "warning", "ready" => "success", "dismissed" => "ink-3" } %>
                <span class="pipeline__chip" style="background: var(--<%= tag_colors[tag.tag] || 'surface-2' %>-soft); color: var(--<%= tag_colors[tag.tag] || 'ink-3' %>);">
                  <%= tag.tag.humanize %>
                </span>
              <% end %>
              <% if parcel.auction&.county.present? %>
                <span class="pipeline__chip">📍 <%= parcel.auction.county %></span>
              <% end %>
            </div>

            <%# Bid value %>
            <div class="pipeline__card-values">
              <div>
                <span class="pipeline__card-value-label">Bid</span>
                <span class="pipeline__card-value-amount">
                  <%= parcel.opening_bid ? number_to_currency(parcel.opening_bid, precision: 0) : "—" %>
                </span>
              </div>
              <div>
                <span class="pipeline__card-value-label">Assessed</span>
                <span class="pipeline__card-value-amount">
                  <%= parcel.assessed_value ? number_to_currency(parcel.assessed_value, precision: 0) : "—" %>
                </span>
              </div>
            </div>

            <%# Inline Note %>
            <div class="pipeline__card-note" data-pp-id="<%= pp.id %>">
              <p><%= pp.notes.presence || "Click to add a note..." %></p>
              <textarea placeholder="Add your notes..."><%= pp.notes %></textarea>
              <button class="pipeline__note-btn" onclick="plToggleNote(this)">✏️ edit</button>
            </div>

            <%# Footer: date + actions %>
            <div class="pipeline__card-footer">
              <span class="pipeline__card-date">
                <% if parcel.auction&.sale_date %>
                  🗓 <%= parcel.auction.sale_date.strftime("%b %d, %Y") %>
                  <% sale_diff = (parcel.auction.sale_date - Date.current).to_i %>
                  <% if sale_diff == 0 %>
                    <span style="display:inline-block; margin-left:6px; padding:1px 6px; border-radius:4px; background:#E67E22; color:#fff; font:600 10px var(--font-mono); letter-spacing:0.5px;">🔴 HOY</span>
                  <% elsif sale_diff < 0 && sale_diff > -ArchivePostAuctionPipelineJob::ARCHIVE_AFTER_DAYS %>
                    <span style="display:inline-block; margin-left:6px; padding:1px 6px; border-radius:4px; background:var(--ink-3); color:#fff; font:600 10px var(--font-mono); letter-spacing:0.5px;">⏳ <%= sale_diff %>d</span>
                  <% end %>
                <% end %>
              </span>
              <div style="display:flex;gap:6px;">
                <button class="pl-btn pl-btn--ghost pl-btn--sm"
                        onclick="event.stopPropagation(); pfOpenDrawer('/research/parcels/<%= parcel.id %>')"
                        title="Open full property card">
                  View →
                </button>
                <button class="pl-btn pl-btn--danger pl-btn--sm"
                        onclick="event.stopPropagation(); plRemoveProperty(<%= pp.id %>, this)"
                        title="Remove from pipeline">
                  ✕
                </button>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Add Stage Button ── %>
  <div class="pipeline__add-stage" onclick="plOpenModal()">
    <div class="pipeline__add-stage-icon">+</div>
    <span class="pipeline__add-stage-text">Add Stage</span>
  </div>
</div>

<script>
  // ══════════════════════════════════════════════════════════════════════
  // Pipeline Board — Vanilla JS (Sin dependencias externas)
  // ══════════════════════════════════════════════════════════════════════

  var PF_BASE_PATH = '<%= request.path %>';
  var CSRF_TOKEN   = document.querySelector('meta[name="csrf-token"]')?.content || '';

  // ── Upcoming Auctions — Collapse / Expand ───────────────────────────
  var _upcomingCollapsed = false;
  var _upcomingExpanded  = false;
  var UPCOMING_LIMIT     = 5;

  function plToggleUpcoming() {
    var list  = document.getElementById('upcoming-list');
    var icon  = document.getElementById('upcoming-toggle-icon');
    var btn   = document.getElementById('upcoming-show-more');

    _upcomingCollapsed = !_upcomingCollapsed;

    if (_upcomingCollapsed) {
      list.style.maxHeight  = '0';
      list.style.opacity    = '0';
      list.style.marginTop  = '0';
      icon.style.transform  = 'rotate(-90deg)';
      if (btn) btn.style.display = 'none';
    } else {
      list.style.maxHeight  = list.scrollHeight + 'px';
      list.style.opacity    = '1';
      list.style.marginTop  = '';
      icon.style.transform  = 'rotate(0deg)';
      if (btn) btn.style.display = 'flex';
      // Reset max-height after transition so dynamically added content works
      setTimeout(function() { list.style.maxHeight = 'none'; }, 450);
    }
  }

  function plToggleUpcomingAll() {
    _upcomingExpanded = !_upcomingExpanded;
    var rows    = document.querySelectorAll('.upcoming-auction-row');
    var btnText = document.getElementById('upcoming-btn-text');
    var btnIcon = document.getElementById('upcoming-btn-icon');

    rows.forEach(function(row) {
      var idx = parseInt(row.dataset.upcomingIdx, 10);
      if (idx >= UPCOMING_LIMIT) {
        row.style.display = _upcomingExpanded ? 'grid' : 'none';
      }
    });

    if (_upcomingExpanded) {
      btnText.textContent = 'Mostrar menos';
      btnIcon.textContent = '▲';
      btnIcon.style.transform = 'rotate(180deg)';
    } else {
      var hiddenCount = rows.length - UPCOMING_LIMIT;
      btnText.textContent = 'Mostrar todas (' + hiddenCount + ' más)';
      btnIcon.textContent = '▼';
      btnIcon.style.transform = 'rotate(0deg)';
    }
  }

  // ── Helpers ──────────────────────────────────────────────────────────
  function plHeaders() {
    return {
      'Content-Type': 'application/json',
      'X-CSRF-Token': CSRF_TOKEN,
      'X-Requested-With': 'XMLHttpRequest'
    };
  }

  function plToast(msg, isError) {
    var t = document.getElementById('pl-toast');
    t.textContent = msg;
    t.style.background = isError ? 'var(--danger)' : 'var(--ink-1)';
    t.classList.add('visible');
    clearTimeout(t._timer);
    t._timer = setTimeout(function() { t.classList.remove('visible'); }, 2400);
  }

  function plUpdateCounts() {
    document.querySelectorAll('.pipeline__column').forEach(function(col) {
      var stageId = col.dataset.stageId;
      var count   = col.querySelectorAll('.pipeline__card').length;
      var pill    = col.querySelector('[data-count-for="' + stageId + '"]');
      if (pill) pill.textContent = count;
    });
    // KPI total
    var totalCards = document.querySelectorAll('.pipeline__card').length;
    var kpiTotal   = document.getElementById('kpi-total');
    if (kpiTotal) kpiTotal.textContent = totalCards;
  }

  // ── Drag & Drop ────────────────────────────────────────────────────
  var _draggedCard = null;

  function plDragStart(e) {
    _draggedCard = e.target.closest('.pipeline__card');
    _draggedCard.classList.add('pipeline__card--dragging');
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', _draggedCard.dataset.propertyId);
  }

  function plDragEnd(e) {
    if (_draggedCard) _draggedCard.classList.remove('pipeline__card--dragging');
    document.querySelectorAll('.pipeline__column--drag-over').forEach(function(col) {
      col.classList.remove('pipeline__column--drag-over');
    });
    _draggedCard = null;
  }

  function plDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    var col = e.target.closest('.pipeline__column');
    if (col) col.classList.add('pipeline__column--drag-over');
  }

  function plDragLeave(e) {
    var col = e.target.closest('.pipeline__column');
    if (col && !col.contains(e.relatedTarget)) {
      col.classList.remove('pipeline__column--drag-over');
    }
  }

  function plDrop(e) {
    e.preventDefault();
    var col = e.target.closest('.pipeline__column');
    if (!col || !_draggedCard) return;
    col.classList.remove('pipeline__column--drag-over');

    var newStageId  = col.dataset.stageId;
    var propId      = _draggedCard.dataset.propertyId;
    var body        = col.querySelector('.pipeline__column-body');

    // Optimistic UI: move card immediately
    body.appendChild(_draggedCard);
    _draggedCard.classList.remove('pipeline__card--dragging');
    plUpdateCounts();

    // Persist
    fetch('/research/portfolio/properties/' + propId + '/move', {
      method: 'PATCH',
      headers: plHeaders(),
      body: JSON.stringify({ stage_id: newStageId })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Move failed');
      return r.json();
    })
    .then(function(data) {
      plToast('Moved to ' + (data.stage_name || 'new stage'));
    })
    .catch(function(err) {
      plToast('Failed to move — please refresh', true);
    });
  }

  // ── Inline Notes ───────────────────────────────────────────────────
  function plToggleNote(btn) {
    var noteDiv  = btn.closest('.pipeline__card-note');
    var isEditing = noteDiv.classList.contains('pipeline__card-note--editing');

    if (isEditing) {
      // Save
      var textarea = noteDiv.querySelector('textarea');
      var ppId     = noteDiv.dataset.ppId;
      var newNote  = textarea.value.trim();

      noteDiv.classList.remove('pipeline__card-note--editing');
      noteDiv.querySelector('p').textContent = newNote || 'Click to add a note...';
      btn.innerHTML = '✏️ edit';

      fetch('/research/portfolio/properties/' + ppId + '/update_note', {
        method: 'PATCH',
        headers: plHeaders(),
        body: JSON.stringify({ body: newNote })
      })
      .then(function(r) {
        if (!r.ok) throw new Error('Note save failed');
        plToast('Note saved ✓');
      })
      .catch(function() { plToast('Failed to save note', true); });
    } else {
      // Edit mode
      noteDiv.classList.add('pipeline__card-note--editing');
      btn.innerHTML = '💾 save';
      var textarea = noteDiv.querySelector('textarea');
      textarea.focus();
    }
  }

  // ── Stage Management ───────────────────────────────────────────────
  function plOpenModal() {
    var modal = document.getElementById('pl-add-stage-modal');
    modal.classList.add('active');
    document.getElementById('pl-stage-name-input').value = '';
    document.getElementById('pl-stage-emoji-input').value = '';
    document.getElementById('pl-stage-name-input').focus();
  }

  function plCloseModal() {
    document.getElementById('pl-add-stage-modal').classList.remove('active');
  }

  function plSubmitNewStage() {
    var name  = document.getElementById('pl-stage-name-input').value.trim();
    var emoji = document.getElementById('pl-stage-emoji-input').value.trim() || '📋';

    if (!name) { plToast('Please enter a stage name', true); return; }

    fetch('/research/portfolio/stages', {
      method: 'POST',
      headers: plHeaders(),
      body: JSON.stringify({ name: name, emoji: emoji })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Create failed');
      return r.json();
    })
    .then(function(data) {
      plCloseModal();
      plToast('Stage "' + name + '" created ✓');
      // Insert new column before the "Add Stage" button
      var board   = document.getElementById('pl-board');
      var addBtn  = board.querySelector('.pipeline__add-stage');
      var col     = document.createElement('div');
      col.className = 'pipeline__column';
      col.dataset.stageId = data.id;
      col.dataset.stageDefault = 'false';
      col.setAttribute('ondragover', 'plDragOver(event)');
      col.setAttribute('ondragleave', 'plDragLeave(event)');
      col.setAttribute('ondrop', 'plDrop(event)');
      col.innerHTML = '<div class="pipeline__column-header">'
        + '<span class="pipeline__column-emoji">' + emoji + '</span>'
        + '<span class="pipeline__column-name" contenteditable="true" data-stage-id="' + data.id + '" onblur="plRenameStage(this,' + data.id + ')">' + name + '</span>'
        + '<span class="count-pill" data-count-for="' + data.id + '">0</span>'
        + '<button class="pipeline__column-menu" onclick="plDeleteStage(' + data.id + ',this)" title="Delete stage">🗑</button>'
        + '</div>'
        + '<div class="pipeline__column-body"></div>';
      board.insertBefore(col, addBtn);
    })
    .catch(function() { plToast('Failed to create stage', true); });
  }

  function plRenameStage(el, stageId) {
    var newName = el.textContent.trim();
    if (!newName) return;

    fetch('/research/portfolio/stages/' + stageId, {
      method: 'PATCH',
      headers: plHeaders(),
      body: JSON.stringify({ name: newName })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Rename failed');
      plToast('Stage renamed ✓');
    })
    .catch(function() { plToast('Failed to rename stage', true); });
  }

  function plDeleteStage(stageId, btn) {
    if (!confirm('Delete this stage? Properties inside will need to be reassigned.')) return;

    fetch('/research/portfolio/stages/' + stageId, {
      method: 'DELETE',
      headers: plHeaders()
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Delete failed');
      var col = btn.closest('.pipeline__column');
      col.style.transform = 'scale(0.95)';
      col.style.opacity = '0';
      setTimeout(function() { col.remove(); }, 300);
      plToast('Stage deleted');
    })
    .catch(function() { plToast('Cannot delete default stage', true); });
  }

  // ── Remove Property ────────────────────────────────────────────────
  function plRemoveProperty(propId, btn) {
    if (!confirm('Remove this property from your pipeline?')) return;

    fetch('/research/portfolio/properties/' + propId, {
      method: 'DELETE',
      headers: plHeaders()
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Remove failed');
      var card = btn.closest('.pipeline__card');
      card.style.transform = 'scale(0.95)';
      card.style.opacity = '0';
      setTimeout(function() { card.remove(); plUpdateCounts(); }, 300);
      plToast('Property removed');
    })
    .catch(function() { plToast('Failed to remove property', true); });
  }

  // ── Search / Filter ────────────────────────────────────────────────
  function plFilter(query) {
    var q = query.toLowerCase().trim();
    document.querySelectorAll('.pipeline__card').forEach(function(card) {
      var text = card.dataset.searchable || '';
      card.style.display = (!q || text.indexOf(q) !== -1) ? '' : 'none';
    });
  }

  // ── Drawer (mismo patrón Rama 2) ───────────────────────────────────
  function pfOpenDrawer(url) {
    var backdrop = document.getElementById('pf-backdrop');
    var drawer   = document.getElementById('pf-drawer');
    var content  = document.getElementById('pf-drawer-content');

    backdrop.classList.add('is-open');
    drawer.classList.add('is-open');
    window.history.pushState({ path: url }, '', url);

    content.innerHTML = '<div style="display:flex;height:100%;align-items:center;justify-content:center;color:var(--ink-3);padding:4rem;"><div class="map-spinner"></div></div>';

    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.text(); })
      .then(function(html) {
        content.innerHTML = html;
        content.querySelectorAll('script').forEach(function(old) {
          var s = document.createElement('script');
          s.textContent = old.textContent;
          old.replaceWith(s);
        });
      })
      .catch(function() {
        content.innerHTML = '<div style="padding:2rem;text-align:center;color:#E74C3C;">Failed to load property. <button onclick="pfCloseDrawer()" style="margin-top:1rem;padding:0.4rem 0.8rem;border:1px solid #E74C3C;border-radius:6px;background:none;cursor:pointer;color:#E74C3C;">Close</button></div>';
      });
  }

  function pfCloseDrawer() {
    var backdrop = document.getElementById('pf-backdrop');
    var drawer   = document.getElementById('pf-drawer');
    if (backdrop) backdrop.classList.remove('is-open');
    if (drawer)   drawer.classList.remove('is-open');
    window.history.pushState({}, '', PF_BASE_PATH);
  }

  // ESC y popstate
  function pfEscHandler(e) { if (e.key === 'Escape') { pfCloseDrawer(); plCloseModal(); } }
  function pfPopHandler()  { if (window.location.pathname === PF_BASE_PATH) pfCloseDrawer(); }

  document.addEventListener('keydown', pfEscHandler);
  window.addEventListener('popstate', pfPopHandler);

  // Turbo lifecycle cleanup
  document.addEventListener('turbo:before-cache', function() {
    var backdrop = document.getElementById('pf-backdrop');
    var drawer   = document.getElementById('pf-drawer');
    var content  = document.getElementById('pf-drawer-content');
    if (backdrop) backdrop.classList.remove('is-open');
    if (drawer)   drawer.classList.remove('is-open');
    if (content)  content.innerHTML = '';
    document.removeEventListener('keydown', pfEscHandler);
    window.removeEventListener('popstate', pfPopHandler);
  }, { once: true });
</script>
